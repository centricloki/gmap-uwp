<UserControl
    x:Class="DRLMobile.Uwp.CustomControls.PreviewDocumentControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="using:DRLMobile.Uwp.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DRLMobile.Uwp.CustomControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Background="{StaticResource FooterBackgroundColor}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                x:Name="TitleTextBlock"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                d:Text="Title text"
                FontSize="{StaticResource MediumFontSize}"
                Foreground="White"
                TextWrapping="Wrap" />


            <StackPanel
                Margin="0,0,5,5"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="20">

                <FontIcon
                    Name="PrintIcon"
                    Margin="0,10,5,0"
                    FontSize="25"
                    Foreground="{StaticResource FooterTextColor}"
                    Glyph="{StaticResource PrintIcon}"
                    Style="{StaticResource FontIconStyle}"
                    Tapped="PrintIcon_Tapped"
                    Visibility="{x:Bind IsPrintEmailIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <FontIcon
                    Name="EmailIcon"
                    Margin="0,10,5,0"
                    FontSize="25"
                    Foreground="{StaticResource FooterTextColor}"
                    Glyph="{StaticResource MailIcon}"
                    Style="{StaticResource FontIconStyle}"
                    Tapped="EmailIcon_Tapped"
                    Visibility="{x:Bind IsPrintEmailIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <FontIcon
                    Grid.Column="1"
                    Margin="0,10,5,0"
                    VerticalAlignment="Center"
                    FontSize="25"
                    Foreground="White"
                    Glyph="{StaticResource CancelIcon}"
                    Style="{StaticResource FontIconStyle}"
                    Tapped="ClosePreviewer" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Background="White">
            <FlipView x:Name="imageFlipView">
                <FlipView.ItemTemplate>
                    <DataTemplate x:DataType="local:CustomImage">
                        <ScrollViewer
                            DoubleTapped="ScrollViewer_DoubleTapped"
                            MinZoomFactor="1"
                            ZoomMode="Enabled">
                            <Image Source="{Binding Path}" />
                        </ScrollViewer>
                    </DataTemplate>
                </FlipView.ItemTemplate>
            </FlipView>
        </Grid>

    </Grid>
</UserControl>