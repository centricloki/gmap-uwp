                                                    BorderBrush="Transparent"
                                                    Foreground="{StaticResource LoginScreenTextFontColor}"
                                                    PlaceholderForeground="{StaticResource LoginScreenTextFontColor}"
                                                    PlaceholderText="{Binding Unit}"
                                                    SelectionChanged="UnitComboBox_SelectionChanged">
                                                    <x:String>CA</x:String>
                                                    <x:String>BX</x:String>
                                                    <x:String>EA</x:String>
                                                    <x:String>IP</x:String>
                                                    <x:String>BK</x:String>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>

                                    <DE:GridTemplateColumn
                                        x:Name="CreditRequest"
                                        MinWidth="110"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="CreditRequest">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Credit Request" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                    Name="CreditRequestComboBox"
                                                    Width="80"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Foreground="{StaticResource LoginScreenTextFontColor}"
                                                    ItemsSource="{Binding RtnDifCreditRequestComboboxList, Mode=TwoWay}"
                                                    PlaceholderForeground="{StaticResource LoginScreenTextFontColor}"
                                                    PlaceholderText="{Binding CreditRequest}"
                                                    SelectionChanged="RtnGridCreditRequestComboBox_SelectionChanged">
                                                    <x:String>DIF-Destroyed</x:String>
                                                    <x:String>RTN-Retail Returns</x:String>
                                                    <x:String>RTN-Out Of Code</x:String>
                                                    <x:String>RTN-Defective</x:String>
                                                    <x:String>RTN-Overstock</x:String>
                                                    <x:String>RTN-Discontinued</x:String>
                                                    <x:String>RTN-Reset</x:String>
                                                    <x:String>RTN-Mispick</x:String>
                                                    <x:String>RTN-Misship</x:String>
                                                    <x:String>RTN-Order Error</x:String>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>

                                    <DE:GridTemplateColumn
                                        x:Name="rtnunitPrice"
                                        Width="127"
                                        HorizontalAlignment="Stretch"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="PriceDisplay">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unit Price" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Editors:TextEdit
                                                        x:Name="rtnTextEdit"
                                                        Width="80"
                                                        CornerRadius="10"
                                                        FlyoutBase.AttachedFlyout="{StaticResource CustomPriceKeyPadFlyout}"
                                                        GotFocus="RtnUnitPrice_GotFocus"
                                                        PointerExited="UnitPriceTextEdit_PointerExited"
                                                        Text="{Binding PriceDisplay, Mode=TwoWay}">
                                                        <Editors:TextEdit.TextInputSettings>
                                                            <Editors:TextInputMaskSettings
                                                                IgnoreBlank="True"
                                                                Mask="\$(\d{0,4}\.?\d{1,2})?"
                                                                MaskType="RegEx"
                                                                SaveLiteral="True" />
                                                        </Editors:TextEdit.TextInputSettings>
                                                    </Editors:TextEdit>
                                                    <Image
                                                        x:Name="rtnunitPriceImage"
                                                        Width="15"
                                                        Height="15"
                                                        Margin="3,0,0,0"
                                                        Source="{StaticResource EditCart}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>

                                    <DE:GridTextColumn
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="TotalDisplay"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Subtotal" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTemplateColumn
                                        x:Name="rtndelete"
                                        Width="80"
                                        AllowColumnFiltering="False"
                                        FieldName="DeleteImage">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Tapped="Delete_Tapped">
                                                    <Image
                                                        x:Name="deleteImage"
                                                        Width="20"
                                                        Height="20"
                                                        Source="{StaticResource DeleteCart}" />
                                                </Grid>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                </DE:GridControl.Columns>
                            </DE:GridControl>

                            <StackPanel
                                Grid.Row="1"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource LoginButtonBackground}">
                                <StackPanel
                                    Padding="10,10,50,10"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="Sub Total:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="{x:Bind ViewModel.CartDetailModel.OrderDetailModel.SubTotalUpperDisplay, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </controls:Expander>
                </StackPanel>

                <!--  DIF Grid  -->
                <StackPanel
                    x:Name="difStack"
                    Grid.Row="2"
                    Margin="10"
                    x:Load="{x:Bind ViewModel.LoadCreditRequestGrids, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.CartDetailModel.DifGridVisibility, Mode=OneWay}">
                    <controls:Expander HorizontalAlignment="Stretch" IsExpanded="True">
                        <controls:Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    HorizontalAlignment="Left"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource CartTextColor}"
                                    Text="DIF" />
                            </Grid>
                        </controls:Expander.Header>

                        <Grid x:Name="DIFGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DE:GridControl
                                x:Name="DIFDataGridcontrol"
                                Grid.Row="0"
                                AlternationCount="2"
                                AutoGenerateColumns="False"
                                FontSize="{StaticResource DataGridTextSize}"
                                ItemsSource="{x:Bind ViewModel.DifGridDataSource, Mode=TwoWay}"
                                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                ShowAutoFilterRow="False"
                                ShowCriteriaInAutoFilterRow="True"
                                ShowGroupPanel="False"
                                ShowGroupedColumns="False">
                                <DE:GridControl.Columns>
                                    <DE:GridTemplateColumn
                                        x:Name="isAllDIFLowerGridSelected"
                                        Width="60"
                                        AllowColumnFiltering="False"
                                        AllowSorting="False"
                                        FieldName="IsAllLowerGridSelected">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <CheckBox
                                                    x:Name="LowerGridheaderCheckbox"
                                                    Width="10"
                                                    Height="10"
                                                    Checked="LowerGridheaderCheckbox_Checked"
                                                    IsChecked="{Binding IsLowerGridSelectAllChecked, Mode=TwoWay}"
                                                    Unchecked="LowerGridheaderCheckbox_Unchecked" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsAllLowerGridSelected, Mode=TwoWay}" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                    <DE:GridTextColumn
                                        Width="100"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="BrandName"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Brand" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTextColumn
                                        Width="100"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="StyleName"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Style" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTextColumn
                                        Width="90"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="ItemNumber"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTextColumn
                                        Width="240"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="ItemDescription"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTemplateColumn
                                        x:Name="DIFQuantity"
                                        Width="120"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="QuantityDisplay">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Quantity" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox
                                                        x:Name="DIFQuantityTextBlock"
                                                        Width="70"
                                                        BeforeTextChanging="rtnquantityTextBlock_BeforeTextChanging"
                                                        FlyoutBase.AttachedFlyout="{StaticResource CustomKeyPadFlyout}"
                                                        Foreground="{StaticResource LoginScreenTextFontColor}"
                                                        GotFocus="DIFQuantityTextBlock_GotFocus"
                                                        MaxLength="5"
                                                        PointerExited="QuantityTextBlock_PointerExited"
                                                        Text="{Binding QuantityDisplay, Mode=TwoWay}" />
                                                    <Image
                                                        x:Name="DIFQuantityImage"
                                                        Width="15"
                                                        Height="15"
                                                        Margin="2,0,0,0"
                                                        Source="{StaticResource EditCart}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>

                                    <DE:GridTemplateColumn
                                        x:Name="DIFUnit"
                                        MinWidth="110"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="Unit">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unit" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                    Name="DIFUnitComboBox"
                                                    Width="80"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Foreground="{StaticResource LoginScreenTextFontColor}"
                                                    PlaceholderForeground="{StaticResource LoginScreenTextFontColor}"
                                                    PlaceholderText="{Binding Unit}"
                                                    SelectionChanged="UnitComboBox_SelectionChanged">
                                                    <x:String>CA</x:String>
                                                    <x:String>BX</x:String>
                                                    <x:String>EA</x:String>
                                                    <x:String>IP</x:String>
                                                    <x:String>BK</x:String>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>

                                    <DE:GridTemplateColumn
                                        x:Name="DIFCreditRequest"
                                        MinWidth="110"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="CreditRequest">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Credit Request" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                    Name="DIFCreditRequestComboBox"
                                                    Width="80"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Foreground="{StaticResource LoginScreenTextFontColor}"
                                                    ItemsSource="{Binding RtnDifCreditRequestComboboxList, Mode=TwoWay}"
                                                    PlaceholderForeground="{StaticResource LoginScreenTextFontColor}"
                                                    PlaceholderText="{Binding CreditRequest}"
                                                    SelectionChanged="DIFCreditRequestComboBox_SelectionChanged">
                                                    <x:String>DIF-Destroyed</x:String>
                                                    <x:String>RTN-Retail Returns</x:String>
                                                    <x:String>RTN-Out Of Code</x:String>
                                                    <x:String>RTN-Defective</x:String>
                                                    <x:String>RTN-Overstock</x:String>
                                                    <x:String>RTN-Discontinued</x:String>
                                                    <x:String>RTN-Reset</x:String>
                                                    <x:String>RTN-Mispick</x:String>
                                                    <x:String>RTN-Misship</x:String>
                                                    <x:String>RTN-Order Error</x:String>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>

                                    <DE:GridTemplateColumn
                                        x:Name="DifUnitPrice"
                                        Width="127"
                                        HorizontalAlignment="Stretch"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="PriceDisplay">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unit Price" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Editors:TextEdit
                                                        x:Name="nonTobaccoTextEdit"
                                                        Width="80"
                                                        CornerRadius="10"
                                                        FlyoutBase.AttachedFlyout="{StaticResource CustomPriceKeyPadFlyout}"
                                                        GotFocus="DifUnitPrice_GotFocus"
                                                        PointerExited="UnitPriceTextEdit_PointerExited"
                                                        Text="{Binding PriceDisplay, Mode=TwoWay}">
                                                        <Editors:TextEdit.TextInputSettings>
                                                            <Editors:TextInputMaskSettings
                                                                IgnoreBlank="True"
                                                                Mask="\$(\d{0,4}\.?\d{1,2})?"
                                                                MaskType="RegEx"
                                                                SaveLiteral="True" />
                                                        </Editors:TextEdit.TextInputSettings>
                                                    </Editors:TextEdit>
                                                    <Image
                                                        x:Name="nonTobaccoUnitPriceImage"
                                                        Width="15"
                                                        Height="15"
                                                        Margin="2,0,0,0"
                                                        Source="{StaticResource EditCart}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>

                                    <DE:GridTextColumn
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="TotalDisplay"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Subtotal" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTemplateColumn
                                        x:Name="DifDelete"
                                        AllowColumnFiltering="False"
                                        FieldName="DeleteImage">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Tapped="Delete_Tapped">
                                                    <Image
                                                        x:Name="nonTobaccoDeleteImage"
                                                        Width="20"
                                                        Height="20"
                                                        Source="{StaticResource DeleteCart}" />
                                                </Grid>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                </DE:GridControl.Columns>
                            </DE:GridControl>
                            <StackPanel
                                Grid.Row="1"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource LoginButtonBackground}">
                                <StackPanel
                                    Padding="10,10,50,10"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="Sub Total:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="{x:Bind ViewModel.CartDetailModel.OrderDetailModel.SubTotalLowerDisplay, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                    </controls:Expander>
                </StackPanel>

                <StackPanel
                    Grid.Row="3"
                    HorizontalAlignment="Stretch"
                    Visibility="{x:Bind ViewModel.CartDetailModel.GrandTotalVisibility, Mode=OneWay}">
                    <StackPanel
                        Padding="10,10,50,10"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontWeight="Bold"
                            Foreground="{StaticResource CartTextColor}"
                            Text="Grand Total:" />
                        <TextBlock
                            HorizontalAlignment="Right"
                            Foreground="{StaticResource CartTextColor}"
                            Text="{x:Bind ViewModel.CartDetailModel.OrderDetailModel.GrandTotalDisplay, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <StackPanel
            x:Name="grandTotalStack"
            Grid.Row="2"
            Margin="0,15,0,15"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Orientation="Horizontal"
            Visibility="{x:Bind ViewModel.CartDetailModel.BottomButtonVisiblity, Mode=OneWay}">
            <Button
                x:Name="PlaceOrderButton"
                Command="{x:Bind ViewModel.EmailFactSheetCommad}"
                Content="Email Factsheet"
                Style="{StaticResource CustomerDetailPageButton}" />
            <Button
                x:Name="DocumentsButton"
                Margin="{StaticResource SmallLeftMargin}"
                Command="{x:Bind ViewModel.PlaceAnOderButtonCommand}"
                Content="{x:Bind ViewModel.PurchaseOrderButtonText, Mode=TwoWay}"
                RelativePanel.RightOf="PlaceOrderButton"
                Style="{StaticResource CustomerDetailPageButton}" />
        </StackPanel>

        <toolkit:Loading
            Grid.Row="0"
            Grid.RowSpan="3"
            IsLoading="{x:Bind ViewModel.CartDetailModel.IsLoading, Mode=OneWay}">
            <controls:Loading.Background>
                <SolidColorBrush Opacity="0.4" Color="Black" />
            </controls:Loading.Background>
            <StackPanel
                Padding="12"
                Orientation="Vertical"
                Spacing="10">
                <ProgressBar
                    Width="{Binding ElementName=PageName, Path=ActualWidth}"
                    Foreground="White"
                    IsIndeterminate="True" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="{StaticResource LargeFontSize}"
                    Foreground="White"
                    Text="{x:Bind ViewModel.CartDetailModel.LoadingText, Mode=OneWay}" />
            </StackPanel>
        </toolkit:Loading>

    </Grid>
</Page>
