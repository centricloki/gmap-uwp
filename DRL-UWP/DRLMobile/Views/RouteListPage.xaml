                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Customer#" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
