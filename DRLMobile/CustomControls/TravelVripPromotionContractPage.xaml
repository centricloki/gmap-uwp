                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="SecondPaymentID"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Tradeshow Booth Request #" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

            </DE:GridControl.Columns>
        </DE:GridControl>

        <!--  Contract Grid  -->
        <DE:GridControl
            x:Name="ContractDataGridcontrol"
            Grid.Row="2"
            x:Load="{x:Bind ViewModel.IsContractGridLoaded, Mode=OneWay}"
            AlternationCount="2"
            AutoGenerateColumns="False"
            FontSize="{StaticResource DataGridTextSize}"
            ItemsSource="{x:Bind ViewModel.ContractGridDataSource, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ShowAutoFilterRow="True"
            ShowCriteriaInAutoFilterRow="True"
            ShowGroupPanel="False"
            ShowGroupedColumns="False"
            ShowSearchPanelMode="Never"
            Visibility="{x:Bind ViewModel.IsContractGridVisible, Mode=OneWay}">
            <DE:GridControl.Columns>
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="ContractID"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Promo #" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="ContractPlanType"
                    TextWrapping="WrapWholeWords">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Plan Type" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="ContractYear"
                    TextWrapping="Wrap">
