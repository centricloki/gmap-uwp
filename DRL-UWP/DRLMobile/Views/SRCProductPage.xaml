<Page
    x:Class="DRLMobile.Views.SRCProductPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:customControls="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:localConverter="using:DRLMobile.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="srcProductPage"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <localConverter:BoolToCartImageConverter x:Key="cartImageCovnerter" />
        <localConverter:BoolToFavoriteImageConverter x:Key="favoriteImageConverter" />
        <localConverter:BoolToFavoriteDetailImageConverter x:Key="favoriteDetailImageConverter" />
        <localConverter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <SolidColorBrush x:Key="SystemColors.HighlightBrushKey" Color="Transparent" />
        <SolidColorBrush x:Key="SystemColors.ControlBrushKey" Color="Transparent" />
        <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
        <Style x:Key="TextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
        <Flyout
            x:Key="CustomKeyPadFlyout"
            x:Name="QuantityCustomKeyPadFlyout"
            FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
            LightDismissOverlayMode="Off"
            Placement="Left">
            <customControls:CustomKeypad
                DoneClickEvent="CustomKeypad_DoneClickEvent"
                IsDotButtonVisible="Collapsed"
                IsMinusButtonVisible="Visible"
                NumPadButtonClick="{x:Bind SrcProductPageViewModel.NumPadButtonClickCommand, Mode=OneWay}" />
        </Flyout>
    </Page.Resources>
    <Grid x:Name="gridpanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />

        </Grid.RowDefinitions>
        <customControls:HeaderControl
            Title="RESOURCES"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            BadgeText="{x:Bind SrcProductPageViewModel.BadgeText, Mode=OneWay}"
            CartButtonClick="{x:Bind SrcProductPageViewModel.CartButtonCommand, Mode=OneWay}"
            ComboBoxValueChangedCommand="{x:Bind SrcProductPageViewModel.HeaderComboBoxClickedCommand}"
            CustomerAddressText="{x:Bind SrcProductPageViewModel.CustomerAddresss, Mode=OneWay}"
            CustomerNameText="{x:Bind SrcProductPageViewModel.CustomerNameNumber, Mode=OneWay}"
            CustomerPanelClick="{x:Bind SrcProductPageViewModel.CustomerPanelClickCommand, Mode=OneWay}"
            CustomerSubAddressText="{x:Bind SrcProductPageViewModel.CustomerCityState, Mode=OneWay}"
            DisplayMemberPathValue="SearchDisplayPath"
            IsAutoSuggestBoxVisible="Visible"
            IsBadgeVisible="{x:Bind SrcProductPageViewModel.IsBadgeVisible, Mode=OneWay}"
            IsCartButtonVisible="Visible"
            IsComboBoxVisible="Visible"
            IsCustomerPanelVisible="{x:Bind SrcProductPageViewModel.CustomerTitlePanelVisibility, Mode=OneWay}"
            IsPageTitleVisible="Visible"
            ItemList="{x:Bind SrcProductPageViewModel.HeaderSearchItemSource, Mode=TwoWay}"
            PlaceHolderText="Search by Name or Number"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SuggestionChoosenCommand="{x:Bind SrcProductPageViewModel.HeaderSearchSuggestionChoosenCommand}"
            TextValueChangedCommand="{x:Bind SrcProductPageViewModel.HeaderSearchTextChangeCommand}" />

        <!--  Category List  -->
        <ListBox
            x:Name="LvCategory"
            Grid.Row="1"
            Padding="0"
            Background="{StaticResource LoginButtonBackground}"
            ItemsSource="{Binding CategoryList, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.IsHorizontalRailEnabled="False"
            ScrollViewer.VerticalScrollMode="Disabled"
            SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
            SelectionMode="Multiple">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="10,10,5,5" />
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel
                        x:Name="CategoryStack"
                        Height="60"
                        Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <ListBoxItem Margin="0" Padding="0">

                        <RelativePanel
                            x:Name="CategoryRelativePanel"
                            Padding="0"
                            Tapped="CategoryRelativePanel_Tapped">
                            <Image
                                x:Name="CategoryImage"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Source="{Binding CategoryImage}" />
                            <TextBlock
                                x:Name="CategoryText"
                                FontSize="{StaticResource FooterFontSize}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource FooterTextColor}"
                                RelativePanel.AlignHorizontalCenterWithPanel="True"
                                RelativePanel.AlignVerticalCenterWithPanel="True"
                                Text="{Binding CategoryName}" />
                        </RelativePanel>
                    </ListBoxItem>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!--  Brand List  -->
        <ListBox
            x:Name="LvBrand"
            Grid.Row="2"
            Padding="0"
            Background="{StaticResource LoginButtonBackground}"
            ItemsSource="{Binding BrandList, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.IsHorizontalRailEnabled="False"
            ScrollViewer.VerticalScrollMode="Disabled"
            SelectionMode="Multiple">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="10,0,5,5" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel
                        x:Name="BrandStack"
                        Height="60"
                        Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <ListBoxItem Margin="0" Padding="0">
                        <Grid Background="Transparent" Tapped="BrandGrid_Tapped">
                            <Image
                                Name="ProductImage"
                                Width="120"
                                Margin="8,5,8,10"
                                Source="{StaticResource NoProduct}"
                                Stretch="Fill" />
                            <Image
                                Name="SelectedImagePanel"
                                Width="120"
                                Margin="0"
                                Source="{Binding SelectedImage}"
                                Stretch="Fill" />
                            <Image
                                Width="120"
                                Margin="8,5,8,10"
                                Source="{Binding BrandImageFromLocal}"
                                Stretch="Fill" />
                        </Grid>
                    </ListBoxItem>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel
            Grid.Row="2"
            Padding="0,10,0,10"
            Background="{StaticResource LoginButtonBackground}"
            Visibility="{Binding NoBrandVisibility}">
            <TextBlock
                x:Name="NoBrand"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource MediumFontSize}"
                FontWeight="SemiBold"
                Foreground="{StaticResource LoginScreenTextFontColor}"
                Text="No Brand Found" />
        </StackPanel>

        <!--  Style List  -->
        <ListBox
            x:Name="LvStyle"
            Grid.Row="3"
            Padding="0"
            Background="{StaticResource LoginButtonBackground}"
            ItemsSource="{Binding StyleList, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.IsHorizontalRailEnabled="False"
            ScrollViewer.VerticalScrollMode="Disabled"
            SelectionMode="Multiple">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="10,0,5,5" />
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel
                        x:Name="StyleStack"
                        Height="40"
                        Padding="0"
                        Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <ListBoxItem Margin="0" Padding="0">
                        <RelativePanel x:Name="StyleRelativePanel" Tapped="StyleRelativePanel_Tapped">
                            <Image
                                Name="StyleImage"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Source="{Binding StyleImage}" />
                            <TextBlock
                                Name="StyleText"
                                Padding="0,8,0,0"
                                FontSize="{StaticResource FooterFontSize}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource FooterTextColor}"
                                RelativePanel.AlignHorizontalCenterWithPanel="True"
                                Text="{Binding StyleName}" />
                        </RelativePanel>
                    </ListBoxItem>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel
            Grid.Row="3"
            Padding="0,10,0,10"
            Background="{StaticResource LoginButtonBackground}"
            Visibility="{Binding NoStyleVisibility}">
            <TextBlock
                x:Name="NoStyle"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource MediumFontSize}"
                FontWeight="SemiBold"
                Foreground="{StaticResource LoginScreenTextFontColor}"
                Text="No Style Found" />
        </StackPanel>

        <!--  Product List Grid  -->
        <DE:GridControl
            x:Name="DataGridcontrol"
            Grid.Row="4"
            AlternationCount="2"
            AutoGenerateColumns="False"
            AutoScrollOnSorting="False"
            ItemClickCommand="{x:Bind SrcProductPageViewModel.ItemSelectedCommand}"
            ItemsSource="{x:Bind SrcProductPageViewModel.ProductGridDataSource, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ShowAutoFilterRow="True"
            ShowCriteriaInAutoFilterRow="True"
            ShowGroupPanel="False"
            ShowGroupedColumns="False"
            Visibility="{Binding ProductListVisibility}">
            <DE:GridControl.Columns>

                <DE:GridTextColumn
                    MinWidth="150"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="ItemNumber"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>


                <DE:GridTextColumn
                    MinWidth="300"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="ItemDescription"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    x:Name="link"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="Link"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Link" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTemplateColumn
                    x:Name="pdf"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    FieldName="PdfImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="PDF" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent" Tapped="PdfClicked">
                                <Image
                                    x:Name="pdfImage"
                                    Width="27"
                                    Height="27"
                                    Source="{Binding PdfImage}" />
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTemplateColumn
                    x:Name="cart"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="CartImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Add to Cart" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Tapped="Grid_Tapped">
                                <Image
                                    x:Name="cartImage"
                                    Width="27"
                                    Height="27"
                                    Source="{Binding IsAddedToCart, Mode=TwoWay, Converter={StaticResource cartImageCovnerter}}">
                                    <!--<Image.Source>
                                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding CartImage}" />
                                    </Image.Source>-->
                                </Image>
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTemplateColumn
                    x:Name="distributionImage"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="DistributionImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Distribution" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid x:Name="distributionGrid" Tapped="DistributionGrid_Tapped">
                                <Image
                                    x:Name="distributionImage"
                                    Width="25"
                                    Height="25">
                                    <Image.Source>
                                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding DistributionImage}" />
                                    </Image.Source>
                                </Image>
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTextColumn
                    x:Name="distributionDate"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="DistributionRecordedDate"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Distribution Recorded" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTemplateColumn
                    x:Name="favoriteProducts"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="FavoriteImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Favorite Products" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid x:Name="FavoriteGrid" Tapped="FavoriteGrid_Tapped">
                                <Image
                                    x:Name="favoriteImage"
                                    Width="27"
                                    Height="27"
                                    Source="{Binding IsFavorite, Converter={StaticResource favoriteImageConverter}}">
                                    <!--<Image.Source>
                                    <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding FavoriteImage}" />
                                </Image.Source>-->
                                </Image>
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTemplateColumn
                    x:Name="favoriteSalesDocs"
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="FavoriteSalesDocs">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Favorite Sales Docs" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid x:Name="FavoriteSalesDocs" Tapped="FavoriteSalesDocs_Tapped">
                                <Image
                                    x:Name="favoriteImage"
                                    Width="27"
                                    Height="27">
                                    <Image.Source>
                                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding FavoriteSalesDocs}" />
                                    </Image.Source>
                                </Image>
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>
            </DE:GridControl.Columns>

        </DE:GridControl>
        <StackPanel
            Grid.Row="4"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Visibility="{Binding NoProductVisibility}">
            <TextBlock
                x:Name="NoProduct"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource MediumFontSize}"
                FontWeight="SemiBold"
                Foreground="{StaticResource LoginScreenTextFontColor}"
                Text="No Product Found" />
        </StackPanel>
        <Grid
            Grid.Row="4"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{Binding LoadingVisibility}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>

        <!--  Product Detail Section  -->
        <Grid
            x:Name="productDetailsGrid"
            Grid.Row="4"
            Background="{StaticResource LoginButtonBackground}"
            Visibility="{Binding ProductDetailVisibility}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <!--  Left Product Image Section  -->

            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                Margin="-22,0,0,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="White"
                Orientation="Horizontal">
                <Image
                    Name="ProductImage"
                    Width="880"
                    Margin="0,30,0,30"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Stretch="Uniform">
                    <!--  Source="{StaticResource DefaultProduct}"  -->
                    <Image.Source>
                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding ProductDetailModel.ProductImagePath}" />
                    </Image.Source>
                </Image>
            </StackPanel>

            <!--  Right Product Detail Section  -->

            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                Padding="20"
                Background="{StaticResource LoginButtonBackground}"
                Orientation="Vertical">
                <TextBlock
                    FontSize="{StaticResource LargeFontSize}"
                    Foreground="Black"
                    Text="{Binding ProductDetailModel.ItemNumber}" />
                <TextBlock
                    FontSize="{StaticResource MediumFontSize}"
                    Foreground="Black"
                    Text="{Binding ProductDetailModel.ItemDescription}" />
                <StackPanel Margin="0,30,0,20" Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Margin="0,20,0,0"
                            FontSize="{StaticResource MediumFontSize}"
                            Foreground="Black"
                            Text="Quantity :" />
                        <TextBox
                            x:Name="quantityTextBlock"
                            Width="70"
                            Height="40"
                            Margin="10,0,10,0"
                            BeforeTextChanging="quantityTextBlock_BeforeTextChanging"
                            FlyoutBase.AttachedFlyout="{StaticResource CustomKeyPadFlyout}"
                            Foreground="{StaticResource LoginScreenTextFontColor}"
                            GotFocus="quantityTextBlock_GotFocus"
                            InputScope="Number"
                            MaxLength="4"
                            PointerEntered="quantityTextBlock_PointerEntered"
                            PointerExited="quantityTextBlock_PointerExited"
                            Text="{x:Bind SrcProductPageViewModel.ProductDetailModel.QuantityDisplay, Mode=TwoWay}" />
                    </StackPanel>
                    <Button
                        x:Name="AddToCartButton"
                        Background="Transparent"
                        Command="{x:Bind SrcProductPageViewModel.DetailAddToCartCommand, Mode=OneWay}">
                        <Grid>
                            <RelativePanel Padding="0">
                                <Image Width="150" Height="50">
                                    <Image.Source>
                                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding ProductDetailModel.ProductDetailCartBackgroundImage}" />
                                    </Image.Source>
                                </Image>
                                <StackPanel
                                    Orientation="Horizontal"
                                    RelativePanel.AlignHorizontalCenterWithPanel="True"
                                    RelativePanel.AlignVerticalCenterWithPanel="True">
                                    <Image Width="20" Height="20">
                                        <Image.Source>
                                            <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding ProductDetailModel.ProductDetailCartImage}" />
                                        </Image.Source>
                                    </Image>
                                    <TextBlock
                                        Margin="5,0,0,0"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource TextStyle}"
                                        Text="Add To Cart" />

                                </StackPanel>
                            </RelativePanel>

                        </Grid>
                    </Button>
                </StackPanel>
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.5*" />
                        <ColumnDefinition Width="0.5*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Button
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,0,18,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Command="{x:Bind SrcProductPageViewModel.FactSheetClickCommand, Mode=OneWay}">
                        <Grid>
                            <StackPanel Spacing="5">
                                <Image
                                    x:Name="FactsheetImage"
                                    Width="50"
                                    Height="50">
                                    <Image.Source>
                                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{StaticResource FactsheetNormal}" />
                                    </Image.Source>
                                </Image>
                                <TextBlock
                                    Name="FactsheetTitle"
                                    Style="{StaticResource TextStyle}"
                                    Text="Factsheet" />
                            </StackPanel>
                        </Grid>
                    </Button>
                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Command="{x:Bind SrcProductPageViewModel.RetailImageClickCommand, Mode=OneWay}">
                        <Grid>
                            <StackPanel Spacing="5">
                                <Image
                                    x:Name="RetailImage"
                                    Width="50"
                                    Height="50">
                                    <Image.Source>
                                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{StaticResource RetailImageNormal}" />
                                    </Image.Source>
                                </Image>
                                <TextBlock
                                    Name="RetailTitle"
                                    Style="{StaticResource TextStyle}"
                                    Text="Retail Image" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,22,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Command="{x:Bind SrcProductPageViewModel.ProductImageClickCommand, Mode=OneWay}">

                        <Grid>
                            <StackPanel Spacing="5">
                                <Image
                                    x:Name="ProductSectionImage"
                                    Width="50"
                                    Height="50">
                                    <Image.Source>
                                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{StaticResource RetailImageNormal}" />
                                    </Image.Source>
                                </Image>
                                <TextBlock
                                    Name="ProductSectionTitle"
                                    Style="{StaticResource TextStyle}"
                                    Text="Product" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button
                        Grid.Row="1"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Command="{x:Bind SrcProductPageViewModel.FavoriteDetailImageClickCommand, Mode=OneWay}">

                        <Grid>
                            <StackPanel Spacing="5">
                                <Image
                                    x:Name="FavoriteDetailImage"
                                    Width="50"
                                    Height="50">
                                    <Image.Source>
                                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding ProductDetailModel.FavoriteImage}" />
                                    </Image.Source>
                                </Image>
                                <TextBlock
                                    Name="FavoriteDetailTitle"
                                    Style="{StaticResource TextStyle}"
                                    Text="Favorite" />
                            </StackPanel>
                        </Grid>
                    </Button>
                </Grid>
                <Grid>
                    <RelativePanel Margin="0,10,0,0">
                        <Grid
                            x:Name="LeftProductDetailArrowGrid"
                            Padding="10"
                            RelativePanel.AlignLeftWithPanel="True"
                            Tapped="LeftProductDetailArrowGrid_Tapped">
                            <Image
                                x:Name="LeftProductDetailArrow"
                                Width="20"
                                Height="20">
                                <Image.Source>
                                    <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding ProductDetailModel.LeftArrowImage}" />
                                </Image.Source>
                            </Image>
                        </Grid>
                        <Grid
                            x:Name="listIconGrid"
                            Padding="10,0,10,0"
                            Background="Transparent"
                            RelativePanel.AlignHorizontalCenterWithPanel="True"
                            RelativePanel.AlignVerticalCenterWithPanel="True"
                            Tapped="ListIconGrid_Tapped">
                            <Image
                                Width="20"
                                Height="20"
                                Source="{StaticResource ListIcon}" />
                        </Grid>
                        <Grid
                            x:Name="RightProductDetailArrowGrid"
                            Padding="10"
                            RelativePanel.AlignRightWithPanel="True"
                            Tapped="RightProductDetailArrowGrid_Tapped">
                            <Image
                                x:Name="RightProductDetailArrow"
                                Width="20"
                                Height="20">
                                <Image.Source>
                                    <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding ProductDetailModel.RightArrowImage}" />
                                </Image.Source>
                            </Image>
                        </Grid>

                    </RelativePanel>
                </Grid>
            </StackPanel>
        </Grid>

        <!--  Preview document and images  -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="5"
            d:Visibility="Collapsed"
            Visibility="{x:Bind SrcProductPageViewModel.PreviewDocumentVisibility, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Background="Black" Opacity="0.6" />

            <customControls:PreviewDocumentControl CloseCommad="{x:Bind SrcProductPageViewModel.PreviewDocumentCommand}" FilePath="{x:Bind SrcProductPageViewModel.PreviewUrl, Mode=TwoWay}" />
        </Grid>

    </Grid>
</Page>
