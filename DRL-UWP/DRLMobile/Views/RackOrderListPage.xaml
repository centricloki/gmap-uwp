<Page
    x:Class="DRLMobile.Views.RackOrderListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:customControls="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:data="using:DRLMobile"
    xmlns:local="using:DRLMobile.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource LoginBackgroundColor}"
    mc:Ignorable="d">
    <Grid x:Name="outerPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <customControls:HeaderControl
            Title="NEW RACK ORDER"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            CustomerAddressText="{x:Bind RackOrderListPageViewModel.CustomerAddresss, Mode=OneWay}"
            CustomerNameText="{x:Bind RackOrderListPageViewModel.CustomerNameNumber, Mode=OneWay}"
            CustomerSubAddressText="{x:Bind RackOrderListPageViewModel.CustomerCityState, Mode=OneWay}"
            IsCustomerPanelVisible="{x:Bind RackOrderListPageViewModel.CustomerTitlePanelVisibility, Mode=OneWay}"
            IsPageTitleVisible="Visible" />

        <!--  Rack Items List  -->
        <controls:AdaptiveGridView
            x:Name="rackItemGrid"
            Grid.Row="1"
            Margin="0,10,0,20"
            DesiredWidth="500"
            IsItemClickEnabled="True"
            ItemClick="GridView_ItemClick"
            ItemsSource="{x:Bind RackOrderListPageViewModel.RackOrderListGridDataSource, Mode=OneWay}">

            <GridView.ItemTemplate>
                <DataTemplate>
                    <StackPanel
                        Margin="10"
                        Padding="10"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource FooterTextColor}"
                        Orientation="Horizontal">
                        <Image
                            Width="150"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Stretch"
                            Stretch="Uniform">
                            <!--  Source="{StaticResource RackItemPlaceHolder}" >  -->
                            <Image.Source>
                                <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding ProductImagePath, Mode=TwoWay}" />
                            </Image.Source>
                        </Image>
                        <StackPanel
                            Margin="20,20,0,0"
                            HorizontalAlignment="Stretch"
                            Orientation="Vertical">
                            <TextBlock
                                Margin="0,10,0,0"
                                HorizontalAlignment="Left"
                                FontSize="{StaticResource MediumFontSize}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource CartTextColor}"
                                Text="{Binding BrandName}" />
                            <TextBlock
                                Margin="0,15,0,0"
                                HorizontalAlignment="Left"
                                FontSize="{StaticResource FooterFontSize}"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource LoginScreenTextFontColor}"
                                Text="{Binding Description}" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </GridView.ItemTemplate>
            <!--<Image
                    Name="ProductImage"
                    Width="880"
                    Margin="0,30,0,30"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Stretch="Uniform">
                <Image.Source>
                    <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding ProductDetailModel.ProductImagePath}" />
                </Image.Source>
            </Image>-->
        </controls:AdaptiveGridView>
    </Grid>
</Page>
