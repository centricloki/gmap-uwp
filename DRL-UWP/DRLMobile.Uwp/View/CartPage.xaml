<Page
    x:Class="DRLMobile.Uwp.View.CartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:Editors="using:DevExpress.UI.Xaml.Editors"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:localConverter="using:DRLMobile.Uwp.Converters"    
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <Style x:Key="NoExpanderHeaderStyle" TargetType="ToggleButton">
                <Setter Property="Visibility" Value="Collapsed" />
            </Style>
            <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource CartTextColor}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
            </Style>
            <Flyout
                x:Key="CustomKeyPadFlyout"
                x:Name="QuantityCustomKeyPadFlyout"   
                Closing="QuantityCustomKeyPadFlyout_Closing"
                FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                LightDismissOverlayMode="Off"
                Placement="BottomEdgeAlignedRight">
                <customControls:CustomKeypad
                    DoneClickEvent="CustomKeypad_DoneClickEvent"
                    IsDotButtonVisible="Collapsed"
                    IsMinusButtonVisible="Visible"
                    NumPadButtonClick="{x:Bind ViewModel.NumPadButtonClickCommand, Mode=OneWay}" />
            </Flyout>
            <Flyout
                x:Key="CustomPriceKeyPadFlyout"
                x:Name="PriceKeyPadFlyout"
                Closing="Flyout_Closing"
                FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                LightDismissOverlayMode="Off"
                Placement="BottomEdgeAlignedRight">
                <customControls:CustomKeypad
                    DoneClickEvent="CustomKeypad_DoneClickEvent_1"
                    IsDotButtonVisible="Visible"
                    IsMinusButtonVisible="Collapsed"
                    NumPadButtonClick="{x:Bind ViewModel.NumPadButtonClickCommand, Mode=OneWay}" />
            </Flyout>
            <localConverter:VisibilityToBoolConverter x:Key="VisibilityToBoolConverter" />
        </ResourceDictionary>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <customControls:HeaderControl
            Title="{x:Bind ViewModel.CartDetailModel.CustomerNameNumber, Mode=OneWay}"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            IsPageTitleVisible="Visible" />

        <ScrollViewer Grid.Row="1">
            <Grid x:Name="outerPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="2"
                    x:Name="stackPnlEmptyCart"
                    x:Load="{x:Bind ViewModel.CartDetailModel.EmptyCartVisibility, Mode=OneWay,Converter={StaticResource VisibilityToBoolConverter}}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="EmptyCart"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource MediumFontSize}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LoginScreenTextFontColor}"
                        Text="The cart is empty." />
                </StackPanel>

                <StackPanel
                    Grid.Row="2"
                    x:Name="stackPnlNoSelectedCust"
                    x:Load="{x:Bind ViewModel.CartDetailModel.NoSelectedCustomerVisibility, Mode=OneWay,Converter={StaticResource VisibilityToBoolConverter}}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="NoCustomer"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource MediumFontSize}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LoginScreenTextFontColor}"
                        Text="No customer selected." />
                </StackPanel>

                <!--  Upper Grid  -->
                <StackPanel
                    x:Name="tobaccoStack"
                    x:Load="{x:Bind ViewModel.CartDetailModel.TobaccoGridVisibility, Mode=OneWay,Converter={StaticResource VisibilityToBoolConverter}}"
                    Grid.Row="1"
                    Margin="10">
                    <controls:Expander HorizontalAlignment="Stretch" IsExpanded="True">
                        <controls:Expander.Header>
                            <!--<Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>-->
                            <TextBlock
                                    Grid.Column="0"
                                    HorizontalAlignment="Left"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource CartTextColor}"
                                    Text="Tobacco Products" />
                            <!--</Grid>-->
                        </controls:Expander.Header>
                        <Grid x:Name="grid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DE:GridControl
                                x:Name="DataGridcontrol"
                                Grid.Row="0"
                                AlternationCount="2"
                                AutoGenerateColumns="False" 
                                FontSize="{StaticResource DataGridTextSize}"                       
                                ItemsSource="{x:Bind ViewModel.TobaccoGridDataSource, Mode=TwoWay}"
                                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                ShowAutoFilterRow="False"
                                ShowCriteriaInAutoFilterRow="True"
                                ShowGroupPanel="False"
                                ShowGroupedColumns="False">
                                <DE:GridControl.Columns>
                                    <DE:GridTemplateColumn
                                        x:Name="isAllUpperGridSelected"
                                        Width="60"
                                        AllowColumnFiltering="False"
                                        AllowSorting="False"
                                        FieldName="IsAllUpperGridSelected">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <CheckBox
                                                    Width="10"
                                                    Height="10"
                                                    Checked="headerCheckbox_Checked"
                                                    Unchecked="headerCheckbox_Unchecked" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsAllUpperGridSelected, Mode=TwoWay}" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                    <DE:GridTextColumn
                                        Width="90"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="BrandName"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Brand" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                    <DE:GridTextColumn
                                        Width="90"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="StyleName"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Style" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                    <DE:GridTextColumn
                                        Width="90"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="ItemNumber"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                    <DE:GridTextColumn
                                        Width="200"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="ItemDescription"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                    <DE:GridTemplateColumn
                                        x:Name="quantity"
                                        MinWidth="160"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="QuantityDisplay">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Quantity" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox 
                                                        x:Name="quantityEditText" Width="70"
                                                        CornerRadius="10" IsReadOnly="True"
                                                        Text="{Binding QuantityDisplay, Mode=TwoWay}"
                                                        Foreground="{StaticResource LoginScreenTextFontColor}">
                                                    </TextBox>
                                                    <Image                                                        
                                                        x:Name="quantityImage" 
                                                        FlyoutBase.AttachedFlyout="{StaticResource CustomKeyPadFlyout}"
                                                        Tapped="quantityImage_Tapped"
                                                        Width="20"
                                                        Height="20"                                                        
                                                        Source="{StaticResource EditCart}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                    <DE:GridTemplateColumn
                                        x:Name="Unit"
                                        MinWidth="110"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="Unit">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unit" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                    Name="UnitComboBox"
                                                    Width="80"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Foreground="{StaticResource LoginScreenTextFontColor}"
                                                    PlaceholderForeground="{StaticResource LoginScreenTextFontColor}"
                                                    PlaceholderText="{Binding Unit}"
                                                    SelectedItem="{Binding Unit,Mode=TwoWay}" 
                                                    SelectionChanged="UnitComboBox_SelectionChanged">
                                                    <x:String>CA</x:String>
                                                    <x:String>BX</x:String>
                                                    <x:String>EA</x:String>
                                                    <x:String>IP</x:String>
                                                    <x:String>BK</x:String>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                    <DE:GridTemplateColumn
                                        x:Name="unitPrice"                                        
                                        HorizontalAlignment="Stretch"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="PriceDisplay">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unit Price" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox
                                                        x:Name="TobaccoTextEdit" Width="80"
                                                        CornerRadius="10" IsReadOnly="True"
                                                        Text="{Binding PriceDisplay, Mode=TwoWay}"
                                                        Foreground="{StaticResource LoginScreenTextFontColor}">
                                                    </TextBox>
                                                    <Image
                                                        x:Name="unitPriceImage"
                                                        FlyoutBase.AttachedFlyout="{StaticResource CustomPriceKeyPadFlyout}"
                                                        Tapped="unitPriceImage_Tapped"
                                                        Width="20"
                                                        Height="20"                                                        
                                                        Source="{StaticResource EditCart}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                    <DE:GridTextColumn
                                        Width="100"                                        
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="TotalDisplay"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Subtotal" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                    <DE:GridTemplateColumn
                                        x:Name="delete"
                                        Width="80"
                                        AllowColumnFiltering="False">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Delete"/>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Tapped="Delete_Tapped">
                                                    <Image
                                                        x:Name="deleteImage"
                                                        Width="20"
                                                        Height="20"
                                                        Source="{StaticResource DeleteCart}" />
                                                </Grid>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                </DE:GridControl.Columns>
                            </DE:GridControl>
                            <StackPanel
                                Grid.Row="1"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource LoginButtonBackground}">
                                <StackPanel
                                    Padding="10,10,50,10"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="3">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="Sub Total:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="{x:Bind ViewModel.CartDetailModel.OrderDetailModel.SubTotalUpperDisplay, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </controls:Expander>
                </StackPanel>

                <!--  Lower Grid  -->
                <StackPanel
                    x:Name="nonTobaccoStack"
                    x:Load="{x:Bind ViewModel.CartDetailModel.NonTobaccoGridVisibility, Mode=OneWay,Converter={StaticResource VisibilityToBoolConverter}}"
                    Grid.Row="2"
                    Margin="10">
                    <controls:Expander HorizontalAlignment="Stretch" IsExpanded="True">
                        <controls:Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    HorizontalAlignment="Left"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource CartTextColor}"
                                    Text=" NonTobacco Products" />
                            </Grid>
                        </controls:Expander.Header>
                        <Grid x:Name="nontobaccoGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DE:GridControl
                                x:Name="NonTobaccoDataGridcontrol"
                                Grid.Row="0"
                                AlternationCount="2"
                                AutoGenerateColumns="False"
                                FontSize="{StaticResource DataGridTextSize}"
                                ItemsSource="{Binding Path=NonTobaccoGridDataSource}"
                                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                ShowAutoFilterRow="False"
                                ShowCriteriaInAutoFilterRow="True"
                                ShowGroupPanel="False"
                                ShowGroupedColumns="False">
                                <DE:GridControl.Columns>
                                    <DE:GridTemplateColumn
                                        x:Name="isAllLowerGridSelected"
                                        Width="60"
                                        AllowColumnFiltering="False"
                                        AllowSorting="False"
                                        FieldName="IsAllLowerGridSelected">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <CheckBox
                                                    x:Name="LowerGridheaderCheckbox"
                                                    Width="10"
                                                    Height="10"
                                                    Checked="LowerGridheaderCheckbox_Checked"
                                                    IsChecked="{Binding IsLowerGridSelectAllChecked, Mode=TwoWay}"
                                                    Unchecked="LowerGridheaderCheckbox_Unchecked" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsAllLowerGridSelected, Mode=TwoWay}" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                    <DE:GridTextColumn
                                        Width="90"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="BrandName"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Brand" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                    <DE:GridTextColumn
                                        Width="88"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="StyleName"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Style" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                    <DE:GridTextColumn
                                        Width="90"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="ItemNumber"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                    <DE:GridTextColumn
                                        Width="200"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="ItemDescription"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                    <DE:GridTemplateColumn
                                        x:Name="nonTobaccoQuantity"
                                        MinWidth="170"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="QuantityDisplay">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Quantity" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Background="Transparent" Orientation="Horizontal">
                                                    <TextBox 
	                                                x:Name="nonTobaccoQuantityEditText" Width="70"
	                                                CornerRadius="10" IsReadOnly="True"
	                                                Text="{Binding QuantityDisplay, Mode=TwoWay}"
	                                                Foreground="{StaticResource LoginScreenTextFontColor}">
                                                    </TextBox>
                                                    <Image
                                                        x:Name="nonTobaccoQuantityImage"
                                                       FlyoutBase.AttachedFlyout="{StaticResource CustomKeyPadFlyout}"
	                                                    Tapped="quantityImage_Tapped"
	                                                    Width="20"
	                                                    Height="20"  
                                                        Source="{StaticResource EditCart}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                    <DE:GridTemplateColumn
                                        x:Name="nonTobaccoUnit"
                                        Width="100"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="Unit">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unit" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox
                                                    Name="nonTobaccoUnitComboBox"
                                                    Width="80"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Foreground="{StaticResource LoginScreenTextFontColor}"
                                                    PlaceholderForeground="{StaticResource LoginScreenTextFontColor}"
                                                    PlaceholderText="{Binding Unit}"
                                                    SelectedItem="{Binding Unit,Mode=TwoWay}" 
                                                    SelectionChanged="UnitComboBox_SelectionChanged">
                                                    <x:String>CA</x:String>
                                                    <x:String>BX</x:String>
                                                    <x:String>EA</x:String>
                                                    <x:String>IP</x:String>
                                                    <x:String>BK</x:String>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                    <DE:GridTemplateColumn
                                        x:Name="nonTobaccoUnitPrice"
                                        HorizontalAlignment="Stretch"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        FieldName="PriceDisplay">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unit Price" />
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox  
	                                                x:Name="nonTobaccoTextEdit" Width="80"
	                                                CornerRadius="10" IsReadOnly="True"
                                                   Text="{Binding PriceDisplay, Mode=TwoWay}"
	                                                Foreground="{StaticResource LoginScreenTextFontColor}"/>
                                                    <Image
                                                        x:Name="nonTobaccoUnitPriceImage"
                                                        FlyoutBase.AttachedFlyout="{StaticResource CustomPriceKeyPadFlyout}"
	                                                    Tapped="unitPriceImage_Tapped"
	                                                    Width="20"
	                                                    Height="20"       
                                                        Source="{StaticResource EditCart}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                    <DE:GridTextColumn
                                        Width="100"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="TotalDisplay"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Subtotal" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                    <DE:GridTemplateColumn                                        
                                        x:Name="nonTobaccoDelete"
					                    Width="80"
                                        AllowColumnFiltering="False">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Delete"/>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.HeaderTemplate>
                                        <DE:GridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Tapped="Delete_Tapped">
                                                    <Image
                                                        x:Name="nonTobaccoDeleteImage"
                                                        Width="20"
                                                        Height="20"
                                                        Source="{StaticResource DeleteCart}" />
                                                </Grid>
                                            </DataTemplate>
                                        </DE:GridTemplateColumn.CellTemplate>
                                    </DE:GridTemplateColumn>
                                </DE:GridControl.Columns>
                            </DE:GridControl>
                            <StackPanel
                                Grid.Row="1"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource LoginButtonBackground}">
                                <StackPanel
                                    Padding="10,10,50,10"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="3">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="Sub Total:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="{x:Bind ViewModel.CartDetailModel.OrderDetailModel.SubTotalLowerDisplay, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </controls:Expander>
                </StackPanel>


                <!--  RTN Grid  -->
                <StackPanel
                    x:Name="rtnStack"
                    x:Load="{x:Bind ViewModel.CartDetailModel.RtnGridVisibility, Mode=OneWay,Converter={StaticResource VisibilityToBoolConverter}}"
                    Grid.Row="1"
                    Margin="10">
                    <controls:Expander HorizontalAlignment="Stretch" IsExpanded="True">
                        <controls:Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    HorizontalAlignment="Left"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource CartTextColor}"
                                    Text="RTN" />
                            </Grid>
                        </controls:Expander.Header>
                        <Grid x:Name="RTNgrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DE:GridControl
                                x:Name="RTNDataGridcontrol"
                                Grid.Row="0"
                                AlternationCount="2"
                                AutoGenerateColumns="False"
                                FontSize="{StaticResource DataGridTextSize}"
                                ItemsSource="{x:Bind ViewModel.RtnGridDataSource, Mode=TwoWay}"
                                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                ShowAutoFilterRow="False"
                                ShowCriteriaInAutoFilterRow="True"
                                ShowGroupPanel="False"
                                ShowGroupedColumns="False">
                                <DE:GridControl.Columns>
                                    <DE:GridTemplateColumn
                                        x:Name="isAllRtnUpperGridSelected"
                                          Width="60"
                                        MinWidth="60"
                                        AllowColumnFiltering="False"
                                        AllowSorting="False"
                                        FieldName="IsAllUpperGridSelected">
                                        <DE:GridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <CheckBox
                                                    Width="10"
                                                    Height="10"
                                                    Checked="headerCheckbox_Checked"
