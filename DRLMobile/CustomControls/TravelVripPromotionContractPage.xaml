                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="PromotionID"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Promo #" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="PromotionPlanType"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Plan Type" />
