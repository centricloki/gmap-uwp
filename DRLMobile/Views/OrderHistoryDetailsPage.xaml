                            BorderBrush="Black"
                            BorderThickness="0.4"
                            Foreground="{StaticResource LoginScreenTextFontColor}"
                            ItemsSource="{x:Bind ViewModel.CreditRequestComoBoxSource, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.AddEditUIModel.SelectedCreditRequest, Mode=TwoWay}"
