<Page
    x:Class="DRLMobile.Uwp.View.TravelVripPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DRLMobile.Uwp.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="SystemColors.HighlightBrushKey" Color="Transparent" />
        <SolidColorBrush x:Key="SystemColors.ControlBrushKey" Color="Transparent" />
        <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
        <Style x:Key="TextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
    </Page.Resources>
    <Grid x:Name="gridpanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />

        </Grid.RowDefinitions>
        <customControls:HeaderControl
            Title="{x:Bind TravelPageViewModel.PageTitle, Mode=OneWay}"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            AutoSuggestionText="{x:Bind TravelPageViewModel.AutoSuggestionText, Mode=TwoWay}"
            DisplayMemberPathValue="SearchDisplayPath"
            IsAutoSuggestBoxVisible="Visible"
            IsPageTitleVisible="Visible"
            IsTravelComboBoxVisible="Visible"
            ItemList="{x:Bind TravelPageViewModel.HeaderSearchItemSource, Mode=TwoWay}"
            PlaceHolderText="Search by customer name or #"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SuggestionChoosenCommand="{x:Bind TravelPageViewModel.HeaderSearchSuggestionChoosenCommand}"
            TextValueChangedCommand="{x:Bind TravelPageViewModel.HeaderSearchTextChangeCommand}"
            TravelComboBoxPlaceHolderText="{x:Bind TravelPageViewModel.ComboboxPlaceHolderText, Mode=OneWay}"
            TravelComboBoxValueChangedCommand="{x:Bind TravelPageViewModel.TravelComboBoxClickedCommand, Mode=OneWay}"
            TravelComboboxItemList="{x:Bind TravelPageViewModel.HeaderComboBoxDataSource, Mode=OneWay}" />
        <customControls:SegmentControl
            Grid.Row="1"
            Margin="0,10,0,15"
            HorizontalAlignment="Center"
            LeftSegmentCommand="{x:Bind TravelPageViewModel.LeftSegmentButtonCommand, Mode=OneWay}"
            LeftSegmentText="Travel"
            RightSegmentCommand="{x:Bind TravelPageViewModel.RightSegmentButtonCommand, Mode=OneWay}"
            RightSegmentText="V-RIP"
            SelectedSegment="Left" />
        
        <!--  Travel Grid  -->
        <DE:GridControl
            x:Name="TravelDataGridcontrol"
            Grid.Row="2"
            AlternationCount="2"
            AutoGenerateColumns="False"
            FontSize="{StaticResource DataGridTextSize}"
            ItemClickCommand="{x:Bind TravelPageViewModel.TravelItemSelectedCommand}"
            ItemsSource="{x:Bind TravelPageViewModel.TravelGridDataSource, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ShowAutoFilterRow="True"
            ShowCriteriaInAutoFilterRow="True"
            ShowGroupPanel="False"
            ShowGroupedColumns="False"
            ShowSearchPanelMode="Never"
            Visibility="{x:Bind TravelPageViewModel.IsTravelGridVisible, Mode=OneWay}"
            EndSorting="TravelDataGridcontrol_EndSorting">
            <DE:GridControl.Columns>
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="CustomerNumber"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Customer No" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="CustomerName"
                    TextWrapping="NoWrap"
                    MinWidth="240"
                    TextTrimming="CharacterEllipsis">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Customer Name" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    FieldName="YearToShow"
                    AllowSorting="True"
                    AllowColumnFiltering="False"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Year" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="NetPointsToShowInt"
                    DisplayFormat=" {0:n0}"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Net Points" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
                
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="Awards"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Awards" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
                
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    DisplayFormat=" {0:n0}"
                    FieldName="NeededPointToShowInt"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Needed Points" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="Next"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Next" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="City"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="City" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="State"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="State" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
            </DE:GridControl.Columns>
        </DE:GridControl>

        <!--  Vrip Grid  -->
        <DE:GridControl
            x:Name="VripDataGridcontrol"
            Grid.Row="2"
            AlternationCount="2"
            AutoGenerateColumns="False"
            FontSize="{StaticResource DataGridTextSize}"
            ItemClickCommand="{x:Bind TravelPageViewModel.VripItemSelectedCommand}"
            ItemsSource="{x:Bind TravelPageViewModel.VripGridDataSource, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ShowAutoFilterRow="True"
            ShowCriteriaInAutoFilterRow="True"
            ShowGroupPanel="False"
            ShowGroupedColumns="False"
            ShowSearchPanelMode="Never"
            Visibility="{x:Bind TravelPageViewModel.IsVripGridVisible, Mode=OneWay}"
            EndSorting="VripDataGridcontrol_EndSorting">
            <DE:GridControl.Columns>
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="CustomerNumber"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Customer No" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="CustomerName"
                    TextWrapping="NoWrap"
                    TextTrimming="CharacterEllipsis"
                    MinWidth="240">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Customer Name" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="YearToShow"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Year" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="CslyrToShow"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Cslyr" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
                
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="TargetToShowInt"
                    DisplayFormat=" {0:n0}"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Target" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="CsytdToShowInt"
                    DisplayFormat=" {0:n0}"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Csytd" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="CSNeededToShowInt"
                    DisplayFormat=" {0:n0}"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="CS Needed" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="Qualified"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Qualified" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="Rebate"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Rebate" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
            </DE:GridControl.Columns>
        </DE:GridControl>
        
        <Grid
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{Binding LoadingVisibility}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>
    </Grid>
</Page>
