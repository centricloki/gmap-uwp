<Page
    x:Class="DRLMobile.Uwp.View.AddActivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:converter="using:DRLMobile.Uwp.Converters"
    xmlns:core="using:Microsoft.Xaml.Interactions.Core"
    xmlns:customControl="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helper="using:DRLMobile.Uwp.Helpers"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:DRLMobile.Uwp.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="using:System"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <!--  ✅ FIXED: Use non-zero offset to enable DynamicWidthBehavior  -->
        <Style
            x:Key="DynamicWidthBehaviorStyle"
            BasedOn="{StaticResource EditTextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="helper:DynamicWidthBehavior.WidthOffset" Value="-20" />
        </Style>
        <Style
            x:Key="FixedMaxWidthStyle"
            BasedOn="{StaticResource FieldTextBlockStyle}"
            TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="5,5,0,0" />
            <!--<Setter Property="Width" Value="120" />-->
        </Style>
        <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converter:BoolToInvertBoolConverter x:Key="BoolToInvertBoolConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <customControl:HeaderControl
            Title="ADD ACTIVITY"
            ButtonClick="{x:Bind ViewModel.SaveCommand}"
            CustomIconButtonVisibility="Visible"
            HoverImageSource="{StaticResource SaveIconHover}"
            NormalImageSource="{StaticResource SaveIconNormal}" />

        <!--  ✅ FIXED: Replaced StackPanel with Grid  -->
        <ScrollViewer
            x:Name="MainScrollViewer"
            Grid.Row="1"
            Background="{StaticResource LoginBackgroundColor}"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <!--  ✅ Key: Bind Width to ScrollViewer's viewport  -->
            <Grid
                x:Name="FormGrid"
                MinWidth="300"
                Padding="40,10,140,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Row 0: Call Date + Activity Type  -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Call Date" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <CalendarDatePicker
                            Grid.Column="1"
                            Margin="30,0,0,0"
                            VerticalAlignment="Center"
                            Background="White"
                            Date="{x:Bind ViewModel.SelectedCallDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            DateFormat="{}{month.abbreviated(3)} {day.integer}, {year.full}" />
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Activity Type" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <Grid
                                Name="ActivityTypeGrid"
                                Grid.Column="0"
                                Margin="30,5,0,0"
                                HorizontalAlignment="Stretch"
                                Background="White"
                                CornerRadius="5"
                                Tapped="OpenActivityFlyout">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <FlyoutBase.AttachedFlyout>
                                    <Flyout
                                        x:Name="ActivityTypeFlyout"
                                        FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                                        LightDismissOverlayMode="Off"
                                        Placement="Bottom">
                                        <Grid
                                            MinWidth="200"
                                            Background="White"
                                            BorderBrush="Black"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                            <ListView
                                                Grid.Row="1"
                                                ItemsSource="{x:Bind ViewModel.ActivityTypeList, Mode=OneWay}"
                                                SelectionMode="None">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid
                                                            HorizontalAlignment="Stretch"
                                                            Background="Transparent"
                                                            Tapped="ActivitySelected">
                                                            <TextBlock
                                                                Margin="5"
                                                                Text="{Binding}"
                                                                TextWrapping="WrapWholeWords" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Flyout>
                                </FlyoutBase.AttachedFlyout>
                                <TextBox
                                    x:Name="activityNameTextbox"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    BorderThickness="0"
                                    IsHitTestVisible="False"
                                    IsReadOnly="True"
                                    Style="{StaticResource NoHoverTextBoxStyle}"
                                    Text="{x:Bind ViewModel.SelectedActivityType, Mode=OneWay}" />
                                <FontIcon
                                    Grid.Column="1"
                                    Margin="0,0,10,0"
                                    FontSize="12"
                                    Glyph="{StaticResource DownArrowIcon}"
                                    Style="{StaticResource FontIconStyle}" />
                            </Grid>
                            <FontIcon
                                x:Name="AttachmentIcon"
                                Grid.Column="1"
                                Margin="20,0,-20,0"
                                FontSize="30"
                                Glyph="{StaticResource AttachmentIcon}"
                                Style="{StaticResource FontIconStyle}"
                                Tapped="OpenAttachmentTypeFlyout"
                                Visibility="{x:Bind ViewModel.IsAttachmentIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FontIcon.RenderTransform>
                                    <RotateTransform Angle="45" CenterX="10" CenterY="0" />
                                </FontIcon.RenderTransform>
                                <FlyoutBase.AttachedFlyout>
                                    <Flyout
                                        x:Name="AttachmentTypeFlyout"
                                        FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                                        LightDismissOverlayMode="Off"
                                        Placement="Bottom">
                                        <StackPanel Background="White" CornerRadius="10">
                                            <Button
                                                Margin="10"
                                                Background="White"
                                                Command="{x:Bind ViewModel.OpenPickerCommand}"
                                                CommandParameter="camera"
                                                Content="Take Photo" />
                                            <Button
                                                Margin="10"
                                                Background="White"
                                                Command="{x:Bind ViewModel.OpenPickerCommand}"
                                                CommandParameter="picker"
                                                Content="Photo Library" />
                                            <Button
                                                x:Name="BtnDocumentPicker"
                                                Margin="10"
                                                x:Load="{x:Bind ViewModel.IsNarrativeWeeklyReport, Mode=OneWay}"
                                                Background="White"
                                                Command="{x:Bind ViewModel.OpenPickerCommand}"
                                                CommandParameter="doc"
                                                Content="Document" />
                                        </StackPanel>
                                    </Flyout>
                                </FlyoutBase.AttachedFlyout>
                            </FontIcon>
                            <FontIcon
                                x:Name="AttachementPreviewButton"
                                Grid.Column="2"
                                Margin="20,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="35"
                                Glyph="{StaticResource PreviewIcon}"
                                Style="{StaticResource FontIconStyle}"
                                Visibility="{x:Bind ViewModel.IsAttachmentIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <i:Interaction.Behaviors>
                                    <core:EventTriggerBehavior EventName="Tapped">
                                        <core:InvokeCommandAction Command="{x:Bind ViewModel.PreviewCommand, Mode=OneWay}" />
                                    </core:EventTriggerBehavior>
                                </i:Interaction.Behaviors>
                            </FontIcon>
                        </Grid>
                    </Grid>
                </Grid>

                <!--  Row 1: Account No + Account Name  -->
                <Grid Grid.Row="1"  Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Account No" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            x:Name="selectedAccNoTextbox"
                            Grid.Column="1"
                            Margin="20,3,0,5"
                            helper:DynamicWidthBehavior.WidthOffset="-40"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind ViewModel.SelectedCustomerNo, Mode=OneWay}" />
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Account Name" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <Grid
                            Name="CustomerSelectionGrid"
                            Grid.Column="1"
                            Margin="30,5,0,0"
                            HorizontalAlignment="Stretch"
                            Background="White"
                            CornerRadius="5"
                            Tapped="CustomerSelectionGrid_Tapped">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <FlyoutBase.AttachedFlyout>
                                <Flyout
                                    x:Name="CustomerSelectionFlyout"
                                    FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                                    LightDismissOverlayMode="Off"
                                    Placement="Bottom">
                                    <Grid
                                        Height="300"
                                        MinWidth="300"
                                        Background="White"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBox
                                            Grid.Row="0"
                                            Margin="10"
                                            PlaceholderText="Search Customer"
                                            Visibility="Collapsed" />

                                        <ListView
                                            Grid.Row="1"
                                            ItemsSource="{x:Bind ViewModel.CustomerList, Mode=OneWay}"
                                            SelectionMode="None">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Background="Transparent" Tapped="CustomerSelected">
                                                        <TextBlock Margin="5" TextWrapping="WrapWholeWords">
                                                            <TextBlock.Inlines>
                                                                <Run FontWeight="SemiBold" Text="{Binding CustomerName}" />
                                                                <Run Text="&#x0a;" />
                                                                <Run Text="{Binding CustomerNumber}" />
                                                            </TextBlock.Inlines>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </Flyout>
                            </FlyoutBase.AttachedFlyout>
                            <TextBox
                                x:Name="customerNameTextbox"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                IsHitTestVisible="False"
                                IsReadOnly="True"
                                Style="{StaticResource NoHoverTextBoxStyle}"
                                Text="{x:Bind ViewModel.SelectedCustomerName, Mode=OneWay}" />
                            <FontIcon
                                Grid.Column="1"
                                Margin="0,0,10,0"
                                FontSize="12"
                                Glyph="{StaticResource DownArrowIcon}"
                                Style="{StaticResource FontIconStyle}" />
                        </Grid>
                    </Grid>
                </Grid>

                <!--  Row 2: Hours + Consumer Engagement  -->
                <Grid Grid.Row="2" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Hours" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <ComboBox
                            x:Name="hoursCombobox"
                            Grid.Column="1"
                            Margin="30,3,0,5"
                            VerticalAlignment="Top"
                            d:Text=""
                            HorizontalAlignment="Stretch"
                            Background="White"
                            FontSize="16"
                            SelectedValue="{x:Bind ViewModel.SelectedHours, Mode=TwoWay}">
                            <x:String>1</x:String>
                            <x:String>2</x:String>
                            <x:String>3</x:String>
                            <x:String>4</x:String>
                            <x:String>5</x:String>
                            <x:String>6</x:String>
                            <x:String>7</x:String>
                            <x:String>8</x:String>
                        </ComboBox>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.RowSpan="2"
                            Style="{StaticResource FixedMaxWidthStyle}"
                            Text="Consumer Activation Engagement :" />

                        <Grid Grid.Row="0" Margin="30,5,0,0" HorizontalAlignment="Stretch"
                            Grid.Column="1">
                            <TextBox                           
                            Style="{StaticResource EditTextBoxStyle}" HorizontalAlignment="Stretch" Margin="0"
                            Text="{x:Bind ViewModel.ConsumerActivationEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <TextBlock
                            x:Name="TxtActivationValid"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="30,10,0,0"
                            HorizontalAlignment="Left"
                            helper:DynamicWidthBehavior.WidthOffset="-20"
                            FontSize="14"
                            Foreground="Red"
                            Text="{x:Bind ViewModel.ErrorConsumerActivationEngagement, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsInValidConsumerActivationEngagement, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}" />



                    </Grid>
                </Grid>

                <!--  Row 3: Markets Visited + Calls Made vs Goal  -->
                <Grid
                    x:Name="grdNarrativeRow1" 
                    Grid.Row="3" Margin="0,5,0,0"
                    Visibility="{x:Bind ViewModel.IsNarrativeWeeklyReport, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Market(s) Visited" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            x:Name="txtMarketsVisited"
                            Grid.Column="1"
                            MinHeight="200"
                            MaxHeight="250"
                            AcceptsReturn="True"
                            MaxLength="4000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Text="{Binding MarketsVisited, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid  Margin="20,0,0,0" 
                        x:Name="grdCallsMadeVsGoal"
                        Grid.Column="1"
                        Visibility="{x:Bind ViewModel.IsNarrativeWeeklyReport, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Calls Made vs Goal" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            x:Name="txtCallsMadeVsGoal"
                            Grid.Column="1"
                            Height="200"
                            MaxHeight="250"
                            AcceptsReturn="True"
                            MaxLength="4000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Text="{Binding CallsMadeVsGoal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Grid>

                <!--  Row 4: New Customer Acquisitions + Key Wins  -->
                <Grid
                    x:Name="grdNarrativeRow2"
                    Grid.Row="4" Margin="0,5,0,0"
                    Visibility="{x:Bind ViewModel.IsNarrativeWeeklyReport, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid  Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="New Customer Acquisitions" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            x:Name="txtNewCustomerAcquisitions"
                            Grid.Column="1"
                            Height="200"
                            MaxHeight="250"
                            AcceptsReturn="True"
                            MaxLength="4000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Text="{Binding NewCustomerAcquisitions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Grid.Column="1"  Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Key Wins (New Distribution, Upsells, Promotions, Competitive Wins)" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            x:Name="txtKeyWinsSummary"
                            Grid.Column="1"
                            Height="200"
                            MaxHeight="250"
                            AcceptsReturn="True"
                            MaxLength="4000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Text="{Binding KeyWinsSummary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Grid>

                <!--  Row 5: Challenges + Next Cycle Plan  -->
                <Grid
                    x:Name="grdNarrativeRow3"
                    Grid.Row="5" Margin="0,5,0,0"
                    Visibility="{x:Bind ViewModel.IsNarrativeWeeklyReport, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid  Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Challenges + Market &amp; Competitive Feedback" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            x:Name="txtChallengesAndFeedback"
                            Grid.Column="1"
                            Height="200"
                            MaxHeight="250"
                            AcceptsReturn="True"
                            MaxLength="4000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Text="{Binding ChallengesAndFeedback, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Grid.Column="1" HorizontalAlignment="Stretch"  Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Next Cycle's Plan (Next time in this market)" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            x:Name="txtNextCyclesPlan"
                            Grid.Column="1"
                            Height="200"
                            MaxHeight="250"
                            AcceptsReturn="True"
                            MaxLength="4000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Text="{Binding NextCyclePlan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Grid>

                <!--  Row 6: Notes + Next Week Plan  -->
                <Grid Grid.Row="6" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid  Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Notes/Comments" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            x:Name="notesTextbox"
                            Grid.Column="1"
                            Height="200"
                            MaxHeight="250"
                            VerticalAlignment="Top"
                            AcceptsReturn="True"
                            MaxLength="4000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid
                        x:Name="grdNextWeekPlan"
                        Grid.Column="1"  Margin="20,0,0,0"
                        HorizontalAlignment="Stretch"
                        Visibility="{x:Bind ViewModel.IsNarrativeWeeklyReport, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Next Week's Plan" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            x:Name="txtNextWeekPlan"
                            Grid.Column="1"
                            Height="200"
                            MaxHeight="250"
                            AcceptsReturn="True"
                            MaxLength="4000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Text="{Binding NextWeekPlan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Grid>

                <!--  Row 7: Buttons  -->
                <Grid
                    Grid.Row="7" 
                    HorizontalAlignment="Center"
                    ColumnSpacing="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.5*" />
                        <ColumnDefinition Width="0.5*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="BtnAddActivity"
                        Grid.Column="0"
                        Width="100"
                        Margin="0,30"
                        HorizontalAlignment="Left"
                        Click="AddActivityButton_Click"
                        Content="Add" />
                    <Button
                        Grid.Column="1"
                        Width="100"
                        Margin="0,30"
                        HorizontalAlignment="Right"
                        Click="CancelActivityButton_Click"
                        Content="Cancel" />
                </Grid>

                <!--  Row 8: Attachments  -->
                <controls:AdaptiveGridView
                    x:Name="AttachmentGrid"
                    Grid.Row="8"
                    Margin="20"
                    x:Load="{x:Bind ViewModel.IsAttachmentIconVisible, Mode=OneWay}"
                    DesiredWidth="250"
                    IsItemClickEnabled="False"
                    ItemHeight="90"
                    ItemsSource="{x:Bind ViewModel.AddedAttachementItemSource, Mode=TwoWay}"
                    SelectionMode="None">
                    <controls:AdaptiveGridView.ItemTemplate>
                        <DataTemplate x:DataType="sys:String">
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image
                                    Name="AttachmentImage"
                                    Source="{x:Bind helper:XAMLHelper.GetImageBasedOnExtension((sys:String)), Mode=OneWay}"
                                    Stretch="Uniform" />
                                <Border
                                    Margin="0,0,0,0"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="Red"
                                    CornerRadius="10"
                                    Tapped="DeleteAddedAttachment">
                                    <FontIcon
                                        Margin="2"
                                        Foreground="{StaticResource FooterTextColor}"
                                        Glyph="{StaticResource CancelIcon}"
                                        Style="{StaticResource FontIconStyle}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </controls:AdaptiveGridView.ItemTemplate>
                </controls:AdaptiveGridView>

                <!--  Row 9: Spacer  -->
                <Grid Grid.Row="9" Height="20" />
            </Grid>
        </ScrollViewer>

        <!--  Loading Overlay  -->
        <Grid
            x:Name="ProgressRingGrid"
            Grid.Row="0"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            Background="Black"
            Opacity="0.7">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>
    </Grid>
</Page>