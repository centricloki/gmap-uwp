<Page
    x:Class="DRLMobile.Views.CustomerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:converter="using:DRLMobile.Converters"
    xmlns:customControls="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="Black" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
            </Style>
            <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        </ResourceDictionary>
    </Page.Resources>


    <Grid x:Name="outerPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <customControls:HeaderControl
            x:Name="HeaderControl"
            x:Uid="CustomerPageSearch"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            DisplayMemberPathValue="SearchDisplayPath"
            IsAutoSuggestBoxVisible="Visible"
            IsPageTitleVisible="Visible"
            ItemList="{x:Bind ViewModel.HeaderSearchItemSource, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SuggestionChoosenCommand="{x:Bind ViewModel.HeaderSearchSuggestionChoosenCommand}"
            TextValueChangedCommand="{x:Bind ViewModel.HeaderSearchTextChangeCommand}" />

        <DE:GridControl
            x:Name="DataGridcontrol"
            Grid.Row="1"
            AlternationCount="2"
            AutoGenerateColumns="False"
            FontSize="{StaticResource DataGridTextSize}"
            ItemClickCommand="{x:Bind ViewModel.ItemSelectedCommand}"
            ItemsSource="{Binding Path=Items}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ShowAutoFilterRow="True"
            ShowCriteriaInAutoFilterRow="True"
            ShowGroupPanel="False"
            ShowGroupedColumns="False"
            ShowSearchPanelMode="Never">
            <DE:GridControl.Columns>

                <DE:GridTextColumn
                    MinWidth="300"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="CustomerName"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="CustomerNumber"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Customer#" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="StoreType"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    Width="80"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="Rank"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="Address"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="City"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="State"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock
                                Width="80"
                                Style="{StaticResource GridHeaderStyle}"
                                Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="LastCallDate"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>


                </DE:GridTextColumn>
                <DE:GridTemplateColumn
                    x:Name="ellipsis"
                    Width="60"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="IsEllipsisVisible"
                    Visible="True">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid
                                Name="ellipsisGrid"
                                Tapped="ellipsisGrid_Tapped"
                                Visibility="{Binding IsEllipsisVisible, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}">

                                <FontIcon
                                    x:Name="EllipsisImage"
                                    Width="20"
                                    Height="30"
                                    FontWeight="ExtraBold"
                                    Glyph="{StaticResource EllipsisIcon}"
                                    Style="{StaticResource FontIconStyle}" />
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>


            </DE:GridControl.Columns>
        </DE:GridControl>


        <Grid Grid.Row="2" Background="White">
            <Button
                x:Uid="AddCustomerButton"
                Height="33"
                Margin="{StaticResource XSmallLeftTopRightBottomMargin}"
                HorizontalAlignment="Center"
                Command="{x:Bind ViewModel.AddCustomerCommand}"
                FontSize="15"
                Style="{StaticResource LoginButtonStyle}" />

        </Grid>


        <Grid
            Grid.Row="1"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{Binding LoadingVisibility}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Visibility="{x:Bind ViewModel.TravelPopUpVisibility, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Background="Black" Opacity="0.7" />
            <customControls:TravelVripPromotionContractPage
                CloseCommad="{x:Bind ViewModel.TravelPopUpCloseCommand}"
                CustomerNameText="{x:Bind ViewModel.CustomerName, Mode=OneWay}"
                ResetControl="{x:Bind ViewModel.TravelPopUpVisibility, Mode=OneWay}" />

        </Grid>
    </Grid>
</Page>
