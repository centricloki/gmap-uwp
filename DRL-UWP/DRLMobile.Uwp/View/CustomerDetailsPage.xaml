                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Number Of Locations" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            d:Text="locations"
                            BeforeTextChanging="NumericTextBox_BeforeTextChanging"
                            MaxLength="13"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.NumberOfLocations, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Tobacco License" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderText="Tobacco License"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.TobaccoLicense, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Retailer License" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderText="Retailer License"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.RetailLicense, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Sales Tax Certificate" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Name="SalesTaxCertificateTextBox"
                            Grid.Column="1"
                            PlaceholderText="Sales tax Certificate"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.SalesTaxCertificate, Mode=TwoWay}" />
                    </Grid>

                    <Grid Visibility="{x:Bind ViewModel.UiModel.IsDisrtibutorsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            VerticalAlignment="Center"
                            Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Distributor(s)" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <Grid
                            x:Name="DistributorGrid"
                            Grid.Row="0"
                            Grid.Column="1"
                            MinWidth="250"
                            Margin="20,10,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            CornerRadius="5"
                            Style="{x:Bind ViewModel.UiModel.IsInEditMode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='Grid'}">

                            <i:Interaction.Behaviors>
                                <core:EventTriggerBehavior EventName="Tapped">
                                    <core:InvokeCommandAction Command="{x:Bind ViewModel.SelectDristributonTappedCommand, Mode=OneWay}" />
                                </core:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                            <FlyoutBase.AttachedFlyout>
                                <Flyout
                                    x:Name="DistributorFlyout"
                                    FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                                    LightDismissOverlayMode="Off">
                                    <Grid
                                          Width="350"
                                        Height="350"
                                        Background="White"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="auto" />
                                        </Grid.RowDefinitions>

                                        <Grid
                                            Grid.Row="0"
                                            Height="25"
                                            HorizontalAlignment="Stretch"
                                            Background="{StaticResource FooterBackgroundColor}">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="16"
                                                Foreground="White"
                                                Text="Select Distributor" />
                                        </Grid>

                                        <TextBox
                                            x:Name="FlyoutTextBox"
                                            Grid.Row="1"
                                            Width="270"
                                            Margin="6"
                                            HorizontalAlignment="Center"
                                            Background="White"
                                            BorderBrush="Black"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            PlaceholderText="Search Distributor">
                                            <i:Interaction.Behaviors>
                                                <core:EventTriggerBehavior EventName="TextChanged">
                                                    <core:InvokeCommandAction Command="{x:Bind ViewModel.UiModel.FlyoutTextChangedCommand, Mode=OneWay}" CommandParameter="{Binding ElementName=FlyoutTextBox, Path=Text}" />
                                                </core:EventTriggerBehavior>
                                            </i:Interaction.Behaviors>
                                        </TextBox>

                                        <ListView
                                            Grid.Row="2"
                                            ItemsSource="{x:Bind ViewModel.UiModel.DistributionFlyoutListItemSource, Mode=OneWay}"
                                            SelectionMode="None">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid
                                                        x:Name="DistributorTemplateGrid"
                                                         Background="Transparent"
                                                        Tapped="DistributorTemplateGrid_Tapped">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="25" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock MinWidth="270" HorizontalAlignment="Stretch"
                                                                FontSize="12" FontWeight="Medium" TextWrapping="Wrap">
                                                                <TextBlock.Inlines>
                                                                    <Run Text="{Binding FullName}" />
                                                                    <LineBreak/>
                                                                    <Run FontStyle="Italic" FontSize="11" FontWeight="Normal" Text="{Binding AssignUserName}" />
                                                                </TextBlock.Inlines>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <FontIcon
                                                            Grid.Column="1"
                                                            Margin="3"
                                                            HorizontalAlignment="Right"
                                                            Foreground="Teal"
                                                            Glyph="{StaticResource CheckMark}"
                                                            Style="{StaticResource FontIconStyle}"
                                                            Visibility="{Binding IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <StackPanel
                                            Grid.Row="3"
                                            Margin="3"
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="10">
                                            <Button
                                                Command="{x:Bind ViewModel.CancelDistributorCommand}"
                                                Content="Cancel"
                                                Style="{StaticResource FlyoutButtonStyle}" />
                                            <Button
                                                Command="{x:Bind ViewModel.DistributorDoneCommand}"
                                                Content="Done"
                                                Style="{StaticResource FlyoutButtonStyle}" />
                                        </StackPanel>

                                    </Grid>
                                </Flyout>
                            </FlyoutBase.AttachedFlyout>


                            <TextBlock
                                Margin="5,10,10,10"
                                FontSize="{StaticResource MediumFontSize}"
                                Foreground="{StaticResource LoginScreenTextFontColor}"
                                Text="Select Distributor(s)" />
                        </Grid>

                        <customControl:AlternateRowColorListView
                            x:Name="DristributionList"
                            Grid.Row="1" MaxWidth="400"
                            Grid.ColumnSpan="2"
                            Margin="0,10,10,0" 
                            CornerRadius="5"
                            ItemsSource="{x:Bind ViewModel.UiModel.DistributorList, Mode=TwoWay}"
                            SelectionMode="None"
                            Style="{x:Bind ViewModel.UiModel.IsInEditMode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='ListViewDistributor'}"
                            Visibility="{x:Bind ViewModel.UiModel.IsDisrtibutorsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="dm:DistributorAssignUser">
                                    <Grid BorderThickness="0,0,0,0.2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="25" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" MinWidth="375" HorizontalAlignment="Stretch"
                                            TextWrapping="Wrap"  FontWeight="Medium" FontSize="12"  Padding="0,10,0,10" >
                                            <TextBlock.Inlines>
                                                <Run Text="{Binding FullName}" />
                                                <LineBreak/>
                                                <Run FontStyle="Italic" FontWeight="Normal" FontSize="11" Text="{Binding AssignUserName}" />
                                            </TextBlock.Inlines>
                                        </TextBlock>
                                        <Grid
                                            x:Name="gridDistributorDel"
                                            x:Load="{x:Bind IsDeleteIconVisibile, Mode=OneWay, Converter={StaticResource VisibilityToBoolConverter}}"
                                            Grid.Column="1"
                                            Background="Transparent"
                                            Tapped="DistributorDeletedIconTapped">
                                            <FontIcon 
                                                Margin="3"
                                                HorizontalAlignment="Right"                                                
                                                FontSize="14"
                                                Foreground="Red"
                                                Glyph="{StaticResource DeleteIcon}"
                                                Style="{StaticResource FontIconStyle}"
                                                 />
                                        </Grid>
                                    </Grid>

                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </customControl:AlternateRowColorListView>
                    </Grid>

                    <Grid x:Name="gridWeekDays" Margin="0,10"
                          x:Load="{x:Bind ViewModel.UiModel.IsDirectCustomer, Mode=OneWay, Converter={StaticResource BoolToInvertBoolConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"  />
                            <ColumnDefinition  Width="2*"  />
                        </Grid.ColumnDefinitions>

                        <TextBlock 
                        VerticalAlignment="Top" Grid.Column="0" Margin="0" HorizontalAlignment="Left"
                        Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Store Truck / Order Delivery Date :"/>
                            </TextBlock.Inlines>
                        </TextBlock>
                        <customControl:AlternateRowColorListView 
                        CornerRadius="5" Grid.Column="1" HorizontalAlignment="Left" Margin="20,0,0,0" Width="250" 
                        ItemsSource="{x:Bind ViewModel.Weekdays, Mode=TwoWay}"
                        SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="uim:WeekdayUIModel">
                                    <StackPanel Orientation="Horizontal" >
                                        <!-- Bind to the parent's DataContext property -->
                                        <CheckBox Content="{x:Bind Name}" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" IsHitTestVisible="{x:Bind IsEnabled, Mode=TwoWay}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </customControl:AlternateRowColorListView>
                    </Grid>

                    <StackPanel Spacing="-5" Visibility="{x:Bind ViewModel.UiModel.TravelMainVisibility, Mode=TwoWay}">

                        <TextBlock Style="{StaticResource TitleHeaderStyle}" Text="Travel Points" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                                <TextBlock.Inlines>
                                    <Run Text="Award" />
                                    <Run x:Uid="Colon" d:Text=":" />
                                </TextBlock.Inlines>
                            </TextBlock>

                            <TextBox
                                Grid.Column="1"
                                PlaceholderText="-"
                                Style="{StaticResource ViewOnlyTextBoxStyle}"
                                Text="{x:Bind ViewModel.UiModel.CustomerData.Awards, Mode=TwoWay}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                                <TextBlock.Inlines>
                                    <Run Text="Earned Points" />
                                    <Run x:Uid="Colon" d:Text=":" />
                                </TextBlock.Inlines>
                            </TextBlock>

                            <TextBox
                                Grid.Column="1"
                                PlaceholderText="0"
                                Style="{StaticResource ViewOnlyTextBoxStyle}"
                                Text="{x:Bind ViewModel.UiModel.EarnedPoints, Mode=TwoWay}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                                <TextBlock.Inlines>
                                    <Run Text="Bonous Points" />
                                    <Run x:Uid="Colon" d:Text=":" />
                                </TextBlock.Inlines>
                            </TextBlock>

                            <TextBox
                                Grid.Column="1"
                                PlaceholderText="0"
                                Style="{StaticResource ViewOnlyTextBoxStyle}"
                                Text="{x:Bind ViewModel.UiModel.BonousPoints, Mode=TwoWay}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                                <TextBlock.Inlines>
                                    <Run Text="Net Points" />
                                    <Run x:Uid="Colon" d:Text=":" />
                                </TextBlock.Inlines>
                            </TextBlock>

                            <TextBox
                                Grid.Column="1"
                                PlaceholderText="0"
                                Style="{StaticResource ViewOnlyTextBoxStyle}"
                                Text="{x:Bind ViewModel.UiModel.NetPoints, Mode=TwoWay}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                                <TextBlock.Inlines>
                                    <Run Text="Need for Next" />
                                    <Run x:Uid="Colon" d:Text=":" />
                                </TextBlock.Inlines>
                            </TextBlock>

                            <TextBox
                                Grid.Column="1"
                                PlaceholderText="0"
                                Style="{StaticResource ViewOnlyTextBoxStyle}"
                                Text="{x:Bind ViewModel.UiModel.NeedNextPoints, Mode=TwoWay}" />
                        </Grid>

                    </StackPanel>

                    <StackPanel Spacing="-5" Visibility="{x:Bind ViewModel.UiModel.VripMainVisibility, Mode=TwoWay}">
                        <TextBlock Style="{StaticResource TitleHeaderStyle}" Text="V-RIP" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>


                            <TextBox
                                Grid.Column="1"
                                FontSize="14"
                                Style="{StaticResource ViewOnlyTextBoxStyle}"
                                Text="case quantity" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                                <TextBlock.Inlines>
                                    <Run Text="YTD Qty" />
                                    <Run x:Uid="Colon" d:Text=":" />
                                </TextBlock.Inlines>
                            </TextBlock>

                            <TextBox
                                Grid.Column="1"
                                PlaceholderText="0"
                                Style="{StaticResource ViewOnlyTextBoxStyle}"
                                Text="{x:Bind ViewModel.UiModel.TravelYtdQty, Mode=TwoWay}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                                <TextBlock.Inlines>
                                    <Run Text="Target Qty" />
                                    <Run x:Uid="Colon" d:Text=":" />
                                </TextBlock.Inlines>
                            </TextBlock>

                            <TextBox
                                Grid.Column="1"
                                PlaceholderText="0"
                                Style="{StaticResource ViewOnlyTextBoxStyle}"
                                Text="{x:Bind ViewModel.UiModel.TravelTargetQty, Mode=TwoWay}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                                <TextBlock.Inlines>
                                    <Run Text="Needed Qty" />
                                    <Run x:Uid="Colon" d:Text=":" />
                                </TextBlock.Inlines>
                            </TextBlock>

                            <TextBox
                                Grid.Column="1"
                                PlaceholderText="0"
                                Style="{StaticResource ViewOnlyTextBoxStyle}"
                                Text="{x:Bind ViewModel.UiModel.TravelNeedQty, Mode=TwoWay}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                                <TextBlock.Inlines>
                                    <Run Text="Previous Year" />
                                    <Run x:Uid="Colon" d:Text=":" />
                                </TextBlock.Inlines>
                            </TextBlock>

                            <TextBox
                                Grid.Column="1"
                                PlaceholderText="0"
                                Style="{StaticResource ViewOnlyTextBoxStyle}"
                                Text="{x:Bind ViewModel.UiModel.TravelPreviousYear, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>



                </StackPanel>

            </Grid>
        </ScrollViewer>

        <RelativePanel
            x:Name="RPanel"
            Grid.Row="2"
            Grid.RowSpan="20"
            Grid.ColumnSpan="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BorderThickness="0"  
            FocusVisualPrimaryBrush="Transparent">
            <Button
     x:Name="PlaceOderButton"
                MaxWidth="200"  Margin="0,10,0,0"
     Command="{x:Bind ViewModel.PlaceAnOderButtonCommand}"
     Content="Place an Order"
     Style="{StaticResource CustomerDetailPageButton}" />

            <Button
     x:Name="DocumentsButton"
     MaxWidth="200"  Margin="10,10,0,0"
     Command="{x:Bind ViewModel.AddDocumentCommand}"
     Content="Documents"
     RelativePanel.RightOf="PlaceOderButton"
     Style="{StaticResource CustomerDetailPageButton}" />

            <Button
     x:Name="DistributionButton"
     MaxWidth="200"  Margin="10,10,0,0"
     Command="{x:Bind ViewModel.DistributorButtonCommand}"
     Content="Distribution"
     RelativePanel.RightOf="DocumentsButton"
     Style="{StaticResource CustomerDetailPageButton}" />

            <Button
     x:Name="RackOrderButton"
     MaxWidth="200"  Margin="10,10,0,0"
     Command="{x:Bind ViewModel.RackOrderButtonCommand}"
     Content="Rack Order"
     RelativePanel.RightOf="DistributionButton"
     Style="{StaticResource CustomerDetailPageButton}" />

            <Button
                x:Name="CarStockOrderButton"
                MaxWidth="200"  Margin="10,10,0,0"
                Visibility="{x:Bind ViewModel.IsCarStockEnable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                Command="{x:Bind ViewModel.CarStockOrderButtonCommand}"
                Content="Car Stock Order"
                RelativePanel.RightOf="RackOrderButton"
                Style="{StaticResource CustomerDetailPageButton}" />

            <Button
     x:Name="ActivitiesButton"
     MaxWidth="200"  Margin="0,10,0,0"
     Command="{x:Bind ViewModel.ActivitiesCommand}"
     Content="Activity"
     RelativePanel.Below="PlaceOderButton"
     Style="{StaticResource CustomerDetailPageButton}" />

            <Button
     x:Name="OrderHistroryButton"
     MaxWidth="200"  Margin="10,10,0,0"
     Command="{x:Bind ViewModel.OrderHistoryButtonCommand}"
     Content="Order History"
     RelativePanel.Below="DocumentsButton"
     RelativePanel.RightOf="ActivitiesButton"
     Style="{StaticResource CustomerDetailPageButton}" />

            <Button
     x:Name="PopOrderButton"
     MaxWidth="200"  Margin="10,10,0,0"
     Command="{x:Bind ViewModel.PopOrderButtonCommand}"
     Content="Pop Order"
     RelativePanel.Below="DistributionButton"
     RelativePanel.RightOf="OrderHistroryButton"
     Style="{StaticResource CustomerDetailPageButton}" />

            <Button
     x:Name="CreditRequest"
     MaxWidth="200"  Margin="10,10,0,0"
     Command="{x:Bind ViewModel.CreditRequestButtonCommand}"
     Content="Credit Request"
     RelativePanel.Below="RackOrderButton"
     RelativePanel.RightOf="PopOrderButton"
     Style="{StaticResource CustomerDetailPageButton}"
     Visibility="{x:Bind ViewModel.UiModel.IsDirectCustomer, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

            <Button
     x:Name="BtnChainPlaybook"
     MaxWidth="200"  Margin="10,10,0,0"
     Command="{x:Bind ViewModel.BtnClickChainPlaybookCommand}"
     Content="Chain Playbook"
     RelativePanel.Below="CarStockOrderButton"
     RelativePanel.RightOf="CreditRequest"
     Style="{StaticResource CustomerDetailPageButton}"
     Visibility="{x:Bind ViewModel.UiModel.IsChainPlaybookAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />


        </RelativePanel>

        <Grid
            x:Name="grdCustomerDocuments"
            Grid.Row="0"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            x:Load="{x:Bind ViewModel.AddDocumentVisibility, Mode=OneWay}">
            <Grid Background="Black" Opacity="0.7" />
            <customControl:CustomerDocumentControl
                CancelCommand="{x:Bind ViewModel.AddDocumentCommand, Mode=OneWay}"
                CustomerData="{x:Bind ViewModel.UiModel.CustomerData, Mode=TwoWay}"
                DocumentList="{x:Bind ViewModel.UiModel.CustomerDocuments, Mode=OneWay}"
                PreviewCommand="{x:Bind ViewModel.PreviewDocumentCommand, Mode=OneWay}"
                ResetControl="{x:Bind ViewModel.AddDocumentVisibility, Mode=OneWay}" />
        </Grid>

        <Grid
            x:Name="grdPreviewDocument"
            Grid.Row="0"
            Grid.RowSpan="3"
            d:Visibility="Collapsed"
            x:Load="{x:Bind ViewModel.PreviewDocumentVisibility, Mode=OneWay}">
            <customControl:PreviewDocumentControl
                CloseCommad="{x:Bind ViewModel.PreviewDocumentCommand}"
                FilePath="{x:Bind ViewModel.PreviewUrl, Mode=TwoWay}"
                IsPrintEmailIconVisible="True" />
        </Grid>

        <Grid
    x:Name="gridChildCustomers"
    Grid.Row="0"
    Grid.RowSpan="3"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    d:Visibility="Collapsed"
    x:Load="{x:Bind ViewModel.UiModel.IsPopUpOpenOfAssociatedCustomer, Mode=OneWay}">
            <Grid Background="Black" Opacity="0.7" />
            <customControl:CustomerListView 
                IsHeadQuarter="{x:Bind ViewModel.UiModel.CustomerData.IsParent, Mode=OneWay}"
                PopupHeaderText="{x:Bind ViewModel.UiModel.CustomerName, Mode=OneWay}"
                DataList="{x:Bind ViewModel.UiModel.AssociatedCustomerList, Mode=OneWay}"
                PopupCloseCommand="{x:Bind ViewModel.AssosicatedCustomerPopupCommand, Mode=OneWay}"
                />
        </Grid>

        <!--  Preview ChainPlaybook and images  -->
        <Grid
            x:Name="grdPreviewChainPlaybookGrid"
            Grid.Row="0"
            Grid.RowSpan="3"
            d:Visibility="Collapsed"
            x:Load="{x:Bind ViewModel.PreviewChainPlaybookVisibility, Mode=OneWay}">
            <customControl:PreviewDocumentControl
                 CloseCommad="{x:Bind ViewModel.BtnClosePreviewChainPlaybookCommand}"
                FilePath="{x:Bind ViewModel.PreviewUrlOfChainPlaybook, Mode=TwoWay}"
                IsPrintEmailIconVisible="True"
                PrintPictureCommand="{x:Bind ViewModel.BtnPrintChainPlaybookCommand}"/>
        </Grid>


        <!--  Loader  -->
        <Grid
        x:Name="ProgressRingGrid"
        Grid.Row="0"
        Grid.RowSpan="3"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        d:Visibility="Collapsed"
        x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
        Background="Black"
        Opacity="0.7">
            <ProgressRing
          Width="100"
          Height="100"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Foreground="White"
          IsActive="True" />
        </Grid>
    </Grid>

</Page>