<ContentDialog
    x:Class="DRLMobile.Uwp.CustomControls.CustomContentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DRLMobile.Uwp.CustomControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="dialog"
    mc:Ignorable="d">

    <!--  Content body  -->
    <Grid
        Margin="5"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock
            x:Name="title"
            Margin="5"
            MaxLines="4"
            Text="{Binding Title}"
            TextWrapping="Wrap" />
        <Button
            x:Name="btn1"
            Grid.Row="1"
            Width="350"
            HorizontalAlignment="Center"
            Background="{StaticResource LoginButtonBackground}"
            Click="btn1_Click"
            Content="{Binding FirstButtonText}" />
        <Button
            x:Name="btn2"
            Grid.Row="2"
            Width="350"
            HorizontalAlignment="Center"
            Background="{StaticResource LoginButtonBackground}"
            Click="btn2_Click"
            Content="{Binding FirstButtonText}" />
        <Button
            x:Name="btn3"
            Grid.Row="3"
            Width="350"
            HorizontalAlignment="Center"
            Background="{StaticResource LoginButtonBackground}"
            Click="btn3_Click"
            Content="{Binding FirstButtonText}" />
    </Grid>
</ContentDialog>

