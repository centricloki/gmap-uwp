                                                </Editors:TextInputMaskSettings>
                                            </Editors:TextEdit.TextInputSettings>
                                        </Editors:TextEdit>
                                    </DataTemplate>
                                </DE:GridTemplateColumn.CellTemplate>
                            </DE:GridTemplateColumn>

                            <DE:GridTemplateColumn
                                x:Name="delete"
                                Width="80"
                                AllowColumnFiltering="False">
                                <DE:GridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Action" />
                                    </DataTemplate>
                                </DE:GridTemplateColumn.HeaderTemplate>
                                <DE:GridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <!--<Grid Tapped="Delete_Tapped">-->
                                        <Image Tapped="Delete_Tapped"
                                                x:Name="deleteImage"
                                                Width="20"
                                                Height="20"
                                                Source="{StaticResource DeleteCart}" />
                                        <!--</Grid>-->
                                    </DataTemplate>
                                </DE:GridTemplateColumn.CellTemplate>
                            </DE:GridTemplateColumn>
                        </DE:GridControl.Columns>
                    </DE:GridControl>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="ConfirmOrderButton"
                Grid.Column="1"
                Margin="{StaticResource SmallLeftMargin}"
                HorizontalAlignment="Center"
                Background="White"
                Command="{x:Bind retailTransactionPageViewModel.ConfirmOrderCommand}"
                Content="Confirm Order"
                Style="{StaticResource CustomerDetailPageButton}" />
            <!--<TextBlock Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Height="70" Width="200"
                       Foreground="White" Tapped="AddSignature_TappedEvent"
                       FontSize="{StaticResource MediumFontSize}"
                       Text="Add Signature" />-->
            <TextBox
                Grid.Column="2"
                Height="70"
                Margin="20,5,5,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsReadOnly="False"
                PlaceholderForeground="Gray"
                PlaceholderText="Add Signature"
                Style="{StaticResource EditTextBoxStyle}"
                Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PrintName, Mode=OneWay}"
                TextAlignment="Center"
                 x:Name="SignatureTextBlock"
                	 x:Load="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SignatureTextButtonVisibility, Mode=OneWay,
            Converter={StaticResource VisibilityToBoolConverter}}" />

            <Button
                Grid.Column="2"
                Width="Auto"
                Height="70"
                MinWidth="220"
                Margin="150,0,0,0"
                Background="Transparent"
                Click="SignatureButton_Click"
                Foreground="Transparent"
                Opacity="0"
                x:Name="SignatureButton"
                	 x:Load="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SignatureTextButtonVisibility, Mode=OneWay,
            Converter={StaticResource VisibilityToBoolConverter}}" />

            <Image
                Grid.Column="2"
                Width="Auto"
                Margin="140,0,100,10"
                VerticalAlignment="Center"  CacheMode="BitmapCache" 
                Source="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CustomerSignPath, Mode=OneWay}"
                Tapped="SignatureImageView_Tapped" />
        </Grid>

        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
             x:Name="SignatureGridPanel"
             x:Load="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SignaturePanelVisibility, Mode=OneWay,
            Converter={StaticResource VisibilityToBoolConverter}}"
            Visibility="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SignaturePanelVisibility, Mode=TwoWay}">
            <Grid Background="Black" Opacity="0.7" />
            <customControls:NameAndSignaturePanelControl
                CancelCommand="{x:Bind retailTransactionPageViewModel.CancelSignPanelCommand}"
                IsSignStarted="True"
                PrintName="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PrintName, Mode=TwoWay}"
                SaveSignatureCommand="{x:Bind retailTransactionPageViewModel.SaveSignatureCommand}"
                SignatureFileName="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CustomerSignatureFileName, Mode=TwoWay}" />
        </Grid>

        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
             x:Name="ProgressRingGrid"
                	 x:Load="{x:Bind retailTransactionPageViewModel.LoadingVisibility, Mode=OneWay,
            Converter={StaticResource VisibilityToBoolConverter}}"
            Visibility="{Binding retailTransactionPageViewModel.LoadingVisibility}">
            <Grid Background="Black" Opacity="0.3" />
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>

    </Grid>

</Page>
