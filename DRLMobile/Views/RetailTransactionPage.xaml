<Page
    x:Class="DRLMobile.Views.RetailTransactionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:converter="using:DRLMobile.Converters"
    xmlns:customControls="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <Style x:Key="NoExpanderHeaderStyle" TargetType="ToggleButton">
                <Setter Property="Visibility" Value="Collapsed" />
            </Style>
            <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource CartTextColor}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
            </Style>
            <Flyout
                x:Key="CustomGridKeyPadFlyout"
                x:Name="QuantityGridCustomKeyPadFlyout"
                Closing="QuantityCustomKeyPadFlyout_Closing"
                FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                LightDismissOverlayMode="Off"
                Placement="Left">
                <customControls:CustomKeypad
                    DoneClickEvent="CustomKeypad_DoneClickEvent1"
                    IsDotButtonVisible="Collapsed"
                    IsMinusButtonVisible="Visible"
                    NumPadButtonClick="{x:Bind retailTransactionPageViewModel.NumPadGridButtonClickCommand, Mode=OneWay}" />
            </Flyout>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundColor}">

        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="90" />
        </Grid.RowDefinitions>

        <customControls:HeaderControl
            Title="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PageTitle, Mode=OneWay}"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            IsPageTitleVisible="Visible" />

        <ScrollViewer x:Name="ParentScrollView" Grid.Row="1">
            <Grid Padding="0,10,0,0" RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Grid.Column="0"
                    Spacing="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.TransactionNumberText, Mode=OneWay}" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.TransactionNumber, Mode=OneWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Account" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.AccountNumber, Mode=OneWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Purchase Order" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Purchase Order"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PurchaseOrderNumber, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Customer Name" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Customer Name"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CustomerName, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Address" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Height="70"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Addreess"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.Address, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="City" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="City"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CityName, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="State" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <ComboBox
                            Grid.Column="1"
                            Margin="20,10,0,0"
                            FontSize="16"
                            ItemsSource="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.States.Values, Mode=OneWay}"
                            SelectedItem="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SelectedPhysicalState, Mode=TwoWay}"
                            Style="{StaticResource ComboBoxEditStyle}">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Zip" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <!--  BeforeTextChanging="NumericTextBox_BeforeTextChanging"  -->
                        <TextBox
                            Grid.Column="1"
                            d:Text="zip"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.Zip, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="State Tobacco License" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Tobacco License"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.StateTobaccoLicense, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Retailer License" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Retailer License"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.RetailerLicense, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Retailer Sales Tax Certificate :" />

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Sales Tax Certificate"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.RetailerSalesTaxCertificate, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Email To" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Height="70"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.EmailTo, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Custom Tax Statement :" />

                        <TextBox
                            Grid.Column="1"
                            Height="70"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CustomTaxStatement, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CommentsLabel, Mode=OneWay}" />

                        <!--  Text="Enter Retail Sales Call Notes :" />  -->

                        <TextBox
                            Grid.Column="1"
                            Height="70"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.RetailsSalesCallNotes, Mode=TwoWay}" />
                    </Grid>

                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Republic Sales Rep :" />

                        <TextBox
                            Grid.Column="1"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.RepublicSalesRepName, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Seller's Representative Tobacco Permit :" />

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Permit Number"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SellerRepresentativeTobaccoPermit, Mode=TwoWay}" />

                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="salesTypeLabel"
                            Padding="0,5,0,0"
                            VerticalAlignment="Top"
                            Style="{StaticResource FieldTextBlockStyle}"
                            Text="Sales Type : " />

                        <StackPanel
                            x:Name="SalesTypeStackPanel"
                            Grid.Column="1"
                            Padding="30,10"
                            Spacing="6"
                            Visibility="Visible">
                            <muxc:RadioButtons SelectedIndex="0" SelectionChanged="SalesTypeOption_SelectionChanged">
                                <x:String>Cash Sale</x:String>
                                <x:String>Prebook</x:String>
                                <x:String>Suggested Order</x:String>
                                <x:String>Bill Through</x:String>
                                <x:String>Cash Sales Initiative</x:String>
                                <x:String>Chain Distribution</x:String>
                                <x:String>Credit Card Sales</x:String>
                            </muxc:RadioButtons>
                            <!--<RadioButton Content="Cash Sale" Tag="CashSale" IsChecked="True" Checked="CashSale_RadioButton_Checked"  GroupName="TextColor"/>
                            <RadioButton Content="Prebook" Tag="Prebook" Checked="Prebook_RadioButton_Checked"  GroupName="TextColor"/>
                            <RadioButton Content="Suggested Order" Tag="SuggestedOrder" Checked="SuggestedOrder_RadioButton_Checked"  GroupName="TextColor"/>
                            <RadioButton Content="Bill Through" Tag="BillThrough" Checked="BillThrough_RadioButton_Checked"  GroupName="TextColor"/>
                            <RadioButton Content="Rack/POS" Tag="RackPOS" Checked="RackPOS_RadioButton_Checked"  GroupName="TextColor"/>
                            <RadioButton Content="Cash Sales Initiative" Tag="CashSalesInitiative" Checked="CashSalesInitiative_RadioButton_Checked"  GroupName="TextColor"/>
                            <RadioButton Content="Chain Distribution" Tag="ChainDistribution" Checked="ChainDistribution_RadioButton_Checked"  GroupName="TextColor"/>
                            <RadioButton Content="Credit Card Sales" Tag="CreditCardSales" Checked="CreditCardSales_RadioButton_Checked"  GroupName="TextColor"/>-->
                        </StackPanel>
                        <StackPanel
                            x:Name="sampleOrderStackPanel"
                            Grid.Column="1"
                            Padding="30,10"
                            Spacing="6"
                            Visibility="Collapsed">
                            <RadioButton
                                Content="Sample Order"
                                IsChecked="True"
                                Tag="SampleOrder" />
                        </StackPanel>
                        <StackPanel
                            x:Name="rackPosOrderStackPanel"
                            Grid.Column="1"
                            Padding="30,10"
                            Spacing="6"
                            Visibility="Collapsed">
                            <RadioButton
                                Content="Rack/POS"
                                IsChecked="True"
                                Tag="RackPOS" />
                        </StackPanel>

                    </Grid>

                    <StackPanel x:Name="distributorStackPanel" Visibility="Visible">
                        <Grid Padding="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Distributor :" />

                            <Grid
                                x:Name="DistributorGrid"
                                Grid.Column="1"
                                MinWidth="250"
                                MinHeight="40"
                                Margin="20,10,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                CornerRadius="5"
                                Style="{StaticResource EditBackgroundGridStyle}"
                                Tapped="DistributorGrid_Tapped">

                                <FlyoutBase.AttachedFlyout>
                                    <Flyout
                                        x:Name="DistributorFlyout"
                                        FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                                        LightDismissOverlayMode="Off">
                                        <Grid
                                            Width="300"
                                            Height="300"
                                            Background="White"
                                            BorderBrush="Black"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="auto" />
                                            </Grid.RowDefinitions>

                                            <Grid
                                                Grid.Row="0"
                                                Height="35"
                                                HorizontalAlignment="Stretch"
                                                Background="{StaticResource FooterBackgroundColor}">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    Foreground="White"
                                                    Text="Select Distributor" />
                                            </Grid>

                                            <ListView
                                                Grid.Row="1"
                                                ItemsSource="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.DistributorsList, Mode=OneWay}"
                                                SelectionMode="None">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid
                                                            x:Name="DistributorTemplateGrid"
                                                            Background="Transparent"
                                                            Tapped="DistributorTemplateGrid_Tapped">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="25" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock
                                                                    MinWidth="250"
                                                                    HorizontalAlignment="Stretch"
                                                                    FontSize="12"
                                                                    FontWeight="Medium"
                                                                    Text="{Binding CustomerName}"
                                                                    TextWrapping="Wrap" />
                                                                <TextBlock FontSize="11" TextWrapping="Wrap">
                                                                    <TextBlock.Inlines>
                                                                        <Run Text="{Binding DistributorID}" />
                                                                        <Run Text="," />
                                                                        <Run Text="{Binding StateName}" />
                                                                    </TextBlock.Inlines>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>

                                            <StackPanel
                                                Grid.Row="2"
                                                Margin="3"
                                                HorizontalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="10">
                                                <Button
                                                    Click="CancelButton_Click"
                                                    Content="Cancel"
                                                    Style="{StaticResource FlyoutButtonStyle}" />
                                                <!--<Button Click="DoneButton_Click"
                                                        Content="Done" Style="{StaticResource FlyoutButtonStyle}" />-->
                                            </StackPanel>
                                        </Grid>

                                    </Flyout>
                                </FlyoutBase.AttachedFlyout>

                                <TextBlock
                                    x:Name="selectedDistributor"
                                    Margin="5,10,10,10"
                                    FontSize="{StaticResource MediumFontSize}"
                                    Foreground="{StaticResource LoginScreenTextFontColor}"
                                    Text="Select Distributor" />
                            </Grid>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="City :" />

                            <TextBox
                                Grid.Column="1"
                                IsReadOnly="True"
                                PlaceholderForeground="LightGray"
                                PlaceholderText="City"
                                Style="{StaticResource EditTextBoxStyle}"
                                Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PrebookCity, Mode=OneWay}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.ColumnSpan="2"
                                Margin="0,18,99,0"
                                VerticalAlignment="Top"
                                Style="{StaticResource FieldTextBlockStyle}"
                                Text="State :" />

                            <ComboBox
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Margin="20,10,0,0"
                                FontSize="16"
                                IsEnabled="False"
                                ItemsSource="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PrebookState.Values, Mode=OneWay}"
                                SelectedItem="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SelectedPrebookState, Mode=TwoWay}"
                                Style="{StaticResource ComboBoxEditStyle}">

                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Zip :" />

                            <TextBox
                                Grid.Column="1"
                                IsReadOnly="True"
                                PlaceholderForeground="LightGray"
                                PlaceholderText="Zip"
                                Style="{StaticResource EditTextBoxStyle}"
                                Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PrebookZip, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>

                    <Grid Padding="0,100">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Prebook Ship Date :" />

                        <CalendarDatePicker
                            x:Name="prebookDatePicker"
                            Grid.Column="1"
                            Margin="20,10,0,0"
                            Background="White"
                            DateChanged="prebookDatePicker_DateChanged"
                            PlaceholderText="Choose Prebook Date" />
                    </Grid>

                </StackPanel>

                <StackPanel
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Padding="0,20,0,0"
                    Spacing="0">

                    <StackPanel
                        x:Name="tobaccoStackPanel"
                        Margin="90,0"
                        Visibility="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.TobaccoGridVisibility, Mode=OneWay}">
                        <controls:Expander HorizontalAlignment="Stretch" IsExpanded="True">
                            <controls:Expander.Header>
                                <TextBlock
                                    HorizontalAlignment="Left"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource CartTextColor}"
                                    Text="Tobacco Products" />
                            </controls:Expander.Header>

                            <Grid x:Name="tobaccoMainGrid">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DE:GridControl
                                    x:Name="tobaccoDataGridControl"
                                    Grid.Row="0"
                                    AlternationCount="2"
                                    AutoGenerateColumns="False"
                                    FontSize="{StaticResource DataGridTextSize}"
                                    ItemsSource="{x:Bind retailTransactionPageViewModel.TobaccoGridDataSource, Mode=TwoWay}"
                                    ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                    ShowAutoFilterRow="False"
                                    ShowCriteriaInAutoFilterRow="False"
                                    ShowGroupPanel="False"
                                    ShowGroupedColumns="False">
                                    <DE:GridControl.Columns>

                                        <DE:GridTextColumn
                                            AllowColumnFiltering="False"
                                            FieldName="BrandName"
                                            TextWrapping="Wrap">
                                            <DE:GridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Brand" />
                                                </DataTemplate>
                                            </DE:GridTextColumn.HeaderTemplate>
                                        </DE:GridTextColumn>

                                        <DE:GridTextColumn
                                            AllowColumnFiltering="False"
                                            FieldName="StyleName"
                                            TextWrapping="Wrap">
                                            <DE:GridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Style" />
                                                </DataTemplate>
                                            </DE:GridTextColumn.HeaderTemplate>
                                        </DE:GridTextColumn>

                                        <DE:GridTextColumn
                                            AllowColumnFiltering="False"
                                            FieldName="ItemNumber"
                                            TextWrapping="Wrap">
                                            <DE:GridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                                                </DataTemplate>
                                            </DE:GridTextColumn.HeaderTemplate>
                                        </DE:GridTextColumn>

                                        <DE:GridTextColumn
                                            Width="270"
                                            AllowColumnFiltering="False"
                                            FieldName="ItemDescription"
                                            TextWrapping="Wrap">
                                            <DE:GridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                                                </DataTemplate>
                                            </DE:GridTextColumn.HeaderTemplate>
                                        </DE:GridTextColumn>

                                        <DE:GridTextColumn
                                            AllowColumnFiltering="False"
                                            FieldName="Quantity"
                                            TextWrapping="Wrap">
                                            <DE:GridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Quantity" />
                                                </DataTemplate>
                                            </DE:GridTextColumn.HeaderTemplate>
                                        </DE:GridTextColumn>

                                        <DE:GridTextColumn
                                            AllowColumnFiltering="False"
                                            FieldName="Unit"
                                            TextWrapping="Wrap">
                                            <DE:GridTextColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unit" />
                                                </DataTemplate>
                                            </DE:GridTextColumn.HeaderTemplate>
                                        </DE:GridTextColumn>

                                        <DE:GridTextColumn
                                            AllowColumnFiltering="False"
                                            FieldName="Price"
                                            TextWrapping="Wrap">
                                            <DE:GridTextColumn.HeaderTemplate>
                                                <DataTemplate>
