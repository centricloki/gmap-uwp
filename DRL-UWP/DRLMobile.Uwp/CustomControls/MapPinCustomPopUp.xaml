                                                <Run
                                                    FontStyle="Italic"
                                                    FontWeight="SemiBold"
                                                    Text="Start Date:" />
                                                <Run Text="29/11/2009" />
                                            </TextBlock.Inlines>
                                        </TextBlock>

                                        <TextBlock
                                            Grid.Column="2"
                                            Style="{StaticResource LeftTextBlockStyle}"
                                            TextWrapping="WrapWholeWords">
                                            <TextBlock.Inlines>
                                                <Run
                                                    FontStyle="Italic"
                                                    FontWeight="SemiBold"
                                                    Text="End Date:" />
                                                <Run Text="12/12/2009" />
                                            </TextBlock.Inlines>
                                        </TextBlock>

                                        <Button
                                            Grid.Column="3"
                                            Width="50"
