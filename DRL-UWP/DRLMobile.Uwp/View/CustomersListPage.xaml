<Page
    x:Class="DRLMobile.Uwp.View.CustomersListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:converter="using:DRLMobile.Uwp.Converters"
    xmlns:core="using:Microsoft.Xaml.Interactions.Core"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helper="using:DRLMobile.Uwp.Helpers"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:DRLMobile.Core.Models.UIModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="using:System"
    xmlns:wctprimitives="using:Microsoft.Toolkit.Uwp.UI.Controls.Primitives"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="Black" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="HorizontalTextAlignment" Value="Left" />
                <Setter Property="Margin" Value="10,10,20,10" />
            </Style>
            <Style x:Key="GridDataRowStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="Foreground" Value="Gray" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="HorizontalTextAlignment" Value="Left" />
                <Setter Property="Margin" Value="10,10,5,10" />
            </Style>
            <Style x:Key="ColumnHeaderStyle" TargetType="wctprimitives:DataGridColumnHeader">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="Black" />
                <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
            </Style>

            <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </Page.Resources>
    <Grid x:Name="outerPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <!--  outerPanel.Grid.Row="0"  -->
        <customControls:HeaderControl
            x:Name="HeaderControl"
            x:Uid="CustomerPageSearch"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            DisplayMemberPathValue="SearchDisplayPath"
            IsAccountOwnerFilterVisible="{x:Bind ViewModel.IsAccountOwnerFilterVisible, Mode=TwoWay}"
            IsAutoSuggestBoxVisible="Visible"
            IsCustomerPageTitleVisible="Visible"
            IsPageTitleVisible="Visible"
            IsRbDataVisible="{x:Bind ViewModel.IsRbDataVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            ItemList="{x:Bind ViewModel.HeaderSearchItemSource, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SuggestionChoosenCommand="{x:Bind ViewModel.HeaderSearchSuggestionChoosenCommand}"
            TextValueChangedCommand="{x:Bind ViewModel.HeaderSearchTextChangeCommand}"
            rbActivityDataChangedCommand="{x:Bind ViewModel.rbCustomerDataChangedCommand}"
            rbAssignmentTypeChangedCommand="{x:Bind ViewModel.rbAssignmentTypeChangedCommand}" />
        <!--  outerPanel.Grid.Row="1"  -->
        <Grid x:Name="gridAllCustomers" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.Resources>
                <SolidColorBrush x:Key="gridBrush" Color="Silver" />
            </Grid.Resources>
            <!--  gridAllCustomers.Grid.Row=0  -->
            <Grid x:Name="grdAllCustomerHeader" Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96.4*" />
                    <ColumnDefinition Width="3.6*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <!--  CustomerName  -->
                        <ColumnDefinition Width="5*" />
                        <!--  CustomerNo  -->
                        <ColumnDefinition Width="4*" />
                        <!--  Store Type  -->
                        <ColumnDefinition Width="3.5*" />
                        <!--  Rank  -->
                        <ColumnDefinition Width="2*" />
                        <!--  Address  -->
                        <ColumnDefinition Width="3*" />
                        <!--  City  -->
                        <ColumnDefinition Width="3*" />
                        <!--  State  -->
                        <ColumnDefinition Width="2.4*" />
                        <!--  terrname  -->
                        <ColumnDefinition Width="3.3*" />
                        <!--  calldate  -->
                        <ColumnDefinition Width="3.4*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Grid.Resources>
                        <Style TargetType="Grid">
                            <Setter Property="BorderBrush" Value="{StaticResource gridBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,1,0" />
                        </Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Foreground" Value="Black" />
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="Grid.Column" Value="0" />
                            <Setter Property="Margin" Value="10" />
                        </Style>
                        <Style TargetType="Image">
                            <Setter Property="Width" Value="20" />
                            <Setter Property="Height" Value="15" />
                            <Setter Property="Grid.Column" Value="1" />
                            <Setter Property="VerticalAlignment" Value="Top" />
                            <Setter Property="Margin" Value="0,15,0,0" />
                        </Style>
                        <Style TargetType="TextBox">
                            <Setter Property="BorderBrush" Value="{StaticResource gridBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                            <Setter Property="CornerRadius" Value="0" />
                            <Setter Property="Padding" Value="10" />
                            <Setter Property="PlaceholderText" Value="Search..." />
                            <Setter Property="TextWrapping" Value="WrapWholeWords" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="Grid.Row" Value="1" />
                        </Style>
                    </Grid.Resources>
                    <!--  1st Row  -->
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.80*" />
                            <ColumnDefinition Width="0.20*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CUSTOMER NAME" />
                        <Image
                            x:Name="sortCustomerNameImg"
                            x:Load="{x:Bind IsNotEmpty(ViewModel.SortCustomerName), Mode=OneWay}"
                            Source="{x:Bind GetSortImagePath(ViewModel.SortCustomerName), Mode=OneWay}" />
                        <!--  Sort Button Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="PointerPressed">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.SortColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('customername|{0}', ViewModel.SortCustomerName), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.80*" />
                            <ColumnDefinition Width="0.20*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CUSTOMER#" />
                        <Image
                            x:Name="sortCustomerNoImg"
                            x:Load="{x:Bind IsNotEmpty(ViewModel.SortCustomerNo), Mode=OneWay}"
                            Source="{x:Bind GetSortImagePath(ViewModel.SortCustomerNo), Mode=OneWay}" />
                        <!--  Sort Button Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="PointerPressed">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.SortColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('customernumber|{0}', ViewModel.SortCustomerNo), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </Grid>
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.80*" />
                            <ColumnDefinition Width="0.20*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="STORE TYPE" />
                        <Image
                            x:Name="sortStoreTypeImg"
                            x:Load="{x:Bind IsNotEmpty(ViewModel.SortStoreType), Mode=OneWay}"
                            Source="{x:Bind GetSortImagePath(ViewModel.SortStoreType), Mode=OneWay}" />
                        <!--  Sort Button Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="PointerPressed">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.SortColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('storetype|{0}', ViewModel.SortStoreType), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </Grid>
                    <Grid Grid.Column="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.80*" />
                            <ColumnDefinition Width="0.20*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RANK" />
                        <Image
                            x:Name="sortRankImg"
                            x:Load="{x:Bind IsNotEmpty(ViewModel.SortRank), Mode=OneWay}"
                            Source="{x:Bind GetSortImagePath(ViewModel.SortRank), Mode=OneWay}" />
                        <!--  Sort Button Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="PointerPressed">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.SortColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('rank|{0}', ViewModel.SortRank), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </Grid>
                    <Grid Grid.Column="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.80*" />
                            <ColumnDefinition Width="0.20*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ADDRESS" />
                        <Image
                            x:Name="sortAddressImg"
                            x:Load="{x:Bind IsNotEmpty(ViewModel.SortAddress), Mode=OneWay}"
                            Source="{x:Bind GetSortImagePath(ViewModel.SortAddress), Mode=OneWay}" />
                        <!--  Sort Button Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="PointerPressed">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.SortColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('address|{0}', ViewModel.SortAddress), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </Grid>
                    <Grid Grid.Column="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.80*" />
                            <ColumnDefinition Width="0.20*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CITY" />
                        <Image
                            x:Name="sortCityImg"
                            x:Load="{x:Bind IsNotEmpty(ViewModel.SortCity), Mode=OneWay}"
                            Source="{x:Bind GetSortImagePath(ViewModel.SortCity), Mode=OneWay}" />
                        <!--  Sort Button Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="PointerPressed">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.SortColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('city|{0}', ViewModel.SortCity), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </Grid>
                    <Grid Grid.Column="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.80*" />
                            <ColumnDefinition Width="0.20*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="STATE" />
                        <Image
                            x:Name="sortStateImg"
                            x:Load="{x:Bind IsNotEmpty(ViewModel.SortState), Mode=OneWay}"
                            Source="{x:Bind GetSortImagePath(ViewModel.SortState), Mode=OneWay}" />
                        <!--  Sort Button Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="PointerPressed">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.SortColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('state|{0}', ViewModel.SortState), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </Grid>
                    <Grid Grid.Column="7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.80*" />
                            <ColumnDefinition Width="0.20*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="TERRITORY#" />
                        <Image
                            x:Name="sortTerritoryImg"
                            x:Load="{x:Bind IsNotEmpty(ViewModel.SortTerritory), Mode=OneWay}"
                            Source="{x:Bind GetSortImagePath(ViewModel.SortTerritory), Mode=OneWay}" />
                        <!--  Sort Button Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="PointerPressed">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.SortColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('territory|{0}', ViewModel.SortTerritory), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </Grid>
                    <Grid Grid.Column="8" BorderBrush="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.80*" />
                            <ColumnDefinition Width="0.20*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="LAST CALLDATE" />
                        <Image
                            x:Name="sortCalldateImg"
                            x:Load="{x:Bind IsNotEmpty(ViewModel.SortCalldate), Mode=OneWay}"
                            Source="{x:Bind GetSortImagePath(ViewModel.SortCalldate), Mode=OneWay}" />
                        <!--  Sort Button Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="PointerPressed">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.SortColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('calldate|{0}', ViewModel.SortCalldate), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </Grid>
                    <!--  2nd Row  -->
                    <TextBox Grid.Column="0" Text="{x:Bind ViewModel.FilterCustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <!--  Text Box Filter Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="TextChanged">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.FilterColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('customername|{0}', ViewModel.FilterCustomerName), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </TextBox>
                    <TextBox Grid.Column="1" Text="{x:Bind ViewModel.FilterCustomerNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <!--  Text Box Filter Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="TextChanged">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.FilterColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('customernumber|{0}', ViewModel.FilterCustomerNumber), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </TextBox>
                    <TextBox Grid.Column="2" Text="{x:Bind ViewModel.FilterStoreType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <!--  Text Box Filter Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="TextChanged">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.FilterColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('storetype|{0}', ViewModel.FilterStoreType), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </TextBox>
                    <TextBox Grid.Column="3" Text="{x:Bind ViewModel.FilterRank, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <!--  Text Box Filter Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="TextChanged">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.FilterColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('rank|{0}', ViewModel.FilterRank), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </TextBox>
                    <TextBox Grid.Column="4" Text="{x:Bind ViewModel.FilterAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <!--  Text Box Filter Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="TextChanged">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.FilterColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('address|{0}', ViewModel.FilterAddress), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </TextBox>
                    <TextBox Grid.Column="5" Text="{x:Bind ViewModel.FilterCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <!--  Text Box Filter Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="TextChanged">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.FilterColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('city|{0}', ViewModel.FilterCity), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </TextBox>
                    <TextBox Grid.Column="6" Text="{x:Bind ViewModel.FilterState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <!--  Text Box Filter Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="TextChanged">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.FilterColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('state|{0}', ViewModel.FilterState), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </TextBox>
                    <TextBox Grid.Column="7" Text="{x:Bind ViewModel.FilterTerritory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <!--  Text Box Filter Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="TextChanged">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.FilterColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('Territory|{0}', ViewModel.FilterTerritory), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </TextBox>
                    <TextBox
                        Grid.Column="8"
                        BorderThickness="0,0,0,1"
                        Text="{x:Bind ViewModel.FilterCalldate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <!--  Text Box Filter Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="TextChanged">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.FilterColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('calldate|{0}', ViewModel.FilterCalldate), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </TextBox>
                </Grid>
                <Grid
                    Grid.Column="1"
                    BorderBrush="{StaticResource gridBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid.Resources>
                        <Style TargetType="Image">
                            <Setter Property="Width" Value="20" />
                            <Setter Property="Height" Value="15" />
                            <Setter Property="VerticalAlignment" Value="Top" />
                        </Style>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <Button
                        Grid.Row="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0">
                        <Image
                            x:Name="sortIsEllipsisVisibleImg"
                            x:Load="{x:Bind IsNotEmpty(ViewModel.SortIsEllipsisVisible), Mode=OneWay}"
                            Source="{x:Bind GetSortImagePath(ViewModel.SortIsEllipsisVisible), Mode=OneWay}" />
                        <!--  Sort Button Click  -->
                        <interactivity:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="Click">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.SortColumnClickCommand, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('isellipse|{0}', ViewModel.SortIsEllipsisVisible), Mode=OneWay}" />
                            </core:EventTriggerBehavior>
                        </interactivity:Interaction.Behaviors>
                    </Button>
                    <Rectangle
                        Grid.Row="1"
                        Fill="White"
                        Stroke="{StaticResource gridBrush}"
                        StrokeThickness="0" />
                </Grid>
            </Grid>
            <!--  gridAllCustomers.Grid.Row=1  -->
            <customControls:CustomAlternateRowColorListView
                x:Name="lstAllCustomers"
                Grid.Row="1" Background="#FFFFFF"
                IsTextScaleFactorEnabled="False"
                ItemsSource="{x:Bind ViewModel.CustomerList, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:CustomerPageUIModel">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96.4*" />
                                <ColumnDefinition Width="3.6*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Tapped="customerListDataGrid_ItemClick">
                                <Grid.ColumnDefinitions>
                                    <!--  CustomerName  -->
                                    <ColumnDefinition Width="5*" />
                                    <!--  CustomerNo  -->
                                    <ColumnDefinition Width="4*" />
                                    <!--  Store Type  -->
                                    <ColumnDefinition Width="3.5*" />
                                    <!--  Rank  -->
                                    <ColumnDefinition Width="2*" />
                                    <!--  Address  -->
                                    <ColumnDefinition Width="3*" />
                                    <!--  City  -->
                                    <ColumnDefinition Width="3*" />
                                    <!--  State  -->
                                    <ColumnDefinition Width="2.4*" />
                                    <!--  terrname  -->
                                    <ColumnDefinition Width="3.3*" />
                                    <!--  calldate  -->
                                    <ColumnDefinition Width="3.4*" />
                                </Grid.ColumnDefinitions>
                                <Grid.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="15" />
                                        <Setter Property="FontWeight" Value="Normal" />
                                        <Setter Property="Foreground" Value="Gray" />
                                        <Setter Property="TextWrapping" Value="WrapWholeWords" />
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Padding" Value="10,3,0,3" />
                                    </Style>
                                </Grid.Resources>
                                <TextBlock Grid.Column="0" Text="{x:Bind CustomerName, Mode=OneWay}" />
                                <TextBlock Grid.Column="1" Text="{x:Bind CustomerNumber, Mode=OneWay}" />
                                <TextBlock Grid.Column="2" Text="{x:Bind StoreType, Mode=OneWay}" />
                                <TextBlock Grid.Column="3" Text="{x:Bind Rank, Mode=OneWay}" />
                                <TextBlock Grid.Column="4" Text="{x:Bind Address, Mode=OneWay}" />
                                <TextBlock Grid.Column="5" Text="{x:Bind City, Mode=OneWay}" />
                                <TextBlock Grid.Column="6" Text="{x:Bind State, Mode=OneWay}" />
                                <TextBlock Grid.Column="7" Text="{x:Bind TerritoryName, Mode=OneWay}" />
                                <TextBlock Grid.Column="8" Text="{x:Bind sys:String.Format('{0:MM-dd-yyyy}', CallDate), Mode=OneWay}" />
                            </Grid>
                            <Grid
                                Name="EllipsisGrid"
                                Grid.Column="1"
                                Tapped="EllipsisGrid_Tapped"
                                Visibility="{x:Bind IsEllipsisVisible, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FontIcon
                                    x:Name="EllipsisImage"
                                    Width="20"
                                    Height="30"
                                    FontWeight="ExtraBold"
                                    Glyph="{StaticResource EllipsisIcon}"
                                    Style="{StaticResource FontIconStyle}" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </customControls:CustomAlternateRowColorListView>
        </Grid>
        <!--  outerPanel.Grid.Row="2"  -->
        <Grid Grid.Row="2" Background="White">
            <Button
                x:Uid="AddCustomerButton"
                Height="33"
                Margin="{StaticResource XSmallLeftTopRightBottomMargin}"
                HorizontalAlignment="Center"
                Command="{x:Bind ViewModel.AddCustomerCommand}"
                FontSize="15"
                Style="{StaticResource LoginButtonStyle}" />
        </Grid>
        <!--  outerPanel.Grid.Row="1"  -->
        <Grid
            Grid.Row="1"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{Binding LoadingVisibility}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>
        <!--  outerPanel.Grid.Row="0"  -->
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Visibility="{x:Bind ViewModel.TravelPopUpVisibility, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Background="Black" Opacity="0.7" />
            <customControls:TravelVripPromotionContractPage
                CloseCommad="{x:Bind ViewModel.TravelPopUpCloseCommand}"
                CustomerNameText="{x:Bind ViewModel.CustomerName, Mode=OneWay}"
                ResetControl="{x:Bind ViewModel.TravelPopUpVisibility, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>