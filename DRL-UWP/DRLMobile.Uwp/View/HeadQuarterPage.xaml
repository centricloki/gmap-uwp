<Page 
    x:Name="headQuarterPage"
    x:Class="DRLMobile.Uwp.View.HeadQuarterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:DRLMobile.Uwp.ViewModel"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:core="using:Microsoft.Xaml.Interactions.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:Name="outerPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <!--outerPanel.Grid.Row="0"-->
        <customControls:HeaderControl
        x:Name="HeaderControl"
        x:Uid="HQCustomerPage"
        Grid.Row="0"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Top"
        IsPageTitleVisible="Visible"
        ScrollViewer.HorizontalScrollBarVisibility="Hidden"
        ScrollViewer.VerticalScrollBarVisibility="Hidden"/>

    </Grid>


</Page>


