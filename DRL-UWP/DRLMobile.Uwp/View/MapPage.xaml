                                                                VerticalAlignment="Center"
                                                                FontSize="16"
                                                                Foreground="{StaticResource FooterTextColor}"
                                                                Text="Filter" />
                                                        </Grid>
                                                        <TextBox
                                                            x:Name="FlyoutItemTextBox"
                                                            Grid.Row="1"
                                                            Width="300"
                                                            Margin="6"
                                                            HorizontalAlignment="Center"
                                                            Background="White"
                                                            BorderBrush="Black"
                                                            BorderThickness="1"
                                                            CornerRadius="5"
                                                            PlaceholderText="Search by name">
                                                            <i:Interaction.Behaviors>
                                                                <core:EventTriggerBehavior EventName="TextChanged">
                                                                    <core:InvokeCommandAction Command="{x:Bind ViewModel.ItemSearchHeaderTextChangeCommand, Mode=OneWay}" CommandParameter="{Binding ElementName=FlyoutItemTextBox, Path=Text}" />
                                                                </core:EventTriggerBehavior>
                                                            </i:Interaction.Behaviors>
                                                        </TextBox>
                                                        <ListView
                                                            Grid.Row="2"
                                                            Width="300"
                                                            ItemContainerStyle="{StaticResource ListViewItemStyle}"
                                                            ItemsSource="{x:Bind ViewModel.ProductList, Mode=OneWay}"
                                                            SelectionMode="None">

                                                            <ListView.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid
                                                                        HorizontalAlignment="Stretch"
                                                                        Background="Transparent"
                                                                        Tapped="ItemSelected">
                                                                        <TextBlock Margin="5" TextWrapping="WrapWholeWords">
                                                                            <TextBlock.Inlines>
                                                                                <Run Text="{Binding ProductName}" />
                                                                                <Run Text=" - " />
                                                                                <Run Text="{Binding Description}" />
                                                                            </TextBlock.Inlines>
                                                                        </TextBlock>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListView.ItemTemplate>
                                                        </ListView>
                                                    </Grid>
                                                </Flyout>
                                            </FlyoutBase.AttachedFlyout>

                                            <TextBlock
                                                Grid.Column="0"
                                                Width="400"
                                                Margin="0,0,5,0"
                                                Padding="10,3,26,6"
                                                FontSize="12"
                                                IsHitTestVisible="False"
                                                TextTrimming="WordEllipsis">
                                                <TextBlock.Inlines>
                                                    <Run Text="{x:Bind ViewModel.FilterSelectedItem.ProductName, Mode=OneWay}" />
                                                    <Run Text="{x:Bind ViewModel.FilterSelectedItem.Description, Mode=OneWay}" />
                                                </TextBlock.Inlines>
                                            </TextBlock>
                                            <FontIcon
                                                Grid.Column="1"
                                                Margin="0,0,10,0"
                                                HorizontalAlignment="Right"
                                                FontSize="12"
                                                Glyph="{StaticResource RightFilledArrowIcon}"
                                                Style="{x:Bind ViewModel.IsItemDropDownEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='ZoneFilterFontIcon'}" />
                                        </Grid>

                                    </RelativePanel>
                                    <!--#endregion-->
                                </StackPanel>

                                <!--#region Clear All and Filter Buttons-->
                                <StackPanel
                                    Grid.Row="2"
                                    Margin="3,3,3,10"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="10">
                                    <Button
                                        Width="70"
                                        Padding="5"
                                        Command="{x:Bind ViewModel.ClearFilterCommand}"
                                        Content="Clear All"
                                        FontSize="14"
                                        Style="{StaticResource FlyoutButtonStyle}" />
                                    <Button
                                        Width="70"
                                        Padding="5"
                                        Click="ApplyFilterButton_Click"
                                        Content="Filter"
                                        FontSize="14"
                                        Style="{StaticResource FlyoutButtonStyle}" />
                                </StackPanel>
                                <!--#endregion-->

                            </Grid>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </Button>

                <!--#region Plot Account By Filter Section-->
                <Button
                    x:Name="PlotAccountByButton"
                    Padding="10,6,10,6"
                    HorizontalAlignment="Right"
                    Background="{StaticResource FooterBackgroundColor}"
                    Content="Plot Account By"
                    CornerRadius="15"
                    Foreground="White"
                    Tapped="PlotAccountByButton_Tapped">
                    <FlyoutBase.AttachedFlyout>
                        <Flyout
                            x:Name="PlotAccountByFlyout"
                            FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                            LightDismissOverlayMode="Off"
                            Placement="Bottom">
                            <StackPanel
                                Padding="0"
                                Background="Transparent"
                                Orientation="Vertical">
                                <Path
                                    Margin="80,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Data="M 0.5 5 L 5.5 0 L 10.5 5"
                                    Fill="White"
                                    Stroke="White"
                                    StrokeThickness="1" />
                                <Grid
                                    Height="210"
                                    MinWidth="220"
                                    Background="White"
                                    BorderBrush="Black"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <ListView
                                        Grid.Row="0"
                                        Margin="3,5,0,5"
                                        ItemsSource="{x:Bind ViewModel.PlotByFilterSource, Mode=OneWay}"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Background="Transparent" Tapped="PlotAccountByFlyoutGrid_Tapped">

                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="25" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        MinWidth="180"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        FontSize="14"
                                                        Foreground="{StaticResource LoginScreenTextFontColor}"
                                                        Text="{Binding Title}"
                                                        TextWrapping="Wrap" />
                                                    <FontIcon
                                                        Grid.Column="1"
                                                        Margin="3"
                                                        HorizontalAlignment="Right"
                                                        Foreground="Teal"
                                                        Glyph="{StaticResource CheckMark}"
                                                        Style="{StaticResource FontIconStyle}"
                                                        Visibility="{Binding IsSelected, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                </Grid>
                            </StackPanel>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>

                </Button>
                <!--#endregion-->
            </StackPanel>
            <!--#endregion-->
        </Grid>
        <!--#endregion-->

        <!--#region Map Section-->
        <!--  ZoomLevelChanged="myMap_ZoomLevelChanged"  -->
        <map:MapControl
            x:Name="myMap"
            Grid.Row="2"
            BusinessLandmarksVisible="False"
            ZoomLevel="14"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            CacheMode="BitmapCache"
            LandmarksVisible="True"
            MapElementClick="myMap_MapElementClick"
            MapServiceToken="{StaticResource MapServiceKey}"
            TransitFeaturesVisible="False"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InvertBoolToVisibilityConverter}}"
            />

        <Grid
            x:Name="CustomPinVisibiltyGrid"
            Grid.Row="2"
            Grid.RowSpan="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            x:Load="{x:Bind InvertBool(ViewModel.IsLoading), Mode=OneWay}"
            Visibility="{x:Bind ViewModel.CustomMapPinVisibility, Mode=TwoWay}">
            <Grid Background="Black" Opacity="0.7" />
            <customControls:MapPinCustomPopUp x:Name="customMapPinPopup" CloseCommad="{x:Bind ViewModel.CloseCustomMapPushPinCommand, Mode=OneWay}" />
        </Grid>

        <!--#endregion-->

        <!--#region Bottom Legend Filter Section-->
        <Grid
            x:Name="BottomLegendGrid"
            Grid.Row="3"
            x:Load="{x:Bind NotNull(ViewModel.LegendsLabelText), Mode=OneWay}"
            Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <TextBlock                
                Margin="20,0,20,0"
                VerticalAlignment="Center"
                Style="{StaticResource LabelStyle}"
                Text="{x:Bind ViewModel.LegendsLabelText, Mode=OneWay}" />
                <!--Style="{StaticResource CheckBoxStyle1}"-->
                <CheckBox x:Name="OptionsAllCheckBox" Content="Select all"  />
            </StackPanel>
            <ListView Grid.Row="1"
     VerticalAlignment="Center" Margin="0"
     Background="{StaticResource FooterTextColor}"
     ItemsSource="{x:Bind ViewModel.LegendsFilterSource, Mode=OneWay}" 
     Opacity="{x:Bind IsItemsActive(), Mode=OneWay}"
     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
     ScrollViewer.VerticalScrollBarVisibility="Auto"
     ScrollViewer.VerticalScrollMode="Auto"
     SelectionMode="None"
     ShowsScrollingPlaceholders="True">
                <ListView.Resources>
                    <ResourceDictionary Source="/Styles/ScrollBarStyle.xaml" />
                </ListView.Resources>
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" Margin="0" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel
                 Padding="0" Margin="0"
                 Background="Transparent"
                 Orientation="Horizontal"
                 Tapped="BottomLegendRelativePanel_Tapped">
                            <Grid
                     Width="20"
                     Height="20"
                     Margin="5,0,0,0"
                     Padding="0"
                     Background="{Binding BackgroundColor}"
                     CornerRadius="0">
                                <FontIcon
                         Foreground="White"
                         Glyph="{StaticResource CheckMark}"
                         Style="{StaticResource FontIconStyle}"
                         Visibility="{Binding IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                            <TextBlock
                     MinWidth="240"
                     Margin="5,0,0,0"
                     FontSize="14"
                     Foreground="{StaticResource LoginScreenTextFontColor}"
                     Text="{Binding Title}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        <!--#endregion-->

        <!--#region Loader-->
        <Grid
            x:Name="ProgressRingGrid"
            Grid.Row="1"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>

        <!--#endregion-->
    </Grid>
</Page>