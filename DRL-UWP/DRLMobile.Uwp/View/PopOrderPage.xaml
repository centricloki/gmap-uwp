<Page
    x:Class="DRLMobile.Uwp.View.PopOrderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:Editors="using:DevExpress.UI.Xaml.Editors"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DRLMobile.Uwp.View"
    xmlns:localConverter="using:DRLMobile.Uwp.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wctprimitives="using:Microsoft.Toolkit.Uwp.UI.Controls.Primitives"
    Background="{StaticResource LoginBackgroundColor}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">
    <Page.Resources>
        <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource CartTextColor}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>

        <Flyout
            x:Key="CustomGridKeyPadFlyout"
            x:Name="QuantityGridCustomKeyPadFlyout"
            Closing="QuantityCustomKeyPadFlyout_Closing"
            FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
            LightDismissOverlayMode="Off"
            Placement="Left">
            <customControls:CustomKeypad
                DoneClickEvent="CustomKeypad_DoneClickEvent1"
                IsDotButtonVisible="Collapsed"
                IsMinusButtonVisible="Visible"
                NumPadButtonClick="{x:Bind PopOrderViewModel.NumPadGridButtonClickCommand, Mode=OneWay}" />
        </Flyout>
        <Style x:Key="ColumnHeaderStyle" TargetType="wctprimitives:DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
        </Style>
        <localConverter:BoolToCartImageUriConverter x:Key="cartImageUriCovnerter" />
        <localConverter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <localConverter:VisibilityToBoolConverter x:Key="VisibilityToBoolConverter" />
    </Page.Resources>
    <Grid x:Name="outerPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Canvas x:Name="PrintCanvas" Opacity="0" />

        <customControls:HeaderControl
            Title="NEW POP ORDER"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            BadgeText="{x:Bind PopOrderViewModel.BadgeText, Mode=OneWay}"
            CartButtonClick="{x:Bind PopOrderViewModel.CartButtonCommand, Mode=OneWay}"
            CustomerAddressText="{x:Bind PopOrderViewModel.CustomerAddresss, Mode=OneWay}"
            CustomerNameText="{x:Bind PopOrderViewModel.CustomerNameNumber, Mode=OneWay}"
            CustomerSubAddressText="{x:Bind PopOrderViewModel.CustomerCityState, Mode=OneWay}"
            IsBadgeVisible="{x:Bind PopOrderViewModel.IsBadgeVisible, Mode=OneWay}"
            IsCartButtonVisible="Visible"
            IsCustomerPanelVisible="{x:Bind PopOrderViewModel.CustomerTitlePanelVisibility, Mode=OneWay}"
            IsPageTitleVisible="Visible" />
        <Grid
            x:Name="ComboxFilterGrid"
            Grid.Row="1"
            Padding="10,30,10,20"
            Background="{StaticResource LoginBackgroundColor}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                Orientation="Horizontal">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Category" />
                <ComboBox
                    Name="CategoryComboBox"
                    Width="250"
                    Margin="20,-8,0,0"
                    Background="Transparent"
                    DisplayMemberPath="BrandName"
                    ItemsSource="{x:Bind PopOrderViewModel.PopOrderPageModel.CategoryList, Mode=OneWay}"
                    PlaceholderText="Select"
                    SelectedItem="{x:Bind PopOrderViewModel.PopOrderPageModel.SelectedCategory, Mode=OneWay}"
                    SelectionChanged="CategoryComboBox_SelectionChanged" />
            </StackPanel>
            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Material" />
                <ComboBox
                    Name="MaterialComboBox"
                    Width="250"
                    Margin="20,-8,0,0"
                    Background="Transparent"
                    DisplayMemberPath="BrandName"
                    ItemsSource="{x:Bind PopOrderViewModel.PopOrderPageModel.MaterialList, Mode=OneWay}"
                    PlaceholderText="Select"
                    SelectedItem="{x:Bind PopOrderViewModel.PopOrderPageModel.SelectedMaterial, Mode=OneWay}"
                    SelectionChanged="MaterialComboBox_SelectionChanged" />
            </StackPanel>
            <StackPanel
                Grid.Row="0"
                Grid.Column="2"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Family" />
                <ComboBox
                    Name="FamilyComboBox"
                    Width="250"
                    Margin="20,-8,0,0"
                    Background="Transparent"
                    DisplayMemberPath="BrandName"
                    ItemsSource="{x:Bind PopOrderViewModel.PopOrderPageModel.FamilyList, Mode=OneWay}"
                    PlaceholderText="Select"
                    SelectedItem="{x:Bind PopOrderViewModel.PopOrderPageModel.SelectedFamily, Mode=OneWay}"
                    SelectionChanged="FamilyComboBox_SelectionChanged" />
            </StackPanel>
            <StackPanel
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,20,0,0"
                Orientation="Horizontal">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Brand" />
                <ComboBox
                    Name="BrandComboBox"
                    Width="250"
                    Margin="40,-8,0,0"
                    Background="Transparent"
                    DisplayMemberPath="BrandName"
                    ItemsSource="{x:Bind PopOrderViewModel.PopOrderPageModel.BrandList, Mode=OneWay}"
                    PlaceholderText="Select"
                    SelectedItem="{x:Bind PopOrderViewModel.PopOrderPageModel.SelectedBrand, Mode=OneWay}"
                    SelectionChanged="BrandComboBox_SelectionChanged" />
            </StackPanel>
            <StackPanel
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Group" />
                <ComboBox
                    Name="GroupComboBox"
                    Width="250"
                    Margin="32,-8,0,0"
                    Background="Transparent"
                    DisplayMemberPath="BrandName"
                    ItemsSource="{x:Bind PopOrderViewModel.PopOrderPageModel.GroupList, Mode=OneWay}"
                    PlaceholderText="Select"
                    SelectedItem="{x:Bind PopOrderViewModel.PopOrderPageModel.SelectedGroup, Mode=OneWay}"
                    SelectionChanged="GroupComboBox_SelectionChanged" />
            </StackPanel>
        </Grid>
        <!--  Pop Items List  -->
        <DE:GridControl
            x:Name="PopItemGrid"
            Grid.Row="2"
            Margin="10"
            x:Load="{x:Bind PopOrderViewModel.LoadingVisibility, Mode=OneWay, Converter={StaticResource VisibilityToBoolConverter}, ConverterParameter=false}"
            AlternationCount="2"
            AutoGenerateColumns="False"
            FontSize="{StaticResource DataGridTextSize}"
            ItemsSource="{x:Bind PopOrderViewModel.PopOrderListGridDataSource, Mode=OneWay}"
            KeepFocusedRowOnUpdate="False"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ShowAutoFilterRow="True"
            ShowCriteriaInAutoFilterRow="False"
            ShowGroupPanel="False"
            ShowGroupedColumns="False">

            <DE:GridControl.Columns>
                <DE:GridTemplateColumn
                    x:Name="headerItemImage"
                    Width="80"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="ProductImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Image" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image x:Name="popItemImage" Tapped="ProductImage_Tapped">
                                <Image.Source>
                                    <BitmapImage
                                        DecodePixelHeight="700"
                                        DecodePixelWidth="800"
                                        UriSource="{Binding ProductImagePath, Mode=TwoWay}" />
                                </Image.Source>
                            </Image>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTextColumn
                    Width="80"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="ProductName"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    Width="150"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="Description"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTemplateColumn
                    x:Name="quantity"
                    MinWidth="60"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="QuantityDisplay">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Quantity" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!--<TextBox
                                x:Name="quantityTextBlock"
                                Width="60"
                                HorizontalAlignment="Left"
                                BeforeTextChanging="quantityTextBlock_BeforeTextChanging"
                                FlyoutBase.AttachedFlyout="{StaticResource CustomGridKeyPadFlyout}"
                                Foreground="{StaticResource LoginScreenTextFontColor}"
                                GotFocus="quantityTextBlock_GotFocus"
                                MaxLength="4"
                                PointerExited="QuantityTextBlock_PointerExited"
                                Text="{Binding QuantityDisplay, Mode=TwoWay}" />-->
                            <Editors:TextEdit
                                x:Name="QuantityEditText"
                                Width="60"
                                FlyoutBase.AttachedFlyout="{StaticResource CustomGridKeyPadFlyout}"
                                Foreground="{StaticResource LoginScreenTextFontColor}"
                                GotFocus="QuantityEditText_GotFocus"
                                PointerExited="QuantityEditText_PointerExited"
                                Text="{Binding QuantityDisplay, Mode=TwoWay}">
                                <Editors:TextEdit.TextInputSettings>
                                    <Editors:TextInputMaskSettings
                                        IgnoreBlank="True"
                                        Mask="[0-9]?[0-9]?[0-9]?[0-9]?"
                                        MaskType="RegEx"
                                        SaveLiteral="True" />
                                </Editors:TextEdit.TextInputSettings>
                            </Editors:TextEdit>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTemplateColumn
                    x:Name="cart"
                    Width="50"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="CartImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Add to Cart" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image x:Name="cartImage" Tapped="Grid_Tapped">
                                <Image.Source>
                                    <BitmapImage
                                        DecodePixelHeight="100"
                                        DecodePixelWidth="100"
                                        UriSource="{Binding IsAddedToCart, Mode=TwoWay, Converter={StaticResource cartImageUriCovnerter}}" />
                                </Image.Source>
                            </Image>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>
            </DE:GridControl.Columns>
        </DE:GridControl>

        <Grid
            x:Name="ProgressRingGrid"
            Grid.Row="1"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            x:Load="{x:Bind PopOrderViewModel.LoadingVisibility, Mode=OneWay, Converter={StaticResource VisibilityToBoolConverter}}"
            Background="Black"
            Opacity="0.7">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>


        <Grid
            Name="PreviewControl"
            Grid.Row="0"
            Grid.RowSpan="3"
            d:Visibility="Collapsed"
            x:Load="{x:Bind PopOrderViewModel.IsPreviewDocumentVisibile, Mode=OneWay}"
            Visibility="{x:Bind PopOrderViewModel.IsPreviewDocumentVisibile, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Background="Black" Opacity="0.4" />
            <customControls:PreviewDocumentControl
                CloseCommad="{x:Bind PopOrderViewModel.ClosePreviewCommand}"
                FilePath="{x:Bind PopOrderViewModel.PreviewUrl, Mode=TwoWay}"
                IsPrintEmailIconVisible="True"
                PrintPictureCommand="{x:Bind PopOrderViewModel.PrintPOPImageCommand}" />
        </Grid>

    </Grid>
</Page>
