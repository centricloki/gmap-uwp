<Page
    x:Class="DRLMobile.Views.OrderHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:converter="using:DRLMobile.Converters"
    xmlns:customControl="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Microsoft.Toolkit.Uwp.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>

            <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

            <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="Black" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid
        Background="{StaticResource PageBackgroundColor}"
        ColumnSpacing="0"
        RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <customControl:HeaderControl
            Title="{x:Bind ViewModel.TitleText, Mode=OneWay}"
            AutoSuggestionText="{x:Bind ViewModel.AutoSuggestionText, Mode=TwoWay}"
            DisplayMemberPathValue="SearchDisplayPath"
            IsAutoSuggestBoxVisible="Visible"
            IsPageTitleVisible="Visible"
            IsSecondaryTitleVisible="Visible"
            ItemList="{x:Bind ViewModel.HeaderSearchItemSource, Mode=TwoWay}"
            PlaceHolderText="Search"
            SecondaryTitleText="{x:Bind ViewModel.SelectedCustomer.CustomerName, Mode=OneWay}"
            SuggestionChoosenCommand="{x:Bind ViewModel.HeaderSearchSuggestionChoosenCommand}"
            TextValueChangedCommand="{x:Bind ViewModel.HeaderSearchTextChangeCommand}" />


        <customControl:SegmentControl
            Grid.Row="1"
            Margin="0,5,0,5"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            LeftSegmentCommand="{x:Bind ViewModel.LeftSegmentCommand}"
            LeftSegmentText="Order"
            RightSegmentCommand="{x:Bind ViewModel.RightSegmentCommand}"
            RightSegmentText="Item"
            SelectedSegment="{x:Bind ViewModel.SelectedSegment, Mode=TwoWay}" />


        <Grid Grid.Row="2" Background="White">
            <DE:GridControl
                AlternationCount="2"
                AutoGenerateColumns="False"
                AutoScrollOnSorting="False"
                Background="White"
                ItemClickCommand="{x:Bind ViewModel.ItemClickCommand}"
                ItemsSource="{x:Bind ViewModel.OrderHistoryItemSource, Mode=OneWay}"
                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                ShowAutoFilterRow="True"
                ShowCriteriaInAutoFilterRow="True"
                ShowGroupPanel="False"
                ShowGroupedColumns="False"
                Visibility="{x:Bind ViewModel.IsOrderHistoryVisibile, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <DE:GridControl.Columns>


                    <DE:GridTextColumn
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="Invoice"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Invoice #" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>


                    <DE:GridTextColumn
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="OrderType"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Order Type" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>


                    <DE:GridTextColumn
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="DistributorName"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Distributor Name" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>


                    <DE:GridTextColumn
                        HorizontalContentAlignment="Center"
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="TotalQuantity"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Total Quantity" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>


                    <DE:GridTextColumn
                        HorizontalContentAlignment="Center"
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="TotalAmount"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Total Amount" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>

                    <DE:GridTextColumn
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="OrderPlacedOn"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Order Placed On" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>


                    <DE:GridTextColumn
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="ShippingCompany"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Shipping Company" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>


                    <DE:GridTextColumn
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="TrackingNumber"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Tracking Number" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>



                    <DE:GridTextColumn
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="TrackingUrl"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Tracking URL" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>


                    <DE:GridTemplateColumn
                        x:Name="cart"
                        AllowAutoFilter="False"
                        AllowColumnFiltering="False"
                        AllowSorting="True">
                        <DE:GridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Reorder" />
                            </DataTemplate>
                        </DE:GridTemplateColumn.HeaderTemplate>

                        <DE:GridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Tapped="ReorderTapped">
                                    <Image
                                        Width="27"
                                        Height="27"
                                        Source="{StaticResource CartUnselected}" />
                                </Grid>
                            </DataTemplate>
                        </DE:GridTemplateColumn.CellTemplate>

                    </DE:GridTemplateColumn>

                </DE:GridControl.Columns>

            </DE:GridControl>

            <DE:GridControl
                AlternationCount="2"
                AutoGenerateColumns="False"
                AutoScrollOnSorting="False"
                Background="White"
                ItemsSource="{x:Bind ViewModel.ItemHistoryItemSource, Mode=OneWay}"
                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                ShowAutoFilterRow="True"
                ShowCriteriaInAutoFilterRow="True"
                ShowGroupPanel="False"
                ShowGroupedColumns="False"
                Visibility="{x:Bind ViewModel.IsItemHistoryVisibile, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <DE:GridControl.Columns>
                    <DE:GridTextColumn
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="Invoice"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Invoice #" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>

                    <DE:GridTextColumn
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="ProductName"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item #" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>

                    <DE:GridTextColumn
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="ProductDescription"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>

                    <DE:GridTextColumn
                        HorizontalContentAlignment="Center"
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="Price"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Price" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>

                    <DE:GridTextColumn
                        HorizontalContentAlignment="Center"
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="UOM"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="UOM" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>

                    <DE:GridTextColumn
                        AllowSorting="True"
                        AutoFilterCriteria="Contains"
                        FieldName="OrderDate"
                        TextWrapping="Wrap">
                        <DE:GridTextColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Order Date" />
                            </DataTemplate>
                        </DE:GridTextColumn.HeaderTemplate>
                    </DE:GridTextColumn>

                </DE:GridControl.Columns>
            </DE:GridControl>

            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource LargeFontSize}"
                Foreground="Black"
                Text="No History"
                Visibility="{x:Bind ViewModel.IsNoHistoryPlaceHolderVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>

        <toolkit:Loading
            Grid.Row="0"
            Grid.RowSpan="3"
            IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
            <controls:Loading.Background>
                <SolidColorBrush Opacity="0.4" Color="Black" />
            </controls:Loading.Background>

            <ProgressRing
                Width="100"
                Height="100"
                Foreground="White"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </toolkit:Loading>

    </Grid>
</Page>
