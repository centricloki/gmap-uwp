<UserControl
    x:Class="DRLMobile.CustomControls.SegmentControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid
        Height="50"
        Background="{StaticResource LoginButtonBackground}"
        CornerRadius="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />

        </Grid.ColumnDefinitions>

        <Grid
            x:Name="LeftSegmentGrid"
            Grid.Column="0"
            MinWidth="170"
            Margin="2"
            Background="{StaticResource LoginButtonBackground}"
            CornerRadius="5"
            Tapped="LeftSegmentTapped">
            <TextBlock
                x:Name="LeftSegmentTextBlock"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource MediumFontSize}"
                FontWeight="SemiBold"
                Foreground="Black"
                Text="{x:Bind LeftSegmentText, Mode=TwoWay}"
                TextWrapping="Wrap" />
        </Grid>
        <Grid
            x:Name="CenterSegmentGrid"
            Grid.Column="1"
            MinWidth="170"
            Margin="1"
            Background="{StaticResource LoginButtonBackground}"
            CornerRadius="5"
            Tapped="CenterSegmentGrid_Tapped"
            Visibility="{x:Bind IsCenterSegmentTextVisible, Mode=TwoWay}">
            <TextBlock
                x:Name="CenterSegmentTextBlock"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource MediumFontSize}"
                FontWeight="SemiBold"
                Foreground="Black"
                Text="{x:Bind CenterSegmentText, Mode=TwoWay}"
                TextWrapping="Wrap" />
        </Grid>
        <Grid
            x:Name="RightSegmentGrid"
            Grid.Column="2"
            MinWidth="170"
            Margin="2"
            Background="{StaticResource LoginButtonBackground}"
            CornerRadius="5"
            Tapped="RightSegmentTapped">
            <TextBlock
                x:Name="RightSegmentTextBlock"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource MediumFontSize}"
                FontWeight="SemiBold"
                Foreground="Black"
                Text="{x:Bind RightSegmentText, Mode=TwoWay}"
                TextWrapping="Wrap" />
        </Grid>

    </Grid>

</UserControl>
