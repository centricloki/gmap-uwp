<Page
    x:Class="DRLMobile.Views.FavoritePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:converter="using:DRLMobile.Converters"
    xmlns:core="using:Microsoft.Xaml.Interactions.Core"
    xmlns:customControls="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Microsoft.Toolkit.Uwp.UI.Controls"
    x:Name="favoritePage"
    Background="{StaticResource LoginButtonBackground}"
    mc:Ignorable="d">
    <Page.Resources>
        <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <SolidColorBrush x:Key="SystemColors.HighlightBrushKey" Color="Transparent" />
        <SolidColorBrush x:Key="SystemColors.ControlBrushKey" Color="Transparent" />
        <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
        <Style x:Key="TextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
    </Page.Resources>
    <Grid x:Name="gridpanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />

        </Grid.RowDefinitions>
        <customControls:HeaderControl
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            BadgeText="{x:Bind FavoritePageViewModel.BadgeText, Mode=OneWay}"
            CartButtonClick="{x:Bind FavoritePageViewModel.CartButtonCommand, Mode=OneWay}"
            CustomerTitleNameText="{x:Bind FavoritePageViewModel.CustomerName, Mode=OneWay}"
            CustomerTitleNumberText="{x:Bind FavoritePageViewModel.CustomerNumber, Mode=OneWay}"
            CustomerTitlePanelClick="{x:Bind FavoritePageViewModel.CustomerTitlePanelClickCommand, Mode=OneWay}"
            DisplayMemberPathValue="SearchDisplayPath"
            IsAutoSuggestBoxVisible="Visible"
            IsBadgeVisible="{x:Bind FavoritePageViewModel.IsBadgeVisible, Mode=OneWay}"
            IsCartButtonVisible="Visible"
            IsCustomerPanelVisible="Collapsed"
            IsCustomerTitlePanelVisible="{x:Bind FavoritePageViewModel.CustomerTitlePanelVisibility, Mode=OneWay}"
            IsPageTitleVisible="Collapsed"
            ItemList="{x:Bind FavoritePageViewModel.HeaderSearchItemSource, Mode=TwoWay}"
            PlaceHolderText="Search by Name or Number"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SuggestionChoosenCommand="{x:Bind FavoritePageViewModel.HeaderSearchSuggestionChoosenCommand}"
            TextValueChangedCommand="{x:Bind FavoritePageViewModel.HeaderSearchTextChangeCommand}" />

        <DE:GridControl
            x:Name="DataGridcontrol"
            Grid.Row="1"
            AlternationCount="2"
            AutoGenerateColumns="False"
            FontSize="{StaticResource DataGridTextSize}"
            ItemClickCommand="{x:Bind FavoritePageViewModel.ItemClickCommand}"
            ItemsSource="{x:Bind FavoritePageViewModel.FavoriteGridDataSource, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ShowAutoFilterRow="False"
            ShowCriteriaInAutoFilterRow="True"
            ShowGroupPanel="False"
            ShowGroupedColumns="False"
            Visibility="{x:Bind FavoritePageViewModel.ProductListVisibility, Mode=OneWay}">
            <DE:GridControl.Columns>
                <DE:GridTemplateColumn
                    x:Name="isAllUpperGridSelected"
                    Width="60"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="IsAllUpperGridSelected">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <CheckBox
                                x:Name="HeaderCheckBox"
                                Width="10"
                                Height="10"
                                Checked="headerCheckbox_Checked"
                                Unchecked="headerCheckbox_Unchecked" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox
                                Checked="GridRowCheckBoxCheckedChanged"
                                IsChecked="{Binding IsAllRowsSelected, Mode=TwoWay}"
                                Unchecked="GridRowCheckBoxCheckedChanged" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="BrandName"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Brand" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="StyleName"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Style" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="ItemNumber"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    Width="270"
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="ItemDescription"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTemplateColumn
                    x:Name="unfavorite"
                    Width="70"
                    AllowColumnFiltering="False"
                    FieldName="UnfavoriteImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unfavorite" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid x:Name="UnfavoriteGrid" Tapped="UnfavoriteGrid_Tapped">
                                <Image
                                    x:Name="unfavoriteImage"
                                    Width="27"
                                    Height="27"
                                    Source="{StaticResource FavoriteSelected}" />
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>
            </DE:GridControl.Columns>
        </DE:GridControl>

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Visibility="{x:Bind FavoritePageViewModel.NoProductVisibility, Mode=OneWay}">
            <TextBlock
                x:Name="NoProduct"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource MediumFontSize}"
                FontWeight="SemiBold"
                Foreground="{StaticResource LoginScreenTextFontColor}"
                Text="No Product Found" />
        </StackPanel>

        <Grid
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{Binding LoadingVisibility}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>

        <StackPanel
            Grid.Row="2"
            Margin="0,10,0,20"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Orientation="Horizontal"
            Visibility="{x:Bind FavoritePageViewModel.BottomButtonStackVisiblity, Mode=OneWay}">
            <Button
                x:Name="EmailFactsheetButton"
                Command="{x:Bind FavoritePageViewModel.EmailFactsheetButtonCommand}"
                Content="Email Factsheet"
                Foreground="{StaticResource CartTextColor}"
                Style="{StaticResource CustomerDetailPageButton}" />

            <Button
                x:Name="AddToCartButton"
                Margin="{StaticResource SmallLeftMargin}"
                Command="{x:Bind FavoritePageViewModel.AddToCartButtonCommand}"
                Content="Add to Cart"
                Foreground="{StaticResource CartTextColor}"
                RelativePanel.RightOf="EmailFactsheetButton"
                Style="{StaticResource CustomerDetailPageButton}" />
        </StackPanel>

        <Grid
            x:Name="DetailsScreen"
            Grid.Row="0"
            Grid.RowSpan="3"
            d:Visibility="Visible"
            Visibility="{x:Bind FavoritePageViewModel.IsProductDetailsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Background="Black" Opacity="0.3" />

            <Grid
                Margin="20,100,20,100"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid
                    Grid.Row="0"
                    Grid.Column="3"
                    HorizontalAlignment="Right"
                    Background="Transparent">
                    <i:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="Tapped">
                            <core:InvokeCommandAction Command="{x:Bind FavoritePageViewModel.ShowHideDetailCommand}" />
                        </core:EventTriggerBehavior>
                    </i:Interaction.Behaviors>
                    <Image
                        Width="20"
                        Height="20"
                        Margin="10"
                        Source="{StaticResource ListIcon}" />
                </Grid>


                <Grid
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="Transparent">
                    <FontIcon
                        FontSize="50"
                        Foreground="{x:Bind FavoritePageViewModel.LeftArrowColor, Mode=TwoWay}"
                        Glyph="{StaticResource LeftArrowIcon}"
                        Style="{StaticResource FontIconStyle}" />

                    <i:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="Tapped">
                            <core:InvokeCommandAction Command="{x:Bind FavoritePageViewModel.PrevoiusNextCommand}" CommandParameter="PRE" />
                        </core:EventTriggerBehavior>
                    </i:Interaction.Behaviors>


                </Grid>


                <Grid
                    Grid.Row="1"
                    Grid.Column="1"
                    Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Image
                        Grid.Column="0"
                        Height="auto"
                        Margin="0"
                        Stretch="Uniform">
                        <Image.Source>
                            <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{x:Bind FavoritePageViewModel.DetailUIModel.ProductImagePath, Mode=TwoWay}" />
                        </Image.Source>
                    </Image>

                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="40">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            d:Text="Item number"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Foreground="Black"
                            Text="{x:Bind FavoritePageViewModel.DetailUIModel.SelectedFavorite.ItemNumber, Mode=OneWay}" />

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            d:Text="Super matic machine"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LoginScreenTextFontColor}"
                            Text="{x:Bind FavoritePageViewModel.DetailUIModel.SelectedFavorite.ItemDescription, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                </Grid>

                <Grid
                    Grid.Row="1"
                    Grid.Column="3"
                    Margin="10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="Transparent">
                    <FontIcon
                        FontSize="50"
                        Foreground="{x:Bind FavoritePageViewModel.RightArrowColor, Mode=TwoWay}"
                        Glyph="{StaticResource RightArrowIcon}"
                        Style="{StaticResource FontIconStyle}" />

                    <i:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="Tapped">
                            <core:InvokeCommandAction Command="{x:Bind FavoritePageViewModel.PrevoiusNextCommand}" CommandParameter="NEXT" />
                        </core:EventTriggerBehavior>
                    </i:Interaction.Behaviors>
                </Grid>


                <StackPanel
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="4"
                    Margin="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Command="{x:Bind FavoritePageViewModel.DetailsActionCommand}"
                        CommandParameter="FACTSHEET">
                        <Grid>
                            <StackPanel Spacing="5">
                                <Image
                                    x:Name="RetailImage"
                                    Width="50"
                                    Height="50"
                                    Source="{StaticResource FactsheetNormal}" />
                                <TextBlock Style="{StaticResource TextStyle}" Text="Factsheet" />
                            </StackPanel>
                        </Grid>
                    </Button>


                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Command="{x:Bind FavoritePageViewModel.DetailsActionCommand}"
                        CommandParameter="RETAIL_IMAGE">
                        <Grid>
                            <StackPanel Spacing="5">
                                <Image
                                    Width="50"
                                    Height="50"
                                    Source="{StaticResource RetailImageNormal}" />
                                <TextBlock Style="{StaticResource TextStyle}" Text="Retail Image" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Command="{x:Bind FavoritePageViewModel.DetailsActionCommand}"
                        CommandParameter="IP_IMAGE">
                        <Grid>
                            <StackPanel Spacing="5">
                                <Image
                                    Width="50"
                                    Height="50"
                                    Source="{StaticResource RetailImageNormal}" />
                                <TextBlock Style="{StaticResource TextStyle}" Text="I/P Image" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Command="{x:Bind FavoritePageViewModel.DetailsActionCommand}"
                        CommandParameter="PRODUCT">
                        <Grid>
                            <StackPanel Spacing="5">
                                <Image
                                    Width="50"
                                    Height="50"
                                    Source="{StaticResource RetailImageNormal}" />
                                <TextBlock Style="{StaticResource TextStyle}" Text="Product" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Command="{x:Bind FavoritePageViewModel.MailProductDetailsCommand}">
                        <Grid>
                            <StackPanel Spacing="5">
                                <Image
                                    Width="50"
                                    Height="50"
                                    Source="{StaticResource MailNormal}" />
                                <TextBlock Style="{StaticResource TextStyle}" Text="Mail" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button
                        Grid.Row="0"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Command="{x:Bind FavoritePageViewModel.DetailsCartCommand}">
                        <Grid>
                            <StackPanel Spacing="5">
                                <Image Width="50" Height="50">
                                    <Image.Source>
                                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding DetailUIModel.CartImagePath}" />
                                    </Image.Source>
                                </Image>
                                <TextBlock Style="{StaticResource TextStyle}" Text="Cart" />
                            </StackPanel>
                        </Grid>
                    </Button>
                </StackPanel>




            </Grid>




        </Grid>

        <customControls:PreviewDocumentControl
            Grid.Row="0"
            Grid.RowSpan="3"
            CloseCommad="{x:Bind FavoritePageViewModel.ClosePreviewCommand}"
            FilePath="{x:Bind FavoritePageViewModel.PreviewFilePath, Mode=TwoWay}"
            Visibility="{x:Bind FavoritePageViewModel.IsPreviewDocumentControlVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />


        <toolkit:Loading
            Grid.Row="0"
            Grid.RowSpan="3"
            IsLoading="{x:Bind FavoritePageViewModel.IsLoading, Mode=OneWay}">
            <controls:Loading.Background>
                <SolidColorBrush Opacity="0.4" Color="Black" />
            </controls:Loading.Background>
            <StackPanel
                Padding="12"
                Orientation="Vertical"
                Spacing="10">
                <ProgressBar
                    Width="{Binding ElementName=PageName, Path=ActualWidth}"
                    Foreground="White"
                    IsIndeterminate="True" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="{StaticResource LargeFontSize}"
                    Foreground="White"
                    Text="Please Wait" />
            </StackPanel>

        </toolkit:Loading>


    </Grid>
</Page>
