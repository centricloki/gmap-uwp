<Page
    x:Class="DRLMobile.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Page.Resources />
    <Grid x:Name="outerPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <customControls:HeaderControl
            Title="DASHBOARD"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            ButtonClick="{x:Bind ViewModel.LogoutButtonCommand}"
            IsLogOutButtonVisible="Visible"
            IsPageTitleVisible="Visible" />

        <Grid
            Grid.Row="1"
            Margin="0,30,0,30"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            ColumnSpacing="80"
            RowSpacing="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <customControls:DashboardButton
                x:Uid="Dashboard_Src_Product"
                Grid.Row="0"
                Grid.Column="0"
                ButtonClick="{x:Bind ViewModel.SRCButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource SrcHover}"
                NormalStateImageSource="{StaticResource SrcNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Cart"
                Grid.Row="0"
                Grid.Column="1"
                BadgeText="{x:Bind ViewModel.BadgeText}"
                ButtonClick="{x:Bind ViewModel.CartButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource CartHover}"
                IsBadgeVisible="Visible"
                NormalStateImageSource="{StaticResource CartNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Customer"
                Grid.Row="0"
                Grid.Column="2"
                ButtonClick="{x:Bind ViewModel.CustomerButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource CustomerHover}"
                NormalStateImageSource="{StaticResource CustomerNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Favorite"
                Grid.Row="1"
                Grid.Column="0"
                ButtonClick="{x:Bind ViewModel.FavoriteButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource FavoriteHover}"
                NormalStateImageSource="{StaticResource FavoriteNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Route_List"
                Grid.Row="1"
                Grid.Column="1"
                ButtonClick="{x:Bind ViewModel.RouteListButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource RoutListHover}"
                NormalStateImageSource="{StaticResource RouteListNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Settings"
                Grid.Row="1"
                Grid.Column="2"
                ButtonClick="{x:Bind ViewModel.SettingsButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource SettingHover}"
                NormalStateImageSource="{StaticResource SettingNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Activities"
                Grid.Row="2"
                Grid.Column="0"
                ButtonClick="{x:Bind ViewModel.ActivitiesButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource ActivitiesHover}"
                NormalStateImageSource="{StaticResource ActivitiesNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Map"
                Grid.Row="2"
                Grid.Column="1"
                ButtonClick="{x:Bind ViewModel.MapButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource MapHover}"
                NormalStateImageSource="{StaticResource MapNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Sync"
                Grid.Row="2"
                Grid.Column="2"
                ButtonClick="{x:Bind ViewModel.SyncButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource SyncHover}"
                NormalStateImageSource="{StaticResource SyncNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Rack_Order"
                Grid.Row="3"
                Grid.Column="0"
                ButtonClick="{x:Bind ViewModel.RackOrderButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource RackOrderHover}"
                NormalStateImageSource="{StaticResource RackOrderNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Pop_Order"
                Grid.Row="3"
                Grid.Column="1"
                ButtonClick="{x:Bind ViewModel.PopOrderButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource PopOrderHover}"
                NormalStateImageSource="{StaticResource PopOrderNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Travel_Vrip"
                Grid.Row="3"
                Grid.Column="2"
                ButtonClick="{x:Bind ViewModel.TravelVripButtonCommand, Mode=OneWay}"
                HoverStateImageSource="{StaticResource TravelHover}"
                NormalStateImageSource="{StaticResource TravelNormal}" />

        </Grid>

        <Grid
            Grid.Row="0"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Visibility="{Binding LoadingVisibility}">

            <Grid Background="Black" Opacity="0.3" />
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>

    </Grid>
</Page>
