<Page
    x:Class="DRLMobile.Uwp.View.AddEditRoutePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:converter="using:DRLMobile.Uwp.Converters"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DRLMobile.Uwp.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Microsoft.Toolkit.Uwp.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Page.Resources>

        <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
        <Style x:Key="RouteHeaderTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Margin" Value="20,0,0,0" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundColor}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <customControls:HeaderControl
            Title="{x:Bind ViewModel.HeaderTitle, Mode=OneWay}"
            Grid.Row="0"
            ButtonClick="{x:Bind ViewModel.SaveButtomCommand}"
            CustomIconButtonVisibility="Visible"
            DisplayMemberPathValue="SearchDisplayPath"
            HoverImageSource="{StaticResource SaveIconHover}"
            IsAutoSuggestBoxVisible="Visible"
            IsPageTitleVisible="Visible"
            ItemList="{x:Bind ViewModel.HeaderSearchItemSource, Mode=OneWay}"
            NormalImageSource="{StaticResource SaveIconNormal}"
            PlaceHolderText="Search By Customer Name and #"
            SuggestionChoosenCommand="{x:Bind ViewModel.HeaderSearchSuggestionChoosenCommand}"
            TextValueChangedCommand="{x:Bind ViewModel.HeaderSearchTextChangedCommand}" />

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,5"
            Orientation="Horizontal"
            Spacing="1">

            <StackPanel
                x:Name="AssignToStackPanel"
                Margin="10,0,0,0"
                Spacing="0"
                Visibility="{x:Bind ViewModel.AssignToPanelVisibility, Mode=OneWay}">
                <TextBlock
                    HorizontalAlignment="Left"
                    Style="{StaticResource RouteHeaderTitle}"
                    Text="Assign to Territory Manager" />
                <ComboBox
                    Margin="0,3,0,0"
                    FontSize="16"
                    ItemsSource="{x:Bind ViewModel.TerritoryManagersCollection, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedTerrManagerName, Mode=TwoWay}"
                    Style="{StaticResource ComboBoxWhiteBackground}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            <StackPanel Spacing="0">
                <TextBlock HorizontalAlignment="Left" Style="{StaticResource RouteHeaderTitle}">
                    <TextBlock.Inlines>
                        <Run Text="Route Name" />
                        <Run
                            d:Text="*"
                            Foreground="Red"
                            Text="*" />
                        <Run x:Uid="Colon" d:Text=":" />
                    </TextBlock.Inlines>
                </TextBlock>
                <TextBox
                    MaxWidth="200"
                    MaxHeight="33"
                    Margin="12,3,0,0"
                    MaxLength="50"
                    Style="{StaticResource EditTextBoxStyle}"
                    Text="{x:Bind ViewModel.RouteName, Mode=TwoWay}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="0">
                <TextBlock
                    HorizontalAlignment="Left"
                    Style="{StaticResource RouteHeaderTitle}"
                    Text="Route Brief" />
                <TextBox
                    MaxWidth="200"
                    MaxHeight="33"
                    Margin="12,3,0,0"
                    MaxLength="50"
                    Style="{StaticResource EditTextBoxStyle}"
                    Text="{x:Bind ViewModel.RouteBrief, Mode=TwoWay}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="0">
                <TextBlock HorizontalAlignment="Left" Style="{StaticResource RouteHeaderTitle}">
                    <TextBlock.Inlines>
                        <Run Text="Start Date" />
                        <Run
                            d:Text="*"
                            Foreground="Red"
                            Text="*" />
                        <Run x:Uid="Colon" d:Text=":" />
                    </TextBlock.Inlines>
                </TextBlock>
                <CalendarDatePicker
                    Margin="20,5,0,0"
                    Background="White"
                    Date="{x:Bind ViewModel.StartDate, Mode=TwoWay}"
                    DateFormat="{}{month.integer(2)}/{day.integer(2)}/{year.full}"
                    PlaceholderText="Select A Date" />
            </StackPanel>

            <StackPanel Spacing="0">
                <TextBlock HorizontalAlignment="Left" Style="{StaticResource RouteHeaderTitle}">
                    <TextBlock.Inlines>
                        <Run Text="End Date" />
                        <Run
                            d:Text="*"
                            Foreground="Red"
                            Text="*" />
                        <Run x:Uid="Colon" d:Text=":" />
                    </TextBlock.Inlines>
                </TextBlock>
                <CalendarDatePicker
                    Margin="20,5,0,0"
                    Background="White"
                    Date="{x:Bind ViewModel.EndDate, Mode=TwoWay}"
                    DateFormat="{}{month.integer(2)}/{day.integer(2)}/{year.full}"
                    PlaceholderText="Select A Date" />
            </StackPanel>
        </StackPanel>

        <DE:GridControl
            x:Name="DataGridcontrol"
            Grid.Row="2"
            x:Load="{x:Bind ViewModel.LoadUI, Mode=OneWay}"
            AlternationCount="2"
            AutoGenerateColumns="False"
            EndSorting="DataGridcontrol_EndSorting"
            FontSize="{StaticResource DataGridTextSize}"
            ItemsSource="{x:Bind ViewModel.CustomerList, Mode=OneWay}"
            Loaded="DataGridcontrol_Loaded"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SelectedItem="{x:Null}"
            SelectionMode="None"
            ShowAutoFilterRow="True"
            ShowCriteriaInAutoFilterRow="True"
            ShowGroupPanel="False"
            ShowGroupedColumns="False"
            ShowSearchPanelMode="Never">
            <DE:GridControl.Columns>
                <DE:GridTextColumn
                    MinWidth="300"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="CustomerName"
                    TextWrapping="NoWrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="CustomerNumber"
                    TextWrapping="NoWrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Customer#" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="StoreType"
                    TextWrapping="NoWrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    Width="80"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="Rank"
                    TextWrapping="NoWrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="Address"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="City"
                    TextWrapping="NoWrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="State"
                    TextWrapping="NoWrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock
                                Width="80"
                                Style="{StaticResource GridHeaderStyle}"
                                Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    MinWidth="140"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="ZipCode"
                    TextWrapping="NoWrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridDateColumn
                    Name="LastCallDate"
                    AllowSorting="True"
                    AutoFilterCriteria="{x:Null}"
                    FieldName="CallDate"
                    FixedWidth="False"
                    Mask="MM/dd/yyy"
                    MaskUseAsDisplayFormat="True"
                    ShowCriteriaInAutoFilterRow="False"
                    SortMode="Value"
                    TextWrapping="NoWrap">
                    <DE:GridDateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Last call date" />
                        </DataTemplate>
                    </DE:GridDateColumn.HeaderTemplate>


                </DE:GridDateColumn>

                <DE:GridTemplateColumn
                    Width="50"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSearchPanel="False"
                    AllowSorting="False"
                    Header=" "
                    ShowCriteriaInAutoFilterRow="False">

                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid
                                Width="20"
                                Height="20"
                                Margin="0,0,0,0"
                                Padding="0"
                                Background="White"
                                BorderBrush="Gray"
                                BorderThickness="0.5"
                                CornerRadius="5"
                                Tapped="CheckBoxGrid_Tapped">
                                <FontIcon
                                    FontSize="15"
                                    Foreground="Black"
                                    Glyph="{StaticResource CheckMark}"
                                    Style="{StaticResource FontIconStyle}"
                                    Visibility="{Binding IsSelected, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

            </DE:GridControl.Columns>
        </DE:GridControl>

        <toolkit:Loading
            x:Name="LoadingView"
            Grid.Row="0"
            Grid.RowSpan="3"
            x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            IsLoading="{x:Bind ViewModel.IsLoading}">
            <toolkit:Loading.Background>
                <SolidColorBrush Opacity="0.4" Color="Black" />
            </toolkit:Loading.Background>
            <ProgressRing
                x:Name="ProgressRingView"
                Width="100"
                Height="100"
                x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Foreground="White"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </toolkit:Loading>
    </Grid>
</Page>
