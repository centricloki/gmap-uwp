                                x:Name="TobaccoTextEdit"
                                Width="80"
                                CornerRadius="10"
                                FlyoutBase.AttachedFlyout="{StaticResource CustomPriceKeyPadFlyout}"
                                GotFocus="nonTobaccoTextEdit_GotFocus"
                                PointerExited="nonTobaccoTextEdit_PointerExited"
                                Text="{x:Bind ViewModel.AddEditUIModel.Price, Mode=TwoWay}">
                                <Editors:TextEdit.TextInputSettings>
                                    <Editors:TextInputMaskSettings
                                        IgnoreBlank="True"
                                        Mask="\$(\d{0,4}\.?\d{1,2})?"
                                        MaskType="RegEx"
                                        SaveLiteral="True" />
                                </Editors:TextEdit.TextInputSettings>
                            </Editors:TextEdit>
                            <Image
                                x:Name="unitPriceImage"
                                Width="15"
                                Height="15"
                                Margin="3,0,0,0"
                                Source="{StaticResource EditCart}" />
                        </StackPanel>
                    </Grid>

