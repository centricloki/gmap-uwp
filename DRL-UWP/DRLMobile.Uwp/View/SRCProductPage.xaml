            <Grid Background="Black" Opacity="0.6" />
            <customControls:PreviewDocumentControl
          CloseCommad="{x:Bind SrcProductPageViewModel.PreviewDocumentCommand}"
          FilePath="{x:Bind SrcProductPageViewModel.PreviewUrl, Mode=TwoWay}"
          IsPrintEmailIconVisible="True"
          PrintPictureCommand="{x:Bind SrcProductPageViewModel.PrintProductImageCommand}"/>
        </Grid>


        <!--  Loader  -->
        <Grid
        x:Name="ProgressRingGrid"
        Grid.RowSpan="5"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        d:Visibility="Collapsed"
        x:Load="{x:Bind SrcProductPageViewModel.LoadingVisibility, Mode=OneWay, Converter={StaticResource VisibilityToBoolConverter}}"
        Background="Black"
        Opacity="0.7">
            <ProgressRing
          Width="100"
          Height="100"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Foreground="White"
          IsActive="True" />
        </Grid>

    </Grid>
</Page>
