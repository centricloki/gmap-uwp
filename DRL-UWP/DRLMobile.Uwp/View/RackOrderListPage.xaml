<Page
    x:Class="DRLMobile.Uwp.View.RackOrderListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:converter="using:DRLMobile.Uwp.Converters"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DRLMobile.Uwp.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid x:Name="outerPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Canvas x:Name="PrintCanvas" Opacity="0"/>

        <customControls:HeaderControl
            Title="NEW RACK ORDER"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            CustomerAddressText="{x:Bind RackOrderListPageViewModel.CustomerAddresss, Mode=OneWay}"
            CustomerNameText="{x:Bind RackOrderListPageViewModel.CustomerNameNumber, Mode=OneWay}"
            CustomerSubAddressText="{x:Bind RackOrderListPageViewModel.CustomerCityState, Mode=OneWay}"
            IsCustomerPanelVisible="{x:Bind RackOrderListPageViewModel.CustomerTitlePanelVisibility, Mode=OneWay}"
            IsPageTitleVisible="Visible" />

        <!--  Rack Items List  -->
        <controls:AdaptiveGridView
            x:Name="rackItemGrid"
            Grid.Row="1"
            Margin="0,10,0,20"
            DesiredWidth="500"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind RackOrderListPageViewModel.RackOrderListGridDataSource, Mode=OneWay}">

            <GridView.ItemTemplate>
                <DataTemplate>
                    <StackPanel
                        Margin="10"
                        Padding="10" 
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource FooterTextColor}"
                        Orientation="Horizontal" 
                        Tapped="RackItemClicked">
                        <Image   Width="250" Tapped="ProductImage_Tapped">
                            <Image.Source>
                                <BitmapImage UriSource="{Binding ProductImagePath, Mode=OneWay}" />
                            </Image.Source>
                        </Image>
                        <StackPanel
                            Margin="20,20,0,0" 
                            HorizontalAlignment="Right"
                            Orientation="Vertical">
                            <TextBlock
                                Margin="0,10,0,0"  MaxWidth="150"
                                HorizontalAlignment="Left"
                                FontSize="{StaticResource MediumFontSize}"
                                FontWeight="SemiBold" TextWrapping="WrapWholeWords"
                                Foreground="{StaticResource CartTextColor}"
                                Text="{Binding BrandName}" />
                            <TextBlock
                                Margin="0,15,0,0" MaxWidth="150"
                                HorizontalAlignment="Left"
                                FontSize="{StaticResource FooterFontSize}"
                                FontWeight="SemiBold" TextWrapping="WrapWholeWords"
                                Foreground="{StaticResource LoginScreenTextFontColor}"
                                Text="{Binding Description}" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </GridView.ItemTemplate>
        </controls:AdaptiveGridView>

        <Grid
            Name="PreviewControl"
            Grid.Row="0"
            Grid.RowSpan="3"
            d:Visibility="Collapsed"
            x:Load="{x:Bind RackOrderListPageViewModel.IsPreviewDocumentVisibile, Mode=OneWay}"
            Visibility="{x:Bind RackOrderListPageViewModel.IsPreviewDocumentVisibile, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Background="Black" Opacity="0.4" />
            <customControls:PreviewDocumentControl
                CloseCommad="{x:Bind RackOrderListPageViewModel.ClosePreviewCommand}"
                FilePath="{x:Bind RackOrderListPageViewModel.PreviewUrl, Mode=TwoWay}"
                IsPrintEmailIconVisible="True" 
                PrintPictureCommand="{x:Bind RackOrderListPageViewModel.PrintRackPOSImageCommand}"/>
        </Grid>
    </Grid>
</Page>
