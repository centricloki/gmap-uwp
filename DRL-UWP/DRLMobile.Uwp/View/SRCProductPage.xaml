<Page
    x:Class="DRLMobile.Uwp.View.SRCProductPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Microsoft.Xaml.Interactions.Core"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:DRLMobile.Core.Models.UIModels"
    xmlns:localConverter="using:DRLMobile.Uwp.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="using:System"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <localConverter:BoolToCartImageConverter x:Key="cartImageCovnerter" />
        <localConverter:BoolToFavoriteImageConverter x:Key="favoriteImageConverter" />
        <localConverter:BoolToFavoriteDetailImageConverter x:Key="favoriteDetailImageConverter" />
        <localConverter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <localConverter:VisibilityToBoolConverter x:Key="VisibilityToBoolConverter" />
        <localConverter:InvertVisibilityConverter x:Key="InvertVisibilityConverter" />
        <localConverter:SRCProductColumnWidthConverter x:Key="SRCProductColumnWidthConverter" />
        <localConverter:SRCProductSelectedItemConverter x:Key="SRCProductSelectedItemConverter" />
        <SolidColorBrush x:Key="SystemColors.HighlightBrushKey" Color="Transparent" />
        <SolidColorBrush x:Key="SystemColors.ControlBrushKey" Color="Transparent" />
        <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
        <Style x:Key="TextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
        <Flyout
        x:Key="CustomKeyPadFlyout"
        x:Name="QuantityCustomKeyPadFlyout"
        Closing="QuantityCustomKeyPadFlyout_Closing"
        FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
        LightDismissOverlayMode="Off"
        Placement="BottomEdgeAlignedRight">
            <customControls:CustomKeypad
          DoneClickEvent="CustomKeypad_DoneClickEvent"
          IsDotButtonVisible="Collapsed"
          IsMinusButtonVisible="Visible"
          NumPadButtonClick="{x:Bind SrcProductPageViewModel.NumPadButtonClickCommand, Mode=OneWay}" />
        </Flyout>
    </Page.Resources>
    <Grid x:Name="gridpanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Canvas x:Name="PrintCanvas" Opacity="0" />

        <customControls:HeaderControl
        Title="RESOURCES"
        Grid.Row="0"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Top"
        BadgeText="{x:Bind SrcProductPageViewModel.BadgeText, Mode=OneWay}"
        CartButtonClick="{x:Bind SrcProductPageViewModel.CartButtonCommand, Mode=OneWay}"
        ComboBoxValueChangedCommand="{x:Bind SrcProductPageViewModel.HeaderComboBoxClickedCommand}"
        CustomerAddressText="{x:Bind SrcProductPageViewModel.CustomerAddresss, Mode=OneWay}"
        CustomerNameText="{x:Bind SrcProductPageViewModel.CustomerNameNumber, Mode=OneWay}"
        CustomerPanelClick="{x:Bind SrcProductPageViewModel.CustomerPanelClickCommand, Mode=OneWay}"
        CustomerSubAddressText="{x:Bind SrcProductPageViewModel.CustomerCityState, Mode=OneWay}"
        DisplayMemberPathValue="SearchDisplayPath"
        IsAutoSuggestBoxVisible="Visible"
        IsBadgeVisible="{x:Bind SrcProductPageViewModel.IsBadgeVisible, Mode=OneWay}"
        IsCartButtonVisible="Visible"
        IsComboBoxVisible="Visible"
        IsCustomerPanelVisible="{x:Bind SrcProductPageViewModel.CustomerTitlePanelVisibility, Mode=OneWay}"
        IsPageTitleVisible="Visible"
        ItemList="{x:Bind SrcProductPageViewModel.HeaderSearchItemSource, Mode=TwoWay}"
        PlaceHolderText="Search by Name or Number"
        ScrollViewer.HorizontalScrollBarVisibility="Hidden"
        ScrollViewer.VerticalScrollBarVisibility="Hidden"
        SuggestionChoosenCommand="{x:Bind SrcProductPageViewModel.HeaderSearchSuggestionChoosenCommand}"
        TextValueChangedCommand="{x:Bind SrcProductPageViewModel.HeaderSearchTextChangeCommand}" />

        <!--  Category List  -->
        <ListBox
        x:Name="LvCategory"
        Grid.Row="1"
        Padding="0"
        Background="{StaticResource LoginButtonBackground}"
        ItemsSource="{x:Bind SrcProductPageViewModel.CategoryCollection, Mode=OneWay}"
        ScrollViewer.HorizontalScrollBarVisibility="Auto"
        ScrollViewer.HorizontalScrollMode="Enabled"
        ScrollViewer.IsHorizontalRailEnabled="False"
        ScrollViewer.VerticalScrollMode="Disabled"
        SelectionMode="Single">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="10,10,5,5" />
                    <!--<Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />-->
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel
              x:Name="CategoryStack"
              Height="60"
              Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="local:CategoryUIModel">
                    <ListBoxItem Margin="0" Padding="0">
                        <RelativePanel
                x:Name="CategoryRelativePanel"
                Padding="0"
                Tapped="CategoryRelativePanel_Tapped">
                            <Image
                  x:Name="CategoryImage"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Source="{x:Bind CategoryImageSource, Mode=OneWay}" />
                            <TextBlock
                  x:Name="CategoryText"
                  FontSize="{StaticResource FooterFontSize}"
                  FontWeight="SemiBold"
                  Foreground="{StaticResource FooterTextColor}"
                  RelativePanel.AlignHorizontalCenterWithPanel="True"
                  RelativePanel.AlignVerticalCenterWithPanel="True"
                  Text="{x:Bind CategoryName, Mode=OneWay}" />
                        </RelativePanel>
                    </ListBoxItem>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!--  Brand List  -->
        <ListBox
        x:Name="LvBrand"
        Grid.Row="2"
        Padding="0"
        x:Load="{x:Bind SrcProductPageViewModel.IsBrandGridLoad, Mode=OneWay}"
        Background="{StaticResource LoginButtonBackground}"
        ItemsSource="{x:Bind SrcProductPageViewModel.BrandCollection, Mode=OneWay}"
        ScrollViewer.HorizontalScrollBarVisibility="Auto"
        ScrollViewer.HorizontalScrollMode="Enabled"
        ScrollViewer.IsHorizontalRailEnabled="False"
        ScrollViewer.VerticalScrollMode="Disabled"
        SelectionMode="Multiple">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="10,0,5,5" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel
              x:Name="BrandStack"
              Height="60"
              Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="local:BrandUIModel">
                    <ListBoxItem Margin="0" Padding="0">
                        <Grid Background="Transparent" Tapped="BrandGrid_Tapped">
                            <Image
                  Name="ProductImage"
                  Width="120"
                  Margin="8,5,8,10"
                  Source="{StaticResource NoProduct}"
                  Stretch="Fill" />
                            <Image
                  Name="SelectedImagePanel"
                  Width="120"
                  Margin="0"
                  Source="{x:Bind SelectedImageSource, Mode=OneWay}"
                  Stretch="Fill" />
                            <Image
                  Width="120"
                  Margin="8,5,8,10"
                  Source="{x:Bind BrandImageSource, Mode=OneWay}"
                  Stretch="Fill" />
                        </Grid>
                    </ListBoxItem>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel
        x:Name="NoBrandStackPanel"
        Grid.Row="2"
        Padding="0,10,0,10"
        x:Load="{x:Bind InvertBool(SrcProductPageViewModel.IsBrandGridLoad), Mode=OneWay}"
        Background="{StaticResource LoginButtonBackground}">
            <TextBlock
          x:Name="NoBrand"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          FontSize="{StaticResource MediumFontSize}"
          FontWeight="SemiBold"
          Foreground="{StaticResource LoginScreenTextFontColor}"
          Text="No Brand Found" />
        </StackPanel>

        <!--  Style List  -->
        <ListBox
        x:Name="LvStyle"
        Grid.Row="3"
        Padding="0"
        x:Load="{x:Bind SrcProductPageViewModel.IsStyleGridLoad, Mode=OneWay}"
        Background="{StaticResource LoginButtonBackground}"
        ItemsSource="{x:Bind SrcProductPageViewModel.StyleCollection, Mode=OneWay}"
        ScrollViewer.HorizontalScrollBarVisibility="Auto"
        ScrollViewer.HorizontalScrollMode="Enabled"
        ScrollViewer.IsHorizontalRailEnabled="False"
        ScrollViewer.VerticalScrollMode="Disabled"
        SelectionMode="Multiple">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="10,0,5,5" />
                    <!--<Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />-->
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel
              x:Name="StyleStack"
              Height="40"
              Padding="0"
              Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="local:StyleUIModel">
                    <ListBoxItem Margin="0" Padding="0">
                        <RelativePanel
                x:Name="StyleRelativePanel"
                Background="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource SRCProductSelectedItemConverter}}"
                Tapped="StyleRelativePanel_Tapped">
                            <Image
                  Name="StyleImage"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Source="{x:Bind StyleImageSource, Mode=OneWay}" />
                            <TextBlock
                  Name="StyleText"
                  Padding="0,8,0,0"
                  FontSize="{StaticResource FooterFontSize}"
                  FontWeight="SemiBold"
                  Foreground="{StaticResource FooterTextColor}"
                  RelativePanel.AlignHorizontalCenterWithPanel="True"
                  Text="{x:Bind StyleName, Mode=OneWay}" />
                        </RelativePanel>
                    </ListBoxItem>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel
        x:Name="NoStyleStackPanel"
        Grid.Row="3"
        Padding="0,10,0,10"
        x:Load="{x:Bind InvertBool(SrcProductPageViewModel.IsStyleGridLoad), Mode=OneWay}"
        Background="{StaticResource LoginButtonBackground}">
            <TextBlock
          x:Name="NoStyle"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          FontSize="{StaticResource MediumFontSize}"
          FontWeight="SemiBold"
          Foreground="{StaticResource LoginScreenTextFontColor}"
          Text="No Style Found" />
        </StackPanel>

        <!--  Product List Grid  -->
        <Grid
        x:Name="gridProducts"
        Grid.Row="4"
        x:Load="{x:Bind SrcProductPageViewModel.IsProductGridLoad, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.Resources>
                <SolidColorBrush x:Key="gridBrush" Color="Silver" />
            </Grid.Resources>
            <!--  gridProducts.Grid.Row=0  Header  -->

            <!--WithOut Selected Customer Other Category-->
            <Grid
          x:Name="gridNoSaleNoCustomerPrdHeader"
          x:Load="{x:Bind SrcProductPageViewModel.IsNoSelectedCustomerGrid, Mode=OneWay}"
          Grid.Row="0"
          Padding="0">
                <Grid.ColumnDefinitions>
                    <!--  itemno  -->
                    <ColumnDefinition Width="3*" />
                    <!--  item description | Link  -->
                    <ColumnDefinition Width="3*" />
                    <!--  pdf  -->
                    <ColumnDefinition Width="2.*" />
                    <!--  add to cart | Fav Doc  -->
                    <ColumnDefinition Width="2.*" />
                    <!--  fav product  -->
                    <ColumnDefinition Width="2.*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.Resources>
                    <Style TargetType="Grid">
                        <Setter Property="BorderBrush" Value="{StaticResource gridBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                    </Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="15" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="Foreground" Value="Black" />
                        <Setter Property="TextWrapping" Value="Wrap" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="Grid.Column" Value="0" />
                        <Setter Property="Margin" Value="10" />
                    </Style>
                    <Style TargetType="Image">
                        <Setter Property="Width" Value="20" />
                        <Setter Property="Height" Value="18" />
                        <Setter Property="Grid.Column" Value="1" />
                        <Setter Property="VerticalAlignment" Value="Top" />
                        <Setter Property="Margin" Value="0,15,0,0" />
                    </Style>
                    <Style TargetType="TextBox">
                        <Setter Property="BorderBrush" Value="{StaticResource gridBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="0" />
                        <Setter Property="Padding" Value="10" />
                        <Setter Property="PlaceholderText" Value="Search..." />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="TextWrapping" Value="WrapWholeWords" />
                        <Setter Property="Grid.Row" Value="1" />
                    </Style>
                </Grid.Resources>
                <!--  gridPrdHeader.Grid.Row=0  -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.80*" />
                        <ColumnDefinition Width="0.20*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Item #" />
                    <Image
              x:Name="sortNoSaleNoCustItemNumberImg"
              x:Load="{x:Bind IsNotEmpty(SrcProductPageViewModel.SortItemNumberText), Mode=OneWay}"
              Source="{x:Bind GetSortImagePath(SrcProductPageViewModel.SortItemNumberText), Mode=OneWay}" />
                    <!--  Sort Button Click  -->
                    <interactivity:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="PointerPressed">
                            <core:InvokeCommandAction Command="{x:Bind SrcProductPageViewModel.SortColumnClickCommandAsync, Mode=OneWay}" 
                                                      CommandParameter="{x:Bind sys:String.Format('itemnumber|{0}', SrcProductPageViewModel.SortItemNumberText), Mode=OneWay}" />
                        </core:EventTriggerBehavior>
                    </interactivity:Interaction.Behaviors>
                </Grid>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.80*" />
                        <ColumnDefinition Width="0.20*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Item Description" />
                    <Image
              x:Name="sortNoSaleNoCustItemDescriptionImg"
              x:Load="{x:Bind IsNotEmpty(SrcProductPageViewModel.SortItemDescriptionText), Mode=OneWay}"
              Source="{x:Bind GetSortImagePath(SrcProductPageViewModel.SortItemDescriptionText), Mode=OneWay}" />
                    <!--  Sort Button Click  -->
                    <interactivity:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="PointerPressed">
                            <core:InvokeCommandAction Command="{x:Bind SrcProductPageViewModel.SortColumnClickCommandAsync, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('description|{0}', SrcProductPageViewModel.SortItemDescriptionText), Mode=OneWay}" />
                        </core:EventTriggerBehavior>
                    </interactivity:Interaction.Behaviors>
                </Grid>
                <Grid x:Name="grdColPdf" Grid.Column="2">
                    <TextBlock Text="PDF" />
                </Grid>
                <Grid x:Name="grdColAddToCart" Grid.Column="3">
                    <TextBlock Text="Add to Cart" />
                </Grid>
                <Grid x:Name="grdColFavorite" Grid.Column="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.90*" />
                        <ColumnDefinition Width="0.10*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Favorites" />
                    <Image
                    x:Name="sortNoCustomerFavImg"
                    x:Load="{x:Bind IsNotEmpty(SrcProductPageViewModel.SortFavoriteText), Mode=OneWay}"
                    Source="{x:Bind GetSortImagePath(SrcProductPageViewModel.SortFavoriteText), Mode=OneWay}" />
                    <!--  Sort Button Click  -->
                    <interactivity:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="PointerPressed">
                            <core:InvokeCommandAction Command="{x:Bind SrcProductPageViewModel.SortColumnClickCommandAsync, Mode=OneWay}" 
                                        CommandParameter="{x:Bind sys:String.Format('favorite|{0}', SrcProductPageViewModel.SortFavoriteText), Mode=OneWay}" />
                        </core:EventTriggerBehavior>
                    </interactivity:Interaction.Behaviors>
                </Grid>
                <!--  gridPrdHeader.Grid.Row=1  -->
                <TextBox  Grid.Row="1"
            Grid.Column="0"
                Text="{x:Bind SrcProductPageViewModel.FilterItemNumberText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <!--  Text Box Filter Click  -->
                    <interactivity:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="TextChanged">
                            <core:InvokeCommandAction Command="{x:Bind SrcProductPageViewModel.FilterColumnClickCommandAsync, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('itemnumber|{0}', SrcProductPageViewModel.FilterItemNumberText), Mode=OneWay}" />
                        </core:EventTriggerBehavior>
                    </interactivity:Interaction.Behaviors>
                </TextBox>
                <TextBox Grid.Row="1"
            Grid.Column="1" Text="{x:Bind SrcProductPageViewModel.FilterItemDescriptionText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <!--  Text Box Filter Click  -->
                    <interactivity:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="TextChanged">
                            <core:InvokeCommandAction Command="{x:Bind SrcProductPageViewModel.FilterColumnClickCommandAsync, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('itemdescription|{0}', SrcProductPageViewModel.FilterItemDescriptionText), Mode=OneWay}" />
                        </core:EventTriggerBehavior>
                    </interactivity:Interaction.Behaviors>
                </TextBox>
                <Rectangle
            Grid.Row="1"
            Grid.Column="2"
            Fill="#B3FFFFFF"
            Stroke="{StaticResource gridBrush}"
            StrokeThickness="1" />
                <Rectangle
            Grid.Row="1"
            Grid.Column="3"
            Fill="#B3FFFFFF"
            Stroke="{StaticResource gridBrush}"
            StrokeThickness="1"
                    />
                <Rectangle
            Grid.Row="1"
            Grid.Column="4"
            Fill="#B3FFFFFF"
            Stroke="{StaticResource gridBrush}"
            StrokeThickness="1"  />
            </Grid>
            <!--  gridProducts.Grid.Row=1  Detail with No Sale Category Product List  -->
            <customControls:CustomAlternateRowColorListView
          x:Name="lvNoSaleNoCustomerProducts"
          Grid.Row="1" Background="#FFFFFF"
         x:Load="{x:Bind SrcProductPageViewModel.IsNoSelectedCustomerGrid, Mode=OneWay}"
          ItemsSource="{x:Bind SrcProductPageViewModel.ProductGridDataSource, Mode=OneWay}"
          SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:SRCProductUIModel">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!--  itemno  -->
                                <ColumnDefinition Width="3*" />
                                <!--  item description | Link  -->
                                <ColumnDefinition Width="3*" />
                                <!--  pdf  -->
                                <ColumnDefinition Width="2.*" />
                                <!--  add to cart | Fav Doc  -->
                                <ColumnDefinition Width="2.*" />
                                <!--  fav product  -->
                                <ColumnDefinition Width="2.*" />
                            </Grid.ColumnDefinitions>
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="15" />
                                    <Setter Property="FontWeight" Value="Normal" />
                                    <Setter Property="Foreground" Value="Black" />
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Margin" Value="10,0,0,0" />
                                </Style>
                            </Grid.Resources>
                            <Grid Grid.Column="0">
                                <TextBlock Tapped="TextBlock_Tapped" Text="{x:Bind ItemNumber, Mode=OneWay}" />
                            </Grid>
                            <Grid Grid.Column="1">
                                <TextBlock Tapped="TextBlock_Tapped" Text="{x:Bind ItemDescription, Mode=OneWay}" />
                            </Grid>
                            <Grid
                  Grid.Column="2"
                  Background="Transparent"
                  Tapped="PdfClicked">
                                <Image
                    x:Name="pdfImage"
                    Width="27"
                    Height="27"
                    Source="{x:Bind PdfImage, Mode=OneWay}" />
                            </Grid>
                            <Grid Grid.Column="3" Tapped="Grid_Tapped">
                                <Image
                    x:Name="cartImage"
                    Width="27"
                    Height="27"
                    Source="{x:Bind IsAddedToCart, Mode=OneWay, Converter={StaticResource cartImageCovnerter}}" />
                            </Grid>
                            <Grid Grid.Column="4" Tapped="FavoriteGrid_Tapped">
                                <Image
                    Width="27"
                    Height="27"
                    Source="{x:Bind FavoriteImageSource, Mode=OneWay}" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </customControls:CustomAlternateRowColorListView>

            <!--With Selected Customer Other Category-->
            <Grid
          x:Name="gridCustomerPrdHeader"
          x:Load="{x:Bind SrcProductPageViewModel.IsSelectedCustomerGrid, Mode=OneWay}"
          Grid.Row="0"
          Padding="0">
                <Grid.ColumnDefinitions>
                    <!--  itemno  -->
                    <ColumnDefinition Width="1*" />
                    <!--  item description | Link  -->
                    <ColumnDefinition Width="3*" />
                    <!--  pdf  -->
                    <ColumnDefinition Width="0.5*" />
                    <!--  add to cart | Fav Dohc  -->
                    <ColumnDefinition Width="1*" />
                    <!--dist checkbox-->
                    <ColumnDefinition Width="1*" />
                    <!--dist date-->
                    <ColumnDefinition Width="1.5*" />
                    <!--  fav product  -->
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.Resources>
                    <Style TargetType="Grid">
                        <Setter Property="BorderBrush" Value="{StaticResource gridBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                    </Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="15" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="Foreground" Value="Black" />
                        <Setter Property="TextWrapping" Value="Wrap" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="Grid.Column" Value="0" />
                        <Setter Property="Margin" Value="10" />
                    </Style>
                    <Style TargetType="Image">
                        <Setter Property="Width" Value="20" />
                        <Setter Property="Height" Value="18" />
                        <Setter Property="Grid.Column" Value="1" />
                        <Setter Property="VerticalAlignment" Value="Top" />
                        <Setter Property="Margin" Value="0,15,0,0" />
                    </Style>
                    <Style TargetType="TextBox">
                        <Setter Property="BorderBrush" Value="{StaticResource gridBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="0" />
                        <Setter Property="Padding" Value="10" />
                        <Setter Property="PlaceholderText" Value="Search..." />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="TextWrapping" Value="WrapWholeWords" />
                        <Setter Property="Grid.Row" Value="1" />
                    </Style>
                </Grid.Resources>
                <!--  gridPrdHeader.Grid.Row=0  -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.80*" />
                        <ColumnDefinition Width="0.20*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Item #" />
                    <Image
              x:Name="sortNoSaleItemNumberImg"
              x:Load="{x:Bind IsNotEmpty(SrcProductPageViewModel.SortItemNumberText), Mode=OneWay}"
              Source="{x:Bind GetSortImagePath(SrcProductPageViewModel.SortItemNumberText), Mode=OneWay}" />
                    <!--  Sort Button Click  -->
                    <interactivity:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="PointerPressed">
                            <core:InvokeCommandAction Command="{x:Bind SrcProductPageViewModel.SortColumnClickCommandAsync, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('itemnumber|{0}', SrcProductPageViewModel.SortItemNumberText), Mode=OneWay}" />
                        </core:EventTriggerBehavior>
                    </interactivity:Interaction.Behaviors>
                </Grid>
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.80*" />
                        <ColumnDefinition Width="0.20*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Item Description" />
                    <Image
              x:Name="sortNoSaleItemDescriptionImg"
              x:Load="{x:Bind IsNotEmpty(SrcProductPageViewModel.SortItemDescriptionText), Mode=OneWay}"
              Source="{x:Bind GetSortImagePath(SrcProductPageViewModel.SortItemDescriptionText), Mode=OneWay}" />
                    <!--  Sort Button Click  -->
                    <interactivity:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="PointerPressed">
                            <core:InvokeCommandAction Command="{x:Bind SrcProductPageViewModel.SortColumnClickCommandAsync, Mode=OneWay}" CommandParameter="{x:Bind sys:String.Format('description|{0}', SrcProductPageViewModel.SortItemDescriptionText), Mode=OneWay}" />
                        </core:EventTriggerBehavior>
                    </interactivity:Interaction.Behaviors>
                </Grid>
                <Grid  Grid.Column="2">
                    <TextBlock Text="PDF" />
                </Grid>
                <Grid Grid.Column="3">
                    <TextBlock Text="Add to Cart" />
                </Grid>
                <Grid
            Grid.Column="4">
                    <TextBlock Text="Distribution" />
                </Grid>
