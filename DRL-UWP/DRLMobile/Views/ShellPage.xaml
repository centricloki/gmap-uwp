<Page
    x:Class="DRLMobile.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:DRLMobile.Behaviors"
    xmlns:customControls="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:DRLMobile.Helpers"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:ic="using:Microsoft.Xaml.Interactions.Core"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:DRLMobile.Views"
    xmlns:winui="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">
    <Page.Resources>
        <Thickness x:Key="NavigationViewHeaderMargin">12,-20</Thickness>
    </Page.Resources>
    <i:Interaction.Behaviors>
        <ic:EventTriggerBehavior EventName="Loaded">
            <ic:InvokeCommandAction Command="{x:Bind ViewModel.LoadedCommand}" />
        </ic:EventTriggerBehavior>
    </i:Interaction.Behaviors>

    <winui:NavigationView
        x:Name="navigationView"
        AlwaysShowHeader="False"
        Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
        IsBackButtonVisible="Visible"
        IsBackEnabled="{x:Bind ViewModel.IsBackEnabled, Mode=OneWay}"
        IsPaneVisible="True"
        IsSettingsVisible="False"
        PaneDisplayMode="LeftCompact"
        SelectedItem="{x:Bind ViewModel.Selected, Mode=OneWay}">
        <winui:NavigationView.MenuItems>
            <!--
                TODO WTS: Change the symbols for each item as appropriate for your app
                More on Segoe UI Symbol icons: https://docs.microsoft.com/windows/uwp/style/segoe-ui-symbol-font
                Or to use an IconElement instead of a Symbol see https://github.com/Microsoft/WindowsTemplateStudio/blob/release/docs/UWP/projectTypes/navigationpane.md
                Edit String/en-US/Resources.resw: Add a menu item title for each page
            -->
            <winui:NavigationViewItem
                x:Uid="Shell_Main"
                helpers:NavHelper.NavigateTo="views:DashboardPage"
                Content="Dashboard"
                Icon="Home" />

            <winui:NavigationViewItem
                x:Uid="Shell_SrcProduct"
                helpers:NavHelper.NavigateTo="views:SRCProductPage"
                Content="SRC/Product">
                <winui:NavigationViewItem.Icon>
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEB3C;" />
                    <!--<BitmapIcon UriSource="ms-appx:///Assets/Dashboard/src_product_normal.png"/>-->
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>

            <winui:NavigationViewItem
                x:Uid="Shell_Cart"
                helpers:NavHelper.NavigateTo="views:CartPage"
                Content="Cart">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/cart_normal.png" />
                </winui:NavigationViewItem.Icon>

                <!--<NavigationViewItem>
                    <StackPanel Orientation="Horizontal" Spacing="10" Padding="0">
                        <Image Source="ms-appx:///Assets/Dashboard/cart_normal.png" />
                        <TextBlock Text="Cart"/>
                    </StackPanel>
                </NavigationViewItem>-->
            </winui:NavigationViewItem>

            <winui:NavigationViewItem
                x:Uid="Shell_Customer"
                helpers:NavHelper.NavigateTo="views:CustomerPage"
                Content="Customer">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/customers_normal.png" />
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>

            <winui:NavigationViewItem
                x:Uid="Shell_Favorite"
                helpers:NavHelper.NavigateTo="views:FavoritePage"
                Content="Favorite">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/favorite_normal.png" />
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>

            <winui:NavigationViewItem
                x:Uid="Shell_RouteList"
                helpers:NavHelper.NavigateTo="views:RouteListPage"
                Content="Route Lists">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon ShowAsMonochrome="True" UriSource="ms-appx:///Assets/Dashboard/route_list_normal.png" />
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>

            <winui:NavigationViewItem
                x:Uid="Shell_Settings"
                helpers:NavHelper.NavigateTo="views:SettingsPage"
                Content="Settings">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/settings_normal.png" />
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>

            <winui:NavigationViewItem
                x:Uid="Shell_Activities"
                helpers:NavHelper.NavigateTo="views:ActivitiesPage"
                Content="Activities">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/activity_normal.png" />
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>

            <winui:NavigationViewItem
                x:Uid="Shell_Map"
                helpers:NavHelper.NavigateTo="views:MapPage"
                Content="Map">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/map_normal.png" />
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>

            <winui:NavigationViewItem
                x:Uid="Shell_Sync"
                helpers:NavHelper.NavigateTo="views:SyncPage"
                Content="Sync">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/sync_normal.png" />
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>

            <winui:NavigationViewItem
                x:Uid="Shell_RackOrder"
                helpers:NavHelper.NavigateTo="views:RackOrderListPage"
                Content="Rack Order">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/rack_order_normal.png" />
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>

            <winui:NavigationViewItem
                x:Uid="Shell_PopOrder"
                helpers:NavHelper.NavigateTo="views:PopOrderPage"
                Content="Pop Order">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/pop_order_normal.png" />
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>

            <winui:NavigationViewItem
                x:Uid="Shell_Trip"
                helpers:NavHelper.NavigateTo="views:TravelVripPage"
                Content="Travel/VRIP">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/travel-vrip_normal.png" />
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>

            <!--<winui:NavigationViewItem
                x:Uid="Shell_Logout"
                helpers:NavHelper.NavigateTo="views:LogOutPage"
                Content="Logout">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/cart_normal.png" />
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>-->

            <!--<winui:NavigationViewItem x:Uid="Shell_Main" Name="Dashboard1" Content="Apps" Tag="Salah">
                <winui:NavigationViewItem.Icon>
                    <BitmapIcon UriSource="ms-appx:///Assets/Dashboard/src_product_normal.png"/>
                </winui:NavigationViewItem.Icon>
            </winui:NavigationViewItem>-->

        </winui:NavigationView.MenuItems>

        <i:Interaction.Behaviors>
            <behaviors:NavigationViewHeaderBehavior DefaultHeader="{x:Bind ViewModel.Selected.Content, Mode=OneWay}">
                <behaviors:NavigationViewHeaderBehavior.DefaultHeaderTemplate>
                    <DataTemplate>
                        <Grid Height="0">
                            <TextBlock
                                Margin="{StaticResource SmallLeftRightMargin}"
                                Style="{ThemeResource TitleTextBlockStyle}"
                                Text="{Binding}" />
                            <!--  Text="{Binding}"  -->


                        </Grid>
                    </DataTemplate>
                </behaviors:NavigationViewHeaderBehavior.DefaultHeaderTemplate>
            </behaviors:NavigationViewHeaderBehavior>
            <ic:EventTriggerBehavior EventName="ItemInvoked">
                <ic:InvokeCommandAction Command="{x:Bind ViewModel.ItemInvokedCommand}" />
            </ic:EventTriggerBehavior>
        </i:Interaction.Behaviors>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Frame x:Name="shellFrame" Grid.Row="0" />

            <customControls:FooterControl
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                IsLoggedInVisible="Visible"
                IsSyncVisible="Visible"
                LoggedInUsername="{x:Bind ViewModel.TempUserName, Mode=OneWay}"
                SyncDateTime="{x:Bind ViewModel.LastSyncDateTime, Mode=TwoWay}" />
        </Grid>
    </winui:NavigationView>
</Page>
