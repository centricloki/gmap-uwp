<UserControl
    x:Class="DRLMobile.Uwp.CustomControls.MapPinCustomPopUp"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DRLMobile.Uwp.CustomControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <UserControl.Resources />
    <StackPanel
        Padding="20,10,20,40"
        HorizontalAlignment="Stretch"
        Background="White">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="1"
                Grid.ColumnSpan="2"                
                HorizontalAlignment="Center"
                FontWeight="Bold"
                Foreground="{StaticResource CartTextColor}"
                Style="{StaticResource FieldTextBlockStyle}"
                Text="Account Profile Information" />
            <FontIcon
                Grid.Column="2"                
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                FontSize="25"
                Foreground="Gray"
                Glyph="{StaticResource CancelIcon}"
                Style="{StaticResource FontIconStyle}"
                Tapped="ClosePreviewIcon_Tapped" />
        </Grid>
        <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Style="{StaticResource LeftTextBlockStyle}"
                Text="Account Name:" />
            <TextBlock
                x:Name="AccountNameTextBlock"
                Grid.Column="1"
                Margin="22,0,0,0"
                d:Text="G Jiffy Mart"
                Foreground="{StaticResource CartTextColor}"
                Style="{StaticResource RightTextBlockStyle}"
                IsTextSelectionEnabled="True">
            </TextBlock>
        </Grid>

        <Grid Margin="{StaticResource XSmallTopMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Style="{StaticResource LeftTextBlockStyle}"
                Text="Account Number:" />
            <TextBlock
                x:Name="AccountNumberTextBlock"
                Grid.Column="1"
                d:Text="028876"
                IsTextSelectionEnabled="True"
                Style="{StaticResource RightTextBlockStyle}" />
        </Grid>

        <Grid Margin="{StaticResource XSmallTopMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Style="{StaticResource LeftTextBlockStyle}"
                Text="Full Address:" />
            <TextBlock
                x:Name="AddressTextBlock"
                Grid.Column="1"
                Margin="37,0,0,0"
                d:Text="hagcuer "
                Style="{StaticResource RightTextBlockStyle}" />
        </Grid>

        <Grid Margin="{StaticResource XSmallTopMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Style="{StaticResource LeftTextBlockStyle}"
                Text="Phone Number:" />
            <TextBlock
                x:Name="PhoneTextBlock"
                Grid.Column="1"
                Margin="20,0,0,0"
                d:Text="028876265"
                Style="{StaticResource RightTextBlockStyle}" />
        </Grid>

        <Grid Margin="{StaticResource XSmallTopMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Style="{StaticResource LeftTextBlockStyle}"
                Text="Last Call Date:" />
            <TextBlock
                x:Name="LastCallDateTextBlock"
                Grid.Column="1"
                Margin="28,0,0,0"
                d:Text="12/02/1991"
                Style="{StaticResource RightTextBlockStyle}" />
        </Grid>

        <Grid Margin="{StaticResource XSmallTopMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Style="{StaticResource LeftTextBlockStyle}"
                Text="Manager Name:" />
            <TextBlock
                x:Name="ManagerNameTextBlock"
                Grid.Column="1"
                Margin="18,0,0,0"
                d:Text="Manager Name "
                Style="{StaticResource RightTextBlockStyle}" />
        </Grid>

        <Grid x:Name="LastThreeCallActivity" Margin="{StaticResource XSmallTopMargin}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Style="{StaticResource LeftTextBlockStyle}"
                Text="Last Three Call Activities:" />
        </Grid>

        <ListView x:Name="LastThreeCallActivityList" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid HorizontalAlignment="Stretch" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Margin="0,5,5,5"
                            Text="{Binding DisplayCallDate}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="5"
                            Text="{Binding ActivityType}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            Grid.Column="2"
                            Margin="5"
                            Text="{Binding TerritoryName}"
                            TextWrapping="WrapWholeWords" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button
            Width="153" Margin="0,0,2,0"
            Click="Copy_ButtonClick"
            Content="Copy"
            Style="{StaticResource ActionButtonStyle}" />
            <Button
            Width="153"  Margin="2,0,0,0" 
            Click="ShareAccount_ButtonClicked"
            Content="Share Account"
            Style="{StaticResource ActionButtonStyle}" />
        </StackPanel>
        <Button
            Click="AddtoRouteButton_Click"
            Content="Add to Route List"
            Style="{StaticResource ActionButtonStyle}">
            <FlyoutBase.AttachedFlyout>
                <Flyout
                    x:Name="AddtoRouteFlyout"
                    LightDismissOverlayMode="Off"
                    Placement="Right">
                    <Flyout.FlyoutPresenterStyle>
                        <Style BasedOn="{StaticResource ErrorFlyoutPresenterStyle}" TargetType="FlyoutPresenter">
                            <Setter Property="MinWidth" Value="500" />
                        </Style>
                    </Flyout.FlyoutPresenterStyle>
                    <Grid
                        MinHeight="500"
                        Background="White"
                        BorderBrush="Black"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid
                            Grid.Row="0"
                            Height="35"
                            HorizontalAlignment="Stretch"
                            Background="{StaticResource FooterBackgroundColor}">
                            <Button
                                x:Name="CrossButton"
                                Padding="10,5,10,5"
                                Background="Transparent"
                                Click="ClosePopupClicked">
                                <FontIcon
                                    Foreground="White"
                                    Glyph="{StaticResource CancelIcon}"
                                    Style="{StaticResource FontIconStyle}" />
                            </Button>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Add To Route List" />
                            <TextBlock
                                Margin="0,0,20,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="White"
                                Tapped="RouteList_DoneClicked"
                                Text="Done" />
                        </Grid>

                        <!--<ListView
                            x:Name="AddtoRouteList"
                            Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            CornerRadius="5"
                            SelectionMode="None">
                            <ListViewItem>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListViewItem>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid
                                        HorizontalAlignment="Stretch"
                                        Background="Red"
                                        BorderThickness="0,0,0,0.2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition Width="auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Style="{StaticResource LeftTextBlockStyle}"
                                            Text="{Binding RouteName}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Style="{StaticResource LeftTextBlockStyle}"
                                            TextWrapping="WrapWholeWords">
