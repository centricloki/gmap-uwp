    <!--#region combo box for customer profile page-->
    <Style x:Key="ComboBoxViewOnlyStyle" TargetType="ComboBox">
        <Setter Property="Padding" Value="5" />
        <Setter Property="IsEnabled" Value="False" />
        <Setter Property="Margin" Value="10,30,0,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinWidth" Value="150" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="35" />
        <Setter Property="Margin" Value="10,0,0,0" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="MaxDropDownHeight" Value="250" />
        <Setter Property="Foreground" Value="{ThemeResource LoginScreenTextFontColor}" />
