<UserControl
    x:Class="DRLMobile.Uwp.CustomControls.NameAndSignaturePanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="columnLabels" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontStyle" Value="Normal" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style x:Key="columnLabels1" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontStyle" Value="Normal" />
            <Setter Property="Foreground" Value="LightGray" />
        </Style>
        <Style x:Key="buttonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="DarkSlateGray" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Light" />
        </Style>
    </UserControl.Resources>

    <Grid
        Margin="250,200"
        Padding="15"
        Background="White"
        BorderBrush="DarkGray"
        BorderThickness="1"
        ColumnSpacing="5"
        CornerRadius="5"
        RowSpacing="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            VerticalAlignment="Center"
            Style="{StaticResource columnLabels}"
            Text="Print Name:*" />
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            VerticalAlignment="Top"
            Style="{StaticResource columnLabels}"
            Text="Signature:*" />
        <TextBox
            x:Name="nameTextBox"
            Grid.Row="0"
            Grid.Column="1"
            Height="40"
            VerticalAlignment="Center"
            BorderBrush="DarkGray"
            BorderThickness="1"
            CornerRadius="3"
            PlaceholderText="Print Name"
            Text="{Binding PrintName}"
            TextChanging="nameTextBox_TextChanging" />
        <Grid
            x:Name="signaturePanel"
            Grid.Row="1"
            Grid.Column="1"
            BorderBrush="DarkGray"
            BorderThickness="1"
            CornerRadius="3"
            RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width=".33*" />
                <ColumnDefinition Width=".33*" />
                <ColumnDefinition Width=".33*" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Row="0"
                Grid.Column="0"
                Click="CancelButton_Click"
                Content="Cancel"
                Style="{StaticResource buttonStyle}" />
            <Button
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Center"
                Click="ClearSignatureButton_Click"
                Content="Clear"
                Style="{StaticResource buttonStyle}" />
            <Button
                Grid.Row="0"
                Grid.Column="2"
                HorizontalAlignment="Right"
                Click="ConfirmButton_Click"
                Content="Confirm"
                Style="{StaticResource buttonStyle}" />
            <InkCanvas
                x:Name="signatureCanvas"
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3" />
        </Grid>
    </Grid>
</UserControl>