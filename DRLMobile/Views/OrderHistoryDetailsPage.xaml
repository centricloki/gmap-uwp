<Page
    x:Class="DRLMobile.Views.OrderHistoryDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:Editors="using:DevExpress.UI.Xaml.Editors"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:converters="using:DRLMobile.Converters"
    xmlns:core="using:Microsoft.Xaml.Interactions.Core"
    xmlns:customControl="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:DRLMobile.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Microsoft.Toolkit.Uwp.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="NoExpanderHeaderStyle" TargetType="ToggleButton">
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>

        <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource CartTextColor}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="ValueTextBlock"
            BasedOn="{StaticResource FieldTextBlockStyle}"
            TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="20,10,0,0" />
        </Style>

        <Flyout
            x:Key="CustomPriceKeyPadFlyout"
            x:Name="PriceKeyPadFlyout"
            Closing="Flyout_Closing"
            FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
            LightDismissOverlayMode="Off"
            Placement="Left">
            <customControl:CustomKeypad
                DoneClickEvent="CustomKeypad_DoneClickEvent_1"
                IsDotButtonVisible="Visible"
                IsMinusButtonVisible="Collapsed"
                NumPadButtonClick="{x:Bind ViewModel.NumPadButtonClickCommand}" />
        </Flyout>

        <Flyout
            x:Key="CustomKeyPadFlyout"
            x:Name="QuantityCustomKeyPadFlyout"
            Closing="QuantityCustomKeyPadFlyout_Closing"
            FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
            LightDismissOverlayMode="Off"
            Placement="Left">
            <customControl:CustomKeypad
                DoneClickEvent="CustomKeypad_DoneClickEvent"
                IsDotButtonVisible="Collapsed"
                IsMinusButtonVisible="Visible"
                NumPadButtonClick="{x:Bind ViewModel.NumPadButtonClickCommand}" />
        </Flyout>

        <converters:InvertBoolToVisibilityConverter x:Key="InvertBoolVisibilityConverter" />
        <converters:BoolToImageSourceConverter x:Key="BoolToImageConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToStyleConverter x:Key="BoolToStyleConverter" />
    </Page.Resources>


    <Grid Background="{StaticResource LoginBackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="62" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>


        <Grid Grid.Row="0" Background="{StaticResource FooterBackgroundColor}">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource LargeFontSize}"
                FontWeight="SemiBold"
                Foreground="{StaticResource FooterTextColor}"
                Text="ORDER DETAILS" />

            <StackPanel
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="30">
                <customControl:DashboardButton
                    Margin="5"
                    ButtonClick="{x:Bind ViewModel.EditSaveCommand}"
                    HoverStateImageSource="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToImageConverter}, ConverterParameter='Hover'}"
                    ImageHeightWidth="39"
                    IsBadgeVisible="Collapsed"
                    NormalStateImageSource="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToImageConverter}, ConverterParameter='Normal'}"
                    Visibility="{x:Bind ViewModel.IsEditIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <FontIcon
                    Margin="0,0,10,0"
                    FontSize="35"
                    Foreground="{StaticResource FooterTextColor}"
                    Glyph="{StaticResource MailIcon}"
                    Style="{StaticResource FontIconStyle}">
                    <i:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="Tapped">
                            <core:InvokeCommandAction Command="{x:Bind ViewModel.PrintEmailCommand}" CommandParameter="Email" />
                        </core:EventTriggerBehavior>
                    </i:Interaction.Behaviors>
                </FontIcon>
                <FontIcon
                    Margin="0,0,20,0"
                    FontSize="30"
                    Foreground="{StaticResource FooterTextColor}"
                    Glyph="{StaticResource PrintIcon}"
                    Style="{StaticResource FontIconStyle}" />



            </StackPanel>

        </Grid>

        <ScrollViewer Grid.Row="1">
            <Grid RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--#region Details Left-->
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Transaction #" />
                                <Run Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ValueTextBlock}"
                            Text="{x:Bind ViewModel.UiModel.OrderHistoryModel.Invoice, Mode=OneWay}" />


                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Purchase Order " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.PurchaseOrder, Mode=TwoWay}" />


                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Account " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ValueTextBlock}"
                            Text="{x:Bind ViewModel.UiModel.CustomerNumber, Mode=TwoWay}" />


                    </Grid>


                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Address " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.PhysicalAddress, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="City " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.PhysicalCity, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="State " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <ComboBox
                            x:Name="PhysicalStateComboBox"
                            Grid.Column="1"
                            Margin="20,10,0,0"
                            FontSize="16"
                            ItemsSource="{Binding UiModel.StateDictionary.Values}"
                            SelectedItem="{x:Bind ViewModel.UiModel.SelectedPhysicalState, Mode=TwoWay}"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='ComboBox'}">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>

                        </ComboBox>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Zip " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            d:Text="zip"
                            BeforeTextChanging="NumericTextBox_BeforeTextChanging"
                            MaxLength="10"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.PhysicalZip, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="State Tobacco License " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.StateTobaccoLicense, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Retailer License " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.RetailerLicense, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Retailer Sales Certificate " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.RetailerSalesTaxCertificate, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Email To " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.EmailTo, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Custom Tax Statement " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Height="70"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.CustomTaxStatement, Mode=TwoWay}" />
                    </Grid>

                </StackPanel>
                <!--#endregion-->

                <!--#region details Right-->
                <StackPanel Grid.Row="0" Grid.Column="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Created Date " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ValueTextBlock}"
                            Text="{x:Bind ViewModel.UiModel.CreatedDate, Mode=OneWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Republic Sales Rep " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ValueTextBlock}"
                            Text="{x:Bind ViewModel.UiModel.OrderMasterData.RepublicSalesRepository, Mode=OneWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Seller's Name " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ValueTextBlock}"
                            Text="{x:Bind ViewModel.UiModel.OrderMasterData.OrderMasterSellerName, Mode=OneWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Sellers Representative Tobacco Permit " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.OrderMasterSellerRepTobacco, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Pre book Ship Date " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <CalendarDatePicker
                            Grid.Column="1"
                            Margin="20,10,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="White"
                            Date="{x:Bind ViewModel.UiModel.PreBookDate, Mode=TwoWay}"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='Date'}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text=" Sales Type " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>


                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ValueTextBlock}"
                            Text="{x:Bind ViewModel.UiModel.SalesType, Mode=OneWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Comments " />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.Comments, Mode=TwoWay}" />
                    </Grid>

                </StackPanel>
                <!--#endregion-->

                <!--#region Add button-->
                <Border
                    x:Name="AddButtonBorder"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,0,90,0"
                    HorizontalAlignment="Right"
                    x:Load="{x:Bind ViewModel.IsEditmode, Mode=OneWay}"
                    Background="Transparent"
                    BorderBrush="Black"
                    BorderThickness="1"
                    CornerRadius="30"
                    Visibility="{x:Bind ViewModel.IsEditmode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <i:Interaction.Behaviors>
                        <core:EventTriggerBehavior EventName="Tapped">
                            <core:InvokeCommandAction Command="{x:Bind ViewModel.AddButtonCommand}" />
                        </core:EventTriggerBehavior>

                    </i:Interaction.Behaviors>
                    <FontIcon
                        Margin="10"
                        FontSize="{StaticResource MediumFontSize}"
                        FontWeight="ExtraBold"
                        Foreground="Black"
                        Glyph="{StaticResource AddIcon}"
                        Style="{StaticResource FontIconStyle}" />
                </Border>
                <!--#endregion-->

                <!--#region Tobacco Grid-->
                <StackPanel
                    Name="TobaccoGrid"
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="90,0"
                    Visibility="{x:Bind ViewModel.IsTobaccoGridVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:Expander HorizontalAlignment="Stretch" IsExpanded="True">
                        <controls:Expander.Header>
                            <TextBlock
                                HorizontalAlignment="Left"
                                FontWeight="Bold"
                                Foreground="{StaticResource CartTextColor}"
                                Text="Tobacco Products" />
                        </controls:Expander.Header>

                        <Grid HorizontalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DE:GridControl
                                x:Name="TobaccoGridControl"
                                Grid.Row="0"
                                x:Load="{x:Bind ViewModel.LoadTobaccoGrid, Mode=OneWay}"
                                AlternationCount="2"
                                AutoGenerateColumns="False"
                                ItemClickCommand="{x:Bind ViewModel.ItemClickCommand}"
                                ItemsSource="{x:Bind ViewModel.TobaccoGridItemSource, Mode=TwoWay}"
                                ShowAutoFilterRow="False"
                                ShowCriteriaInAutoFilterRow="True"
                                ShowGroupPanel="False"
                                ShowGroupedColumns="False"
                                Visibility="{x:Bind ViewModel.IsTobaccoGridVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <DE:GridControl.Columns>
                                    <DE:GridTextColumn
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="DisplayBrandName"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Brand" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTextColumn
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="DisplayStyleName"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Style" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTextColumn
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="DisplayProductName"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTextColumn
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="DisplayProductDesc"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTextColumn
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="DisplayProductQty"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Quantity" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTextColumn
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="DisplayProductUnit"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unit" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTextColumn
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="DisplayProductUnitPrice"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unit Price" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                    <DE:GridTextColumn
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="DisplayProductSubtotal"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Sub Total" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>

                                </DE:GridControl.Columns>
                            </DE:GridControl>

                            <StackPanel
                                Grid.Row="1"
                                HorizontalAlignment="Right"
                                Background="{ThemeResource LoginButtonBackground}">
                                <StackPanel
                                    Padding="10,10,50,10"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="5">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="Sub Total:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="{x:Bind ViewModel.TotalTobacco, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>

                        </Grid>
                    </controls:Expander>
                </StackPanel>
                <!--#endregion-->

                <!--#region  non tobacco gird-->
                <StackPanel
                    Name="nonTobaccoGrid"
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="90,0"
                    Visibility="{x:Bind ViewModel.IsNonTobaccoGridVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:Expander HorizontalAlignment="Stretch" IsExpanded="True">
                        <controls:Expander.Header>
                            <TextBlock
                                HorizontalAlignment="Left"
                                FontWeight="Bold"
                                Foreground="{StaticResource CartTextColor}"
                                Text="NonTobacco Products" />
                        </controls:Expander.Header>

                        <Grid HorizontalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DE:GridControl
