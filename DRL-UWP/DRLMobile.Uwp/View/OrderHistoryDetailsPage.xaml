                </StackPanel>
                <!--#endregion-->

                <!--#region rack pos grid-->
                <Grid Grid.Row="6"
                    Grid.ColumnSpan="2"
                    Margin="80,20,80,0"
                              x:Name="gridRackPosPanel"
                              x:Load="{x:Bind ViewModel.LoadRackPosPopGrid, Mode=OneWay}"
                              >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.Resources>
                        <Style x:Key="GridTxtBlockStyle" TargetType="TextBlock">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="TextWrapping" Value="Wrap" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="10" />
                        </Style>
                    </Grid.Resources>
                    <!--RackPosGrid Header-->
                    <!--gridRackPosPanel.Grid.Row="0"-->
                    <Grid Grid.Row="0" Padding="0" x:Name="grdRackPosHeader">
                        <Grid.ColumnDefinitions>
                            <!--ProductName-->
                            <ColumnDefinition Width="1.5*"/>
                            <!--ProductDescription-->
                            <ColumnDefinition Width="2*"/>
                            <!--Quantity-->
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.Resources>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#FFF2F2F2" />
                                <Setter Property="BorderBrush" Value="Silver" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                            </Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource GridTxtBlockStyle}">
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Foreground" Value="Black" />
                            </Style>
                        </Grid.Resources>
                        <!--1st Row-->
                        <Border Grid.Column="0">
                            <TextBlock  Text="Item"/>
                        </Border>
                        <Border Grid.Column="1">
                            <TextBlock  Text="Item Distribution"/>
                        </Border>
                        <Border Grid.Column="2">
                            <TextBlock  Text="Quantity"/>
                        </Border>
                    </Grid>
                    <!--RackPosGrid Items-->
                    <!--gridRackPosPanel.Grid.Row=1-->
                    <customControl:CustomAlternateRowColorListView Grid.Row="1"
                                x:Name="lstRackPos" Background="#FFFFFF"
                                x:Load="{x:Bind ViewModel.LoadRackPosPopGrid, Mode=OneWay}"
                                ItemsSource="{x:Bind ViewModel.RackPosPopOrderDetailsItemSource, Mode=OneWay}">
                        <ListView.Resources>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListView.Resources>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="model:OrderDetail">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!--ProductName-->
                                        <ColumnDefinition Width="1.5*"/>
                                        <!--ProductDescription-->
                                        <ColumnDefinition Width="2*"/>
                                        <!--Quantity-->
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.Resources>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GridTxtBlockStyle}">
                                            <Setter Property="FontWeight" Value="Normal" />
                                            <Setter Property="Foreground" Value="Gray" />
                                        </Style>
                                    </Grid.Resources>
                                    <TextBlock Text="{x:Bind ProductName, Mode=OneWay}" Grid.Column="0"/>
                                    <TextBlock Text="{x:Bind ProductDescription, Mode=OneWay}" Grid.Column="1"/>
                                    <TextBlock Text="{x:Bind Quantity, Mode=OneWay}" Grid.Column="2"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </customControl:CustomAlternateRowColorListView>
                </Grid>

                <!--#endregion-->

                <!--#region Grand Total-->
                <StackPanel
                    x:Name="grandTotalStackPanel"
                    Grid.Row="7"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="90,2,90,20"
                    HorizontalAlignment="Right"
                    Background="{ThemeResource LoginButtonBackground}"
                    Visibility="{x:Bind ViewModel.IsGrandTotalVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel
                        Padding="10,10,50,10"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="5">
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontWeight="Bold"
                            Foreground="{StaticResource CartTextColor}"
                            Text="Grand Total: " />
                        <TextBlock
                            HorizontalAlignment="Right"
                            Foreground="{StaticResource CartTextColor}"
                            Text="{x:Bind ViewModel.GrandTotalValue, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
                <!--#endregion-->

            </Grid>
        </ScrollViewer>

        <Image
            Grid.Row="2"
            MaxHeight="60"
            Margin="0,10,20,10"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Source="{x:Bind ViewModel.SignPath, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsSignPanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

        <Grid
            Name="PopupScreen"
            Grid.Row="0"
            Grid.RowSpan="4"
            d:Visibility="Collapsed"
            x:Load="{x:Bind ViewModel.IsAddEditPopupVisible, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsAddEditPopupVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid
                Grid.Row="0"
                Grid.RowSpan="2"
                Background="Black"
                Opacity="0.7" />

            <Grid
                MinWidth="700"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="10,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{StaticResource FooterBackgroundColor}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource MediumFontSize}"
                        Foreground="{StaticResource FooterTextColor}"
                        Text="{x:Bind ViewModel.PopupTitle, Mode=OneWay}" />

                    <FontIcon
                        Margin="0,0,10,0"
                        HorizontalAlignment="Right"
                        FontSize="{StaticResource MediumFontSize}"
                        Foreground="{StaticResource FooterTextColor}"
                        Glyph="{StaticResource CancelIcon}"
                        Style="{StaticResource FontIconStyle}">
                        <i:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="Tapped">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.ClosePopupCommand}" />
                            </core:EventTriggerBehavior>

                        </i:Interaction.Behaviors>
                    </FontIcon>
                </Grid>

                <StackPanel
                    Grid.Row="1"
                    Background="{StaticResource LoginBackgroundColor}"
                    CornerRadius="0,0,10,10"
                    Spacing="10">
                    <AutoSuggestBox
                        Name="AutoSuggestBox"
                        Margin="40,10"
                        DisplayMemberPath="SearchDisplayPath"
                        ItemsSource="{x:Bind ViewModel.AddEditUIModel.ProductList, Mode=OneWay}"
                        PlaceholderText="Search by Product Name or Number"
                        QueryIcon="Find"
                        Text="{x:Bind ViewModel.AddEditUIModel.AutoSuggestionText, Mode=TwoWay}"
                        TextMemberPath="SearchDisplayPath"
                        Visibility="{x:Bind ViewModel.IsAdd, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <i:Interaction.Behaviors>
                            <core:EventTriggerBehavior EventName="TextChanged">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.AutoSuggestTextChanged}" CommandParameter="{Binding ElementName=AutoSuggestBox, Path=Text}" />
                            </core:EventTriggerBehavior>

                            <core:EventTriggerBehavior EventName="SuggestionChosen">
                                <core:InvokeCommandAction Command="{x:Bind ViewModel.AutoSuggestSuggestionChoosen}" />
                            </core:EventTriggerBehavior>
                        </i:Interaction.Behaviors>

                    </AutoSuggestBox>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Brand : " />

                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ValueTextBlock}"
                            Text="{x:Bind ViewModel.AddEditUIModel.BrandName, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Style : " />

                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ValueTextBlock}"
                            Text="{x:Bind ViewModel.AddEditUIModel.StyleName, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Product Name : " />

                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ValueTextBlock}"
                            Text="{x:Bind ViewModel.AddEditUIModel.ProductName, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Product Description : " />

                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ValueTextBlock}"
                            Text="{x:Bind ViewModel.AddEditUIModel.ProductDesc, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Quantity : " />

                        <StackPanel Grid.Column="1" Margin="20,0,0,0" Orientation="Horizontal">
                            <TextBox
                              Width="70"
                                Height="40"
                                Margin="0,2,0,0"
                              x:Name="quantityEditText"
                              CornerRadius="10" IsReadOnly="True"
                              Text="{x:Bind ViewModel.AddEditUIModel.Quantity, Mode=OneWay}"
                              Foreground="{StaticResource LoginScreenTextFontColor}">
                            </TextBox>
                            <Image
                                x:Name="quantityImage"
                                Width="15"
                                Height="15"
                                Margin="2,2,0,0"
                                FlyoutBase.AttachedFlyout="{StaticResource CustomKeyPadFlyout}"
                                Tapped="quantityImage_Tapped"
                                Source="{StaticResource EditCart}" />
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Unit : " />

                        <ComboBox
                            Name="UnitComboBox"
                            Grid.Column="1"
                            Width="80"
                            Margin="20,0,0,0"
                            Background="White"
                            BorderBrush="Black"
                            BorderThickness="0.4"
                            Foreground="{StaticResource LoginScreenTextFontColor}"
                            PlaceholderForeground="{StaticResource LoginScreenTextFontColor}"
                            PlaceholderText="{Binding Unit}"
                            SelectedItem="{x:Bind ViewModel.AddEditUIModel.SelectedUom, Mode=TwoWay}">
                            <x:String>CA</x:String>
                            <x:String>BX</x:String>
                            <x:String>EA</x:String>
                            <x:String>IP</x:String>
                            <x:String>BK</x:String>
                        </ComboBox>
                    </Grid>

                    <Grid Visibility="{x:Bind ViewModel.AddEditUIModel.IsCreditRequest, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Credit Request : " />

                        <ComboBox
                            Grid.Column="1"
                            Width="auto"
                            MinWidth="100"
                            Margin="20,0,0,0"
                            Background="White"
                            BorderBrush="Black"
                            BorderThickness="0.4"
                            Foreground="{StaticResource LoginScreenTextFontColor}"
                            ItemsSource="{x:Bind ViewModel.CreditRequestComoBoxSource, Mode=TwoWay}"
                            Visibility="{x:Bind ViewModel.AddEditUIModel.IsCreditRequest, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            SelectionChanged="ComboBox_SelectionChanged">
                            <x:String>DIF-Destroyed</x:String>
                            <x:String>RTN-Retail Returns</x:String>
                            <x:String>RTN-Out Of Code</x:String>
                            <x:String>RTN-Defective</x:String>
                            <x:String>RTN-Overstock</x:String>
                            <x:String>RTN-Discontinued</x:String>
                            <x:String>RTN-Reset</x:String>
                            <x:String>RTN-Mispick</x:String>
                            <x:String>RTN-Misship</x:String>
                            <x:String>RTN-Order Error</x:String>
                        </ComboBox>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Unit Price : " />

                        <StackPanel
                            Grid.Column="1"
                            Margin="20,0,0,0"
                            Orientation="Horizontal">
                            <TextBox
                              Width="70"
                                Height="40"
                                Margin="0,2,0,0"
                              CornerRadius="10" IsReadOnly="True"
                              Text="{x:Bind ViewModel.AddEditUIModel.Price, Mode=OneWay}"
                              Foreground="{StaticResource LoginScreenTextFontColor}">
                            </TextBox>
                            <Image
                                Width="15"
                                Height="15"
                                Margin="2,2,0,0"
                                FlyoutBase.AttachedFlyout="{StaticResource CustomPriceKeyPadFlyout}"
                                Tapped="UnitPriceImage_Tapped"
                                Source="{StaticResource EditCart}" />
                        </StackPanel>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Sub Total : " />

                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource ValueTextBlock}"
                            Text="{x:Bind ViewModel.AddEditUIModel.SubTotal, Mode=TwoWay}" />
                    </Grid>

                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="30">
                        <Button
                            Width="100"
                            Margin="7"
                            Command="{x:Bind ViewModel.SaveDeleteCommand}"
                            CommandParameter="SAVE"
                            Content="Save"
                            Style="{StaticResource LoginButtonStyle}" />
                        <Button
                            Width="100"
                            Margin="7"
                            Command="{x:Bind ViewModel.SaveDeleteCommand}"
                            CommandParameter="DELETE"
                            Content="Delete"
                            Style="{StaticResource LoginButtonStyle}"
                            Visibility="{x:Bind ViewModel.IsAdd, Mode=OneWay, Converter={StaticResource InvertBoolVisibilityConverter}}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <toolkit:Loading
            x:Name="LoadingView"
            Grid.Row="0"
            Grid.RowSpan="3"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
            <controls:Loading.Background>
                <SolidColorBrush Opacity="0.4" Color="Black" />
            </controls:Loading.Background>
            <ProgressRing
                x:Name="ProgressRing"
                x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Foreground="White"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </toolkit:Loading>

    </Grid>

</Page>