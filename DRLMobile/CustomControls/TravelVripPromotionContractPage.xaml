                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Contract Date" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="NumberOfPayments"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="# of Payments" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="FirstPaymentAmount"
                    TextWrapping="WrapWholeWords">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="1st Qtr/1st Half Amount" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="FirstPaymentID"
                    TextWrapping="WrapWholeWords">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="1st Qtr/1st Half Request #" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="SecondPaymentAmount"
                    TextWrapping="WrapWholeWords">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="2nd Qtr/2nd Half Amount" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="SecondPaymentID"
                    TextWrapping="WrapWholeWords">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="2nd Qtr/2nd Half Request #" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="ThirdPaymentAmount"
                    TextWrapping="WrapWholeWords">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="3rd Qtr Amount" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="ThirdPaymentID"
                    TextWrapping="WrapWholeWords">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="3rd Qtr Request #" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="FourthPaymentAmount"
                    TextWrapping="WrapWholeWords">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="4th Qtr Amount" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="FourthPaymentID"
                    TextWrapping="WrapWholeWords">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="4th Qtr Request #" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

            </DE:GridControl.Columns>
        </DE:GridControl>
        <Grid
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{Binding LoadingVisibility}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>
    </Grid>
</UserControl>
