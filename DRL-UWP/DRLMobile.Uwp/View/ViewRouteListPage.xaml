<Page
    x:Class="DRLMobile.Uwp.View.ViewRouteListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:converter="using:DRLMobile.Uwp.Converters"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:map="using:Windows.UI.Xaml.Controls.Maps"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converter:BoolToStyleConverter x:Key="BoolToStyleConverter" />
        <converter:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter" />
    </Page.Resources>

    <Grid x:Name="outerPanel" Background="{StaticResource LoginBackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="1" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <!--#region Page Header-->
        <customControls:HeaderControl
            x:Name="HeaderControl"
            Title="{x:Bind ViewModel.HeaderTitle, Mode=OneWay}"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            DisplayMemberPathValue="SearchDisplayPath"
            IsAutoSuggestBoxVisible="Visible"
            IsPageTitleVisible="Visible"
            ItemList="{x:Bind ViewModel.HeaderSearchItemSource, Mode=TwoWay}"
            PlaceHolderText="Search by customer name or #"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SuggestionChoosenCommand="{x:Bind ViewModel.HeaderSearchSuggestionChoosenCommand}"
            TextValueChangedCommand="{x:Bind ViewModel.HeaderSearchTextChangeCommand}" />
        <!--#endregion-->

        <Button
                Width="100"
                Height="35"
                Margin="20,1,0,1"
                Command="{x:Bind ViewModel.GoolgeRouteButtonCommand}"
                Content="Navigation"
                FontSize="15"
                Foreground="{StaticResource CartTextColor}"
                Style="{StaticResource LoginButtonStyle}" />

        <!--#region Customer List-->
        <StackPanel
            x:Name="CustomerListPanel"
            Grid.Row="1"
            Padding="5,0,5,0"
            Background="White"
            Visibility="Collapsed">
            <!--#region Select All Header-->
            <Grid
                Height="40"
                Padding="10,5,10,5"
                Background="White"
                BorderBrush="{StaticResource LoginBackgroundColor}"
                BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid
                    Grid.Column="0"
                    Width="20"
                    Height="20"
                    Margin="-6,0,0,0"
                    Padding="0"
                    BorderBrush="Gray"
                    BorderThickness="0.5"
                    CornerRadius="5"
                    Style="{x:Bind ViewModel.IsAllChecked, Mode=OneWay,Converter={StaticResource BoolToStyleConverter}, ConverterParameter='RouteCustomerCheckBox'}"
                    Tapped="SelectAllCheckBox_Tapped">
                    <FontIcon
                        FontSize="15"
                        Foreground="White"
                        Glyph="{StaticResource CheckMark}"
                        Style="{StaticResource FontIconStyle}"
                        Visibility="{x:Bind ViewModel.IsAllChecked, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>

                <TextBlock
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FooterFontSize}"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Select All" />
            </Grid>
            <!--#endregion-->

            <GridView
                Name="ListViewGrid"
                AllowDrop="True"
                CanDrag="True"
                CanDragItems="True"
                CanReorderItems="True"
                Foreground="White"
                IsSwipeEnabled="True"
                ItemsSource="{x:Bind ViewModel.RouteDetailsItemSource, Mode=TwoWay}"
                ReorderMode="Enabled"
                ScrollViewer.HorizontalScrollBarVisibility="Visible"
                ScrollViewer.HorizontalScrollMode="Enabled"
                ScrollViewer.VerticalScrollBarVisibility="Visible"
                ScrollViewer.VerticalScrollMode="Enabled"
                SelectionMode="None">
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Margin="7,0,0,0"
                                    HorizontalAlignment="Left"
                                    FontSize="{StaticResource FooterFontSize}"
                                    Foreground="{StaticResource LoginScreenTextFontColor}"
                                    Text="{Binding ListIndex}" />

                                <Grid
                                    Grid.Row="1"
                                    Width="20"
                                    Height="20"
                                    Margin="0,3,0,0"
                                    Padding="0"
                                    BorderBrush="Gray"
                                    BorderThickness="0.5"
                                    CornerRadius="5"
                                    Style="{Binding IsChecked, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='RouteCustomerCheckBox'}"
                                    Tapped="CheckBoxGrid_Tapped">

                                    <FontIcon
                                        FontSize="15"
                                        Foreground="White"
                                        Glyph="{StaticResource CheckMark}"
                                        Style="{StaticResource FontIconStyle}"
                                        Visibility="{Binding IsChecked, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </Grid>

                            <Grid
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                ColumnSpacing="1"
                                RowSpacing="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    HorizontalAlignment="Left"
                                    FontSize="{StaticResource FooterFontSize}"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource CartTextColor}"
                                    Text="{Binding CustomerName}"
                                    TextAlignment="Start"
                                    TextTrimming="CharacterEllipsis" />

                                <TextBlock
                                    Grid.Row="1"
                                    HorizontalAlignment="Left"
                                    FontSize="{StaticResource FooterFontSize}"
                                    Foreground="{StaticResource CartTextColor}"
                                    Text="Non Tobacco Company" />

                                <TextBlock
                                    Grid.Row="2"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontSize="{StaticResource FooterFontSize}"
                                    Foreground="{StaticResource CartTextColor}"
                                    Text="{Binding CustomerAddress}"
                                    TextTrimming="CharacterEllipsis" />
                            </Grid>

                        </Grid>

                        <!--<StackPanel
                            Width="250"
                            Margin="10,10,10,0"
                            VerticalAlignment="Stretch"
                            Background="AntiqueWhite"
                            Orientation="Horizontal">
                            <StackPanel
                                Width="30"
                                Padding="0"
                                Spacing="0">
                                <TextBlock
                                    Margin="7,0,0,0"
                                    HorizontalAlignment="Left"
                                    FontSize="{StaticResource FooterFontSize}"
                                    Foreground="{StaticResource LoginScreenTextFontColor}"
                                    Text="{Binding ListIndex}" />
                                <Grid
                                    Width="20"
                                    Height="20"
                                    Margin="0,3,0,0"
                                    Padding="0"
                                    BorderBrush="Gray"
                                    BorderThickness="0.5"
                                    CornerRadius="5"
                                    Style="{Binding IsChecked, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='RouteCustomerCheckBox'}"
                                    Tapped="CheckBoxGrid_Tapped">

                                    <FontIcon
                                        FontSize="15"
                                        Foreground="White"
                                        Glyph="{StaticResource CheckMark}"
                                        Style="{StaticResource FontIconStyle}"
                                        Visibility="{Binding IsChecked, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                        -->
                        <!--<CheckBox Width="10" IsChecked="{Binding IsChecked,Mode=TwoWay}" />-->
                        <!--
                            </StackPanel>
                            <StackPanel
                                Margin="5,0,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Left"
                                    FontSize="{StaticResource FooterFontSize}"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource CartTextColor}"
                                    Text="{Binding CustomerName}"
                                    TextAlignment="Start"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    HorizontalAlignment="Left"
                                    FontSize="{StaticResource FooterFontSize}"
                                    Foreground="{StaticResource CartTextColor}"
                                    Text="Non Tobacco Company" />
                                <Grid Background="Azure">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource FooterFontSize}"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="{Binding CustomerAddress}"
                                        TextWrapping="WrapWholeWords" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>-->
                    </DataTemplate>
                </GridView.ItemTemplate>
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid MaximumRowsOrColumns="2" Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
            </GridView>
            <Rectangle
                Height="1"
                HorizontalAlignment="Stretch"
                Fill="{StaticResource LoginButtonBackground}" />
        </StackPanel>
        <!--#endregion-->

        <!--#region Start End Calculation Panel-->
        <Grid
            Grid.Row="2"
            Padding="15"
            Background="White">
            <Grid.ColumnDefinitions>
                <!--  0: Start label  -->
                <ColumnDefinition Width="Auto" />
                <!--  1: Start TextBox  -->
                <ColumnDefinition Width="*" />
                <!--  2: "Or" button  -->
                <ColumnDefinition Width="Auto" />
                <!--  3: "Use Current Location" text  -->
                <ColumnDefinition Width="Auto" />
                <!--  4: Start ToggleSwitch  -->
                <ColumnDefinition Width="Auto" />
                <!--  5: Vertical separator + "End" label  -->
                <ColumnDefinition Width="Auto" />
                <!--  6: End TextBox  -->
                <ColumnDefinition Width="*" />
                <!--  7: "Or" button (End)  -->
                <ColumnDefinition Width="Auto" />
                <!--  8: "Use Current Location" text (End)  -->
                <ColumnDefinition Width="Auto" />
                <!--  9: End ToggleSwitch  -->
                <ColumnDefinition Width="Auto" />
                <!--  10: Calculate button  -->
                <ColumnDefinition Width="Auto" />
                <!--  Total: 11 columns (0 to 10)  -->
            </Grid.ColumnDefinitions>

            <!--  Start Label  -->
            <TextBlock
                Grid.Column="0"
                Margin="0,-5,0,0"
                VerticalAlignment="Center"
                FontSize="{StaticResource LightFontSize}"
                FontWeight="Medium"
                Foreground="{StaticResource CartTextColor}"
                Text="Start" />

            <!--  Start TextBox  -->
            <TextBox
                x:Name="StartTextBox"
                Grid.Column="1"
                Margin="5,-5,0,0"
                Background="Transparent"
                BorderBrush="{StaticResource LoginBackgroundColor}"
                BorderThickness="1"
                PlaceholderText="Enter zip or address"
                Text="{x:Bind ViewModel.StartLocation, Mode=TwoWay}" />

            <!--  "Or" Button (Start)  -->
            <Grid
                Grid.Column="2"
                Margin="10,-6,0,0"
                Background="{StaticResource LoginButtonBackground}"
                CornerRadius="20">
                <TextBlock
                    Margin="0,-5,0,0"
                    Padding="10,2,10,2"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource LightFontSize}"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Or" />
            </Grid>

            <!--  "Use Current Location" Text (Start)  -->
            <TextBlock
                Grid.Column="3"
                Margin="10,-5,0,0"
                VerticalAlignment="Center"
                FontSize="{StaticResource LightFontSize}"
                FontWeight="Medium"
                Foreground="{StaticResource CartTextColor}"
                Text="Use Current Location" />

            <!--  Start ToggleSwitch  -->
            <StackPanel
                Grid.Column="4"
                MaxWidth="40"
                Margin="6,-4,0,0"
                VerticalAlignment="Top"
                Orientation="Horizontal">
                <ToggleSwitch
                    x:Name="StartLocationSwitch"
                    OffContent=""
                    OnContent=""
                    Toggled="StartLocationSwitch_Toggled" />
            </StackPanel>

            <!--  Vertical Separator + End Label  -->
            <StackPanel
                Grid.Column="5"
                Margin="6,-6,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,6,0"
                    VerticalAlignment="Top"
                    FontSize="{StaticResource LoginScreenLargeText}"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="|" />
                <TextBlock
                    FontSize="{StaticResource LightFontSize}"
                    FontWeight="Medium"
                    Foreground="{StaticResource CartTextColor}"
                    Text="End" />
            </StackPanel>

            <!--  End TextBox  -->
            <TextBox
                x:Name="EndTextBox"
                Grid.Column="6"
                Margin="8,-5,0,0"
                Background="Transparent"
                BorderBrush="{StaticResource LoginBackgroundColor}"
                BorderThickness="1"
                PlaceholderText="Enter zip or address"
                Text="{x:Bind ViewModel.EndLocation, Mode=TwoWay}" />

            <!--  "Or" Button (End)  -->
            <Grid
                Grid.Column="7"
                Margin="10,-6,0,0"
                Background="{StaticResource LoginButtonBackground}"
                CornerRadius="20">
                <TextBlock
                    Margin="0,-5,0,0"
                    Padding="10,2,10,2"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource LightFontSize}"
                    FontWeight="Medium"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Or" />
            </Grid>

            <!--  "Use Current Location" Text (End)  -->
            <TextBlock
                Grid.Column="8"
                Margin="10,-5,0,0"
                VerticalAlignment="Center"
                FontSize="{StaticResource LightFontSize}"
                FontWeight="Medium"
                Foreground="{StaticResource CartTextColor}"
                Text="Use Current Location" />

            <!--  End ToggleSwitch  -->
            <StackPanel
                Grid.Column="9"
                MaxWidth="40"
                Margin="6,-4,0,0"
                VerticalAlignment="Top"
                Orientation="Horizontal">
                <ToggleSwitch
                    x:Name="EndLocationSwitch"
                    OffContent=""
                    OnContent=""
                    Toggled="EndLocationSwitch_Toggled" />
            </StackPanel>

            <!--  Calculate Button  -->
            <Button
                Grid.Column="10"
                Width="110"
                Height="35"
                Margin="6,-6,0,0"
                Click="CalculateButton_Click"
                Content="Calculate"
                FontSize="16"
                FontWeight="Medium"
                Foreground="{StaticResource CartTextColor}"
                Style="{StaticResource LoginButtonStyle}" />
        </Grid>
        <!--#endregion-->

        <!--#region Separator-->
        <Rectangle
            Grid.Row="3"
            Height="1"
            HorizontalAlignment="Stretch"
            Fill="{StaticResource LoginButtonBorderBrush}" />
        <!--#endregion-->

        <!--#region Expand Collapse Button-->
        <Button
            x:Name="DownArrowButton"
            Grid.Row="4"
            Margin="0,0,0,0"
            Padding="15,10,15,0"
            HorizontalAlignment="Right"
            Background="{StaticResource FooterTextColor}"
            Tapped="DownArrowButton_Tapped">
            <FontIcon
                x:Name="DownArrow"
                VerticalAlignment="Stretch"
                Foreground="{StaticResource FooterBackgroundColor}"
                Style="{StaticResource FontIconStyle}" />
        </Button>
        <!--#endregion-->

        <!--#region MapControl-->
        <map:MapControl
            x:Name="myMap"
            Grid.Row="5"
            MapElementClick="myMap_MapElementClick"
            MapServiceToken="{StaticResource MapServiceKey}"
            TransitFeaturesVisible="False"
            ZoomLevel="19">
            <map:MapItemsControl x:Name="MapItems" ItemsSource="{x:Bind ViewModel.PointOfIntrestSource, Mode=OneWay}" />
        </map:MapControl>
        <Grid
            Grid.Row="5"
            Grid.RowSpan="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="{x:Bind ViewModel.CustomMapPinVisibility, Mode=TwoWay}">
            <Grid Background="Black" Opacity="1" />
            <customControls:MapPinCustomPopUp x:Name="customMapPinPopup" CloseCommad="{x:Bind ViewModel.CloseCustomMapPushPinCommand, Mode=OneWay}" />
        </Grid>
        <!--#endregion-->

        <!--#region Edit, Delete, Navigation Buttons-->
        <StackPanel
            Name="stkbutton"
            Grid.Row="6"
            HorizontalAlignment="Center"
            Orientation="Horizontal"
            Visibility="{x:Bind ViewModel.CustomMapPinIsVisible, Mode=OneWay, Converter={StaticResource InvertBoolToVisibilityConverter}}">
            <Button
                Width="100"
                Height="35"
                Margin="20,1,0,1"
                Command="{x:Bind ViewModel.EditButtonCommand}"
                Content="Edit"
                FontSize="15"
                Foreground="{StaticResource CartTextColor}"
                Style="{StaticResource LoginButtonStyle}"
                Visibility="{x:Bind ViewModel.IsEditIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            <Button
                Width="100"
                Height="35"
                Margin="20,1,0,1"
                Command="{x:Bind ViewModel.DeleteButtonCommand}"
                Content="Delete"
                FontSize="15"
                Foreground="{StaticResource CartTextColor}"
                Style="{StaticResource LoginButtonStyle}"
                Visibility="{x:Bind ViewModel.IsDeleteIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            <Button
                Width="100"
                Height="35"
                Margin="20,1,0,1"
                Command="{x:Bind ViewModel.GoolgeRouteButtonCommand}"
                Content="Google Map"
                FontSize="15"
                Foreground="{StaticResource CartTextColor}"
                Style="{StaticResource LoginButtonStyle}" />
            <Button
                Width="100"
                Height="35"
                Margin="20,1,0,1"
                Command="{x:Bind ViewModel.NavigationButtonCommand}"
                Content="Navigation"
                FontSize="15"
                Foreground="{StaticResource CartTextColor}"
                Style="{StaticResource LoginButtonStyle}" />
        </StackPanel>
        <!--#endregion-->

        <!--#region Loader-->
        <Grid
            Grid.Row="1"
            Grid.RowSpan="6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{Binding LoadingVisibility}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>
        <!--#endregion-->
    </Grid>
</Page>