<Page
    x:Class="DRLMobile.Uwp.View.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Microsoft.Xaml.Interactions.Core"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:DRLMobile.Uwp.View"
    xmlns:localConverter="using:DRLMobile.Uwp.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uimodels="using:DRLMobile.Core.Models.UIModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <localConverter:VisibilityToBoolConverter x:Key="VisibilityToBoolConverter" />
    </Page.Resources>
    <Grid x:Name="outerPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <customControls:HeaderControl
            Title="DASHBOARD"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            ButtonClick="{x:Bind ViewModel.LogoutButtonCommand}"
            IsAutoSuggestBoxVisible="Collapsed"
            IsComboBoxVisible="Collapsed"
            IsCustomerPanelVisible="Collapsed"
            IsCustomerTitlePanelVisible="Collapsed"
            IsLogOutButtonVisible="Visible"
            IsPageTitleVisible="Visible" />

        <StackPanel
            x:Name="AssignedAreaStackPanel"
            Grid.Row="1"
            Margin="20,0,0,10"
            VerticalAlignment="Top"
            x:Load="{x:Bind ViewModel.IsAnyAssignedUserAreas, Mode=OneWay}"
            Orientation="Horizontal">
            <TextBlock
                Name="AssignedAreaTextBlock"
                Margin="0,0,6,0"
                FontWeight="SemiBold"
                Text="{x:Bind ViewModel.LblAssignedUserAreas, Mode=OneWay}" />
            <ComboBox
                Name="AssignedAreaComboBox"
                Width="200"
                Margin="0,6,2,0"
                ItemsSource="{x:Bind ViewModel.AssignedUserAreas, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedUserArea, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>

                <interactivity:Interaction.Behaviors>
                    <core:EventTriggerBehavior EventName="SelectionChanged">
                        <core:InvokeCommandAction Command="{x:Bind ViewModel.AssignedAreaCommand, Mode=OneWay}" CommandParameter="{x:Bind ViewModel.SelectedUserArea, Mode=OneWay}" />
                    </core:EventTriggerBehavior>
                </interactivity:Interaction.Behaviors>

            </ComboBox>
        </StackPanel>

        <Grid
            Grid.Row="1"
            Margin="0,30,0,30"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            ColumnSpacing="80"
            RowSpacing="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <customControls:DashboardButton
                x:Uid="Dashboard_Src_Product"
                Grid.Row="0"
                Grid.Column="0"
                ButtonClick="{x:Bind ViewModel.SrcProductCommand}"
                HoverStateImageSource="{StaticResource SrcHover}"
                NormalStateImageSource="{StaticResource SrcNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Cart"
                Grid.Row="0"
                Grid.Column="1"
                BadgeText="{x:Bind ViewModel.BadgeText}"
                ButtonClick="{x:Bind ViewModel.CartCommand}"
                HoverStateImageSource="{StaticResource CartHover}"
                IsBadgeVisible="Visible"
                NormalStateImageSource="{StaticResource CartNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Customer"
                Grid.Row="0"
                Grid.Column="2"
                ButtonClick="{x:Bind ViewModel.CustomerCommand}"
                HoverStateImageSource="{StaticResource CustomerHover}"
                NormalStateImageSource="{StaticResource CustomerNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Favorite"
                Grid.Row="1"
                Grid.Column="0"
                ButtonClick="{x:Bind ViewModel.FavoriteCommand}"
                HoverStateImageSource="{StaticResource FavoriteHover}"
                NormalStateImageSource="{StaticResource FavoriteNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Route_List"
                Grid.Row="1"
                Grid.Column="1"
                ButtonClick="{x:Bind ViewModel.RouteListCommand}"
                HoverStateImageSource="{StaticResource RoutListHover}"
                NormalStateImageSource="{StaticResource RouteListNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Settings"
                Grid.Row="1"
                Grid.Column="2"
                BadgeText="!"
                ButtonClick="{x:Bind ViewModel.SettingCommand}"
                HoverStateImageSource="{StaticResource SettingHover}"
                IsBadgeVisible="{x:Bind ViewModel.Badgetextupdate}"
                NormalStateImageSource="{StaticResource SettingNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Activities"
                Grid.Row="2"
                Grid.Column="0"
                ButtonClick="{x:Bind ViewModel.ActivityCommand}"
                HoverStateImageSource="{StaticResource ActivitiesHover}"
                NormalStateImageSource="{StaticResource ActivitiesNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Map"
                Grid.Row="2"
                Grid.Column="1"
                ButtonClick="{x:Bind ViewModel.MapCommand}"
                HoverStateImageSource="{StaticResource MapHover}"
                NormalStateImageSource="{StaticResource MapNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Sync"
                Grid.Row="2"
                Grid.Column="2"
                ButtonClick="{x:Bind ViewModel.SyncButtonCommand}"
                HoverStateImageSource="{StaticResource SyncHover}"
                NormalStateImageSource="{StaticResource SyncNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Rack_Order"
                Grid.Row="3"
                Grid.Column="0"
                ButtonClick="{x:Bind ViewModel.RackOrderCommand}"
                HoverStateImageSource="{StaticResource RackOrderHover}"
                NormalStateImageSource="{StaticResource RackOrderNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Pop_Order"
                Grid.Row="3"
                Grid.Column="1"
                ButtonClick="{x:Bind ViewModel.PopOrderCommand}"
                HoverStateImageSource="{StaticResource PopOrderHover}"
                NormalStateImageSource="{StaticResource PopOrderNormal}" />

            <customControls:DashboardButton
                x:Uid="Dashboard_Travel_Vrip"
                Grid.Row="3"
                Grid.Column="2"
                ButtonClick="{x:Bind ViewModel.TravelVripButtonCommand}"
                HoverStateImageSource="{StaticResource TravelHover}"
                NormalStateImageSource="{StaticResource TravelNormal}" />

            <customControls:DashboardButton 
    Grid.Row="4"
    Grid.Column="0"
    ButtonClick="{x:Bind ViewModel.GoogleMapCommand}"
    HoverStateImageSource="{StaticResource RackOrderHover}"
    NormalStateImageSource="{StaticResource RackOrderNormal}" />

            <customControls:DashboardButton
    Grid.Row="4"
    Grid.Column="1"
    ButtonClick="{x:Bind ViewModel.POCAzureMapCommand}"
    HoverStateImageSource="{StaticResource PopOrderHover}"
    NormalStateImageSource="{StaticResource PopOrderNormal}" />

            <!--<customControls:DashboardButton
    Grid.Row="4"
    Grid.Column="0"
    ButtonClick="{x:Bind ViewModel.AzureMapCommand}"
    HoverStateImageSource="{StaticResource PopOrderHover}"
    NormalStateImageSource="{StaticResource PopOrderNormal}" />


            <customControls:DashboardButton
    Grid.Row="4"
    Grid.Column="0"
    ButtonClick="{x:Bind ViewModel.AzureRouteMapCommand}"
    HoverStateImageSource="{StaticResource PopOrderHover}"
    NormalStateImageSource="{StaticResource PopOrderNormal}" />-->


        </Grid>

        <Grid
            x:Name="ProgressRingGrid"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            x:Load="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay, Converter={StaticResource VisibilityToBoolConverter}}"
            Background="Black"
            Opacity="0.7">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>

    </Grid>
</Page>
