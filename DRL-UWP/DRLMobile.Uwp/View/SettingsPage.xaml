<Page
    x:Class="DRLMobile.Uwp.View.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:DRLMobile.Uwp.Converters"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DRLMobile.Uwp.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:Microsoft.Toolkit.Uwp.UI"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>

            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

            <Style x:Key="NoHoverButton" TargetType="Button">
                <Setter Property="CornerRadius" Value="5" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Height" Value="40" />
                <Setter Property="Width" Value="{StaticResource LoginButtonDefaultWidth}" />
                <Setter Property="Background" Value="{ThemeResource LoginButtonBackground}" />
                <Setter Property="BackgroundSizing" Value="OuterBorderEdge" />
                <Setter Property="Foreground" Value="{ThemeResource LoginScreenTextFontColor}" />
                <Setter Property="BorderBrush" Value="{ThemeResource LoginButtonBorderBrush}" />
                <Setter Property="BorderThickness" Value="{ThemeResource DefaultBorderThikness}" />
                <Setter Property="Padding" Value="{StaticResource ButtonPadding}" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontFamily" Value="{ThemeResource ContentControlThemeFontFamily}" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="FontSize" Value="{ThemeResource MediumFontSize}" />
                <Setter Property="UseSystemFocusVisuals" Value="{StaticResource UseSystemFocusVisuals}" />
                <Setter Property="FocusVisualMargin" Value="-3" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                AutomationProperties.AccessibilityView="Raw"
                                Background="{TemplateBinding Background}"
                                BackgroundSizing="{TemplateBinding BackgroundSizing}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                ContentTransitions="{TemplateBinding ContentTransitions}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform />
                                </ContentPresenter.RenderTransform>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <PointerUpThemeAnimation Storyboard.TargetName="ContentPresenter" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver" />
                                        <VisualState x:Name="Pressed">
                                            <Storyboard Duration="0:0:0.1">
                                                <DoubleAnimation
                                                    Storyboard.TargetName="ContentPresenter"
                                                    Storyboard.TargetProperty="(ContentPresenter.RenderTransform).(ScaleTransform.ScaleX)"
                                                    From="1"
                                                    To="0.95"
                                                    Duration="0:0:0.1" />
                                                <DoubleAnimation
                                                    Storyboard.TargetName="ContentPresenter"
                                                    Storyboard.TargetProperty="(ContentPresenter.RenderTransform).(ScaleTransform.ScaleY)"
                                                    From="1"
                                                    To="0.95"
                                                    Duration="0:0:0.1" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ButtonBackgroundDisabled}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="BorderBrush">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ButtonBorderBrushDisabled}" />
                                                </ObjectAnimationUsingKeyFrames>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource ButtonForegroundDisabled}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </ContentPresenter>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="outerPanel" Background="{StaticResource LoginBackgroundColor}">

        <FlyoutBase.AttachedFlyout>
            <Flyout
                x:Name="ChangePinFlyout"
                LightDismissOverlayMode="Auto"
                Placement="Full"
                ShowMode="Auto">
                <Flyout.FlyoutPresenterStyle>
                    <Style TargetType="FlyoutPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </Flyout.FlyoutPresenterStyle>
                <Grid
                    Margin="20"
                    Background="LightGray"
                    BorderBrush="Black"
                    BorderThickness="1"
                    CornerRadius="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Grid
                        Grid.Row="0"
                        Height="50"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource FooterBackgroundColor}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource LargeFontSize}"
                            Foreground="White"
                            Text="Change Pin" />
                    </Grid>

                    <StackPanel
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">


                        <TextBlock Margin="20,10,0,0" Text="Enter Current PIN" />
                        <TextBox
                            ui:TextBoxExtensions.Regex="^[0-9]*$"
                            ui:TextBoxExtensions.ValidationMode="Forced"
                            ui:TextBoxExtensions.ValidationType="Number"
                            BeforeTextChanging="TextBox_BeforeTextChanging"
                            Foreground="Black"
                            MaxLength="6"
                            PlaceholderText="Enter Current PIN"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind ViewModel.OldPinText, Mode=TwoWay}" />
                        <TextBlock
                            Margin="20,10,0,0"
                            FontSize="12"
                            Foreground="Red"
                            Text="{x:Bind ViewModel.ErrorForOldPinText, Mode=TwoWay}"
                            TextWrapping="Wrap" />
                        <TextBlock Margin="20,40,0,0" Text="Enter New PIN" />
                        <TextBox
                            ui:TextBoxExtensions.Regex="^[0-9]*$"
                            ui:TextBoxExtensions.ValidationMode="Forced"
                            ui:TextBoxExtensions.ValidationType="Number"
                            BeforeTextChanging="TextBox_BeforeTextChanging"
                            Foreground="Black"
                            MaxLength="6"
                            PlaceholderText="Enter New PIN"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind ViewModel.NewPinText, Mode=TwoWay}" />
                        <TextBlock
                            Margin="20,10,0,0"
                            FontSize="12"
                            Foreground="Red"
                            Text="{x:Bind ViewModel.ErrorForNewPinText, Mode=TwoWay}"
                            TextWrapping="Wrap" />
                        <TextBlock Margin="20,40,0,0" Text="Confirm PIN" />
                        <TextBox
                            ui:TextBoxExtensions.Regex="^[0-9]*$"
                            ui:TextBoxExtensions.ValidationMode="Forced"
                            ui:TextBoxExtensions.ValidationType="Number"
                            BeforeTextChanging="TextBox_BeforeTextChanging"
                            Foreground="Black"
                            MaxLength="6"
                            PlaceholderText="Confirm PIN"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind ViewModel.ConfirmNewPinText, Mode=TwoWay}" />
                        <TextBlock
                            Margin="20,10,0,0"
                            FontSize="12"
                            Foreground="Red"
                            Text="{x:Bind ViewModel.ErrorForConfirmNewPinText, Mode=TwoWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Button
                        Grid.Row="2"
                        Margin="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="SaveButtonClicked"
                        Content="Save"
                        Foreground="White"
                        Style="{StaticResource NoHoverButton}">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Offset="0.0" Color="#0a7df0" />
                                <GradientStop Offset="1.0" Color="#1fd9f4" />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Grid>
            </Flyout>
        </FlyoutBase.AttachedFlyout>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <customControls:HeaderControl
            Title="SETTINGS"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            IsPageTitleVisible="Visible" />

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Vertical"
            Spacing="50">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="100">
                <customControls:DashboardButton
                    FontSize="{StaticResource MediumFontSize}"
                    HoverStateImageSource="{StaticResource ChangePinHover}"
                    NormalStateImageSource="{StaticResource ChangePinNormal}"
                    Tapped="ChangePinButton_Tapped"
                    TitleFontSize="{StaticResource SettingPageTextSize}"
                    TitleText="Change Pin" />
                <customControls:DashboardButton
                    ButtonClick="{x:Bind ViewModel.CustomTaxStatementCommand}"
                    FontSize="{StaticResource MediumFontSize}"
                    HoverStateImageSource="{StaticResource TaxStatementHover}"
                    NormalStateImageSource="{StaticResource TaxStatementNormal}"
                    TitleFontSize="{StaticResource SettingPageTextSize}"
                    TitleText="Custom Tax Statement" />
                <customControls:DashboardButton
                    ButtonClick="{x:Bind ViewModel.LogoutCommand}"
                    FontSize="{StaticResource MediumFontSize}"
                    NormalStateImageSource="{StaticResource LogoutNormal}"
                    TitleFontSize="{StaticResource SettingPageTextSize}"
                    TitleText="Logout" />
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" Spacing="20">
                <Button
                    Command="{x:Bind ViewModel.ResetUserComand}"
                    Content="Reset User File"
                    Style="{StaticResource LoginButtonStyle}"
                    Width="180"/>
                <Button                    
                    Command="{x:Bind ViewModel.DownloadSRCZipCommand}"                    
                    Content="Download SRC"                    
                    Style="{StaticResource LoginButtonStyle}" 
                    Width="180"/>
                <Button
                    Command="{x:Bind ViewModel.DownloadCustomerDocumentsCommand}"
                    Content="Download Customer Documents"
                    Style="{StaticResource LoginButtonStyle}"
                    Width="260"/>
                <Button
                    Command="{x:Bind ViewModel.SendLogsCommand}"
                    Content="Send Logs"
                    Style="{StaticResource LoginButtonStyle}"
                    Width="180"/>
                <Button
                    Command="{x:Bind ViewModel.InstallBuildCommand}"
                    Content="Update App"
                    Foreground="White"
                    Style="{StaticResource LoginButtonStyle}"
                    Visibility="{x:Bind ViewModel.IsUpgradeVersion}"
                    Width="180">
                    <Button.Background>
                        <SolidColorBrush Color="Red"/>
                    </Button.Background>
                </Button>
                <!--<Button
                    Visibility="Collapsed"
                    Command="{x:Bind ViewModel.ResetSqlLiteArchiveFlagCommand}"
                    Content="Reset DB Archive Flag"
                    Style="{StaticResource LoginButtonStyle}"
                    Width="180"/>
                <Button
                    Command="{x:Bind ViewModel.UpdateAppComand}"
                    Content="Update Application"
                    Style="{StaticResource LoginButtonStyle}"
                    Visibility="{x:Bind ViewModel.IsUpdateAvailable, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}" 
                    Width="200"/>-->
            </StackPanel>

        </StackPanel>
        
        <Grid
            Grid.Row="0"
            Grid.RowSpan="3"
            d:Visibility="Collapsed"
            Visibility="{x:Bind ViewModel.IsInProgress, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Background="Black" Opacity="0.8" />
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="30">
                <ProgressBar
                    Width="500"
                    Background="White"
                    Foreground="Green"
                    IsIndeterminate="False"
                    Visibility="{x:Bind ViewModel.IsSrcZipProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    Value="{x:Bind ViewModel.BackgroundDownloadService.Percentage, Mode=OneWay}" />
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource LargeFontSize}"
                    Foreground="White"
                    Text="{x:Bind ViewModel.BackgroundDownloadService.PercentageString, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsSrcZipProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <ProgressRing
                    Width="100"
                    Height="100"
                    Foreground="White"
                    IsActive="{x:Bind ViewModel.IsInProgress, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsAppUpdateProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <TextBlock
                    FontSize="{StaticResource LargeFontSize}"
                    Foreground="White"
                    Text="Download In Progress"
                    TextWrapping="Wrap"
                    Visibility="{x:Bind ViewModel.IsAppUpdateProgressVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Grid>

        <Grid
            Grid.Row="0"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}">

            <Grid Background="Black" Opacity="0.3" />
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>

    </Grid>
</Page>

