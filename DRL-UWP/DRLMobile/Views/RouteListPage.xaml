                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>


                </DE:GridTextColumn>
                <DE:GridTemplateColumn
                    x:Name="ellipsis"
                    Width="60"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="IsEllipsisVisible"
                    Visible="True">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid
                                Name="ellipsisGrid"
                                Tapped="ellipsisGrid_Tapped"
                                Visibility="{Binding IsEllipsisVisible, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}">

                                <FontIcon
                                    x:Name="EllipsisImage"
                                    Width="20"
                                    Height="30"
                                    FontWeight="ExtraBold"
                                    Glyph="{StaticResource EllipsisIcon}"
