<Page
    x:Class="DRLMobile.Uwp.View.RouteListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DRLMobile.Uwp.View" NavigationCacheMode="Required"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="Black" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="outerPanel" Background="{StaticResource LoginBackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="2" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <customControls:HeaderControl
            x:Name="HeaderControl"
            Title="ROUTES LIST"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            DisplayMemberPathValue="SearchDisplayPath"
            IsAutoSuggestBoxVisible="Visible"
            IsPageTitleVisible="Visible"
            ItemList="{x:Bind routeListPageViewModel.HeaderSearchItemSource, Mode=TwoWay}"
            PlaceHolderText="Search by route name or destination"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SuggestionChoosenCommand="{x:Bind routeListPageViewModel.HeaderSearchSuggestionChoosenCommand}"
            TextValueChangedCommand="{x:Bind routeListPageViewModel.HeaderSearchTextChangeCommand}" />

        <StackPanel
            x:Name="datePickerPanel"
            x:Load="False"
            Grid.Row="1"
            Padding="20"
            Orientation="Horizontal"
            Visibility="Collapsed">
            <TextBlock
                Margin="40,0,0,0"
                VerticalAlignment="Top"
                FontSize="{StaticResource MediumFontSize}"
                FontWeight="SemiBold"
                Foreground="{StaticResource CartTextColor}"
                Text="Start Date:" 
                 Visibility="Collapsed"/>
            <CalendarDatePicker
                x:Name="startDatePicker"
                Width="150"
                Margin="10,-8,0,0"
                Background="Transparent"
                DateFormat="{}{month.integer(2)}/{day.integer(2)}/{year.full}"
                PlaceholderText="Start Date" 
                 Visibility="Collapsed"/>
            <TextBlock
                Margin="40,-1,0,0"
                VerticalAlignment="Top"
                FontSize="{StaticResource MediumFontSize}"
                FontWeight="SemiBold"
                Foreground="{StaticResource CartTextColor}"
                Text="End Date:" 
                 Visibility="Collapsed"/>
            <CalendarDatePicker
                x:Name="endDatePicker"
                Width="150"
                Margin="10,-8,0,0"
                Background="Transparent"
                DateFormat="{}{month.integer(2)}/{day.integer(2)}/{year.full}"
                PlaceholderText="End Date" 
                 Visibility="Collapsed"/>
            <Button
                Width="90"
                Height="35"
                Margin="50,-6,0,0"
                Click="ClearDatesButton_Click"
                Content="Clear"
                FontSize="15"
                Style="{StaticResource LoginButtonStyle}"
                 Visibility="Collapsed"/>
        </StackPanel>

        <Rectangle
            Grid.Row="2"
            Height="2"
            HorizontalAlignment="Stretch"
            Fill="{StaticResource LoginButtonBorderBrush}" />

        <DE:GridControl
            x:Name="routeListDataGrid"
            Grid.Row="3"
            AlternationCount="2"
            AutoGenerateColumns="False"
            FontSize="{StaticResource DataGridTextSize}"
            ItemsSource="{x:Bind routeListPageViewModel.RouteListItemSource, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ShowAutoFilterRow="True"
            ShowCriteriaInAutoFilterRow="True"
            ShowGroupPanel="False"
            ShowGroupedColumns="False"
            ShowSearchPanelMode="Never"
            EndSorting="routeListDataGrid_EndSorting">
            <DE:GridControl.Columns>
                <DE:GridTextColumn
                    MinWidth="200"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="RouteName"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="ROUTE NAME" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>
                <DE:GridTextColumn
                    MinWidth="200"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="RouteBrief"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="ROUTE DESCRIPTION" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridDateColumn
                    AllowSorting="True"
                    AutoFilterCriteria="{x:Null}"
                    ShowCriteriaInAutoFilterRow="False"
                    FieldName="RouteStartDate"
                    Mask="MM/dd/yyy"
                    SortMode="Value"
                    TextWrapping="NoWrap">
                    <DE:GridDateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="START DATE" />
                        </DataTemplate>
                    </DE:GridDateColumn.HeaderTemplate>
                </DE:GridDateColumn>

                <DE:GridDateColumn
                    AllowSorting="True"
                    AutoFilterCriteria="{x:Null}"
                    ShowCriteriaInAutoFilterRow="False"
                    FieldName="RouteEndDate"
                    Mask="MM/dd/yyy"
                    SortMode="Value"
                    TextWrapping="Wrap">
                    <DE:GridDateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="END DATE" />
                        </DataTemplate>
                    </DE:GridDateColumn.HeaderTemplate>
                </DE:GridDateColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="TerritoryName"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="TERR NAME" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="CreatorName"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="CREATOR" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="UserName"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="ASSIGNED TO" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTemplateColumn
                    x:Name="editRouteColumn"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="EditRouteImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="EDIT" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid x:Name="editRoute" Tapped="editRoute_Tapped" Visibility="{Binding EditIconVisibility}">
                                <FontIcon Glyph="{StaticResource EditIcon}" Style="{StaticResource FontIconStyle}" />
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTemplateColumn
                    x:Name="viewRouteColumn"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="True"
                    FieldName="ViewRouteImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="VIEW" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid x:Name="viewRoute" Tapped="viewRoute_Tapped">
                                <FontIcon Glyph="{StaticResource PreviewIcon}" Style="{StaticResource FontIconStyle}" />
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>
            </DE:GridControl.Columns>
        </DE:GridControl>

        <Grid Grid.Row="4">
            <Button
                Height="33"
                Margin="{StaticResource XSmallLeftTopRightBottomMargin}"
                HorizontalAlignment="Center"
                Command="{x:Bind routeListPageViewModel.AddRouteCommnd}"
                Content="Add Route"
                FontSize="15"
                Style="{StaticResource LoginButtonStyle}" />
        </Grid>

        <Grid
            Grid.Row="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{Binding LoadingVisibility}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>

    </Grid>
</Page>
