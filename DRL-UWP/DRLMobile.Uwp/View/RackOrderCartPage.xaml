<Page
    x:Class="DRLMobile.Uwp.View.RackOrderCartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DRLMobile.Uwp.View"
    xmlns:localConverter="using:DRLMobile.Uwp.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:Editors="using:DevExpress.UI.Xaml.Editors"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource CartTextColor}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
        <Flyout
            x:Key="CustomKeyPadFlyout"
            x:Name="QuantityCustomKeyPadFlyout"
            Closing="QuantityCustomKeyPadFlyout_Closing_1"
            FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
            LightDismissOverlayMode="Off"
            Placement="Left">
            <customControls:CustomKeypad
                DoneClickEvent="CustomKeypad_DoneClickEvent"
                IsDotButtonVisible="Collapsed"
                IsMinusButtonVisible="Visible"
                NumPadButtonClick="{x:Bind RackOrderCartPageViewModel.NumPadButtonClickCommand, Mode=OneWay}" />
        </Flyout>
        <Flyout
            x:Key="CustomGridKeyPadFlyout"
            x:Name="QuantityGridCustomKeyPadFlyout"
            Closing="QuantityCustomKeyPadFlyout_Closing"
            FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
            LightDismissOverlayMode="Off"
            Placement="Left">
            <customControls:CustomKeypad
                DoneClickEvent="CustomKeypad_DoneClickEvent1"
                IsDotButtonVisible="Collapsed"
                IsMinusButtonVisible="Visible"
                NumPadButtonClick="{x:Bind RackOrderCartPageViewModel.NumPadGridButtonClickCommand, Mode=OneWay}" />
        </Flyout>
        <localConverter:BoolToCartImageUriConverter x:Key="cartImageUriCovnerter" />

    </Page.Resources>
    <Grid x:Name="outerPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <customControls:HeaderControl
            Title="NEW RACK ORDER"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            BadgeText="{x:Bind RackOrderCartPageViewModel.BadgeText, Mode=OneWay}"
            CartButtonClick="{x:Bind RackOrderCartPageViewModel.CartButtonCommand, Mode=OneWay}"
            CustomerAddressText="{x:Bind RackOrderCartPageViewModel.CustomerAddresss, Mode=OneWay}"
            CustomerNameText="{x:Bind RackOrderCartPageViewModel.CustomerNameNumber, Mode=OneWay}"
  CustomerSubAddressText="{x:Bind RackOrderCartPageViewModel.CustomerCityState, Mode=OneWay}"
            IsBadgeVisible="{x:Bind RackOrderCartPageViewModel.IsBadgeVisible, Mode=OneWay}"          
            IsCartButtonVisible="Visible"
            IsCustomerPanelVisible="{x:Bind RackOrderCartPageViewModel.CustomerTitlePanelVisibility, Mode=OneWay}"
            IsPageTitleVisible="Visible" />
        <Grid
            Grid.Row="1"
            Margin="10,10,10,0"
            Padding="20"
            Background="{StaticResource FooterTextColor}">

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Left Panel Image, name, description  -->
            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                Height="150"
                Margin="0"
                Padding="0"
                HorizontalAlignment="Stretch"
                Background="{StaticResource FooterTextColor}"
                Orientation="Horizontal">
                <Image    x:Name="itemImage">
                    <Image.Source>
                        <BitmapImage DecodePixelWidth="200" 
                         UriSource="{x:Bind RackOrderCartPageViewModel.RackOrderCartUIModel.ProductImagePath, Mode=OneWay}" />
                    </Image.Source>
                </Image>
                <StackPanel
                    Margin="20,20,0,0"
                    HorizontalAlignment="Stretch"
                    Orientation="Vertical">
                    <TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        FontSize="{StaticResource MediumFontSize}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource CartTextColor}"
                        Text="{x:Bind RackOrderCartPageViewModel.RackOrderCartUIModel.ProductName, Mode=OneWay}" />
                    <TextBlock
                        Margin="0,15,0,0"
                        HorizontalAlignment="Left"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LoginScreenTextFontColor}"
                        Text="{x:Bind RackOrderCartPageViewModel.RackOrderCartUIModel.Description, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <!--  Right panel Quantity, Add to cart  -->
            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                Margin="0"
                Padding="0"
                HorizontalAlignment="Right"
                Background="{StaticResource FooterTextColor}"
                Orientation="Horizontal">
                <StackPanel
                    Margin="0,10,0,0"
                    HorizontalAlignment="Stretch"
                    Orientation="Vertical">
                    <TextBlock
                        Margin="0,22,0,0"
                        HorizontalAlignment="Left"
                        FontSize="{StaticResource FooterFontSize}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource CartTextColor}"
                        Text="Quantity" />
                    <TextBox
                        Name="headerQuantity"
                        Width="100"
                        Margin="0,13,0,0"
                        HorizontalAlignment="Left"
                        BeforeTextChanging="quantityTextBlock_BeforeTextChanging"
                        FlyoutBase.AttachedFlyout="{StaticResource CustomKeyPadFlyout}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LoginScreenTextFontColor}"
                        GotFocus="QuantityTextBlock_GotFocus"
                        InputScope="Number"
                        MaxLength="4"
                        PointerExited="quantityTextBlock_PointerExited"
                        Text="{x:Bind RackOrderCartPageViewModel.RackOrderCartUIModel.QuantityDisplay, Mode=TwoWay}" />
                </StackPanel>
                <Rectangle
                    Width="1"
                    Margin="20,30,20,30"
                    VerticalAlignment="Stretch"
                    Fill="{StaticResource LoginButtonBorderBrush}" />
                <StackPanel
                    Margin="0,10,0,0"
                    HorizontalAlignment="Stretch"
                    Orientation="Vertical">
                    <TextBlock
                        Margin="0,22,0,0"
                        HorizontalAlignment="Left"
                        FontSize="{StaticResource FooterFontSize}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource CartTextColor}"
                        Text="Add To Cart" />
                    <Grid Tapped="Grid_Tapped_1">
                        <Image HorizontalAlignment="Left" Margin="0,5,0,0" >
                            <Image.Source>
                                <BitmapImage DecodePixelWidth="60" DecodePixelHeight="60" 
                                             UriSource="{x:Bind RackOrderCartPageViewModel.RackOrderCartUIModel.IsAddedToCart, Mode=OneWay, Converter={StaticResource cartImageUriCovnerter}}" />
                            </Image.Source>
                        </Image>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Grid>
        <!--  Rack Cart Items List  -->
        <DE:GridControl
            Grid.Row="2"
            Margin="10,0,10,10"
            AlternationCount="2"
            AutoGenerateColumns="False"
            FontSize="{StaticResource DataGridTextSize}"
            ItemsSource="{x:Bind RackOrderCartPageViewModel.RackOrderListGridDataSource, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ShowAutoFilterRow="True"  KeepFocusedRowOnUpdate="False"
            ShowCriteriaInAutoFilterRow="False"
            ShowGroupPanel="False"
            ShowGroupedColumns="False">

            <DE:GridControl.Columns>
                <DE:GridTemplateColumn
                    x:Name="headerItemImage"
                    Width="150"                     
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="ProductImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Image" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4,0,4" Background="Transparent" MaxHeight="250" HorizontalAlignment="Center">
                                <Image  x:Name="popItemImage">
                                    <Image.Source>
                                        <BitmapImage 
                                             UriSource="{Binding ProductImagePath}" />
                                    </Image.Source>
                                </Image>
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTextColumn
                    Width="60"
                    AllowSorting="True"
                    FieldName="ProductName" AutoFilterCriteria="Contains"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    Width="100"
                    AllowSorting="True"
                    FieldName="Description" AutoFilterCriteria="Contains"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTemplateColumn
                    x:Name="quantity"
                    Width="60" AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="QuantityDisplay">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Quantity" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Editors:TextEdit 
                                x:Name="QuantityEditText" 
                                Width="98" 
                                FlyoutBase.AttachedFlyout="{StaticResource CustomGridKeyPadFlyout}"
                                GotFocus="QuantityEditText_GotFocus"
                                PointerExited="QuantityEditText_PointerExited"
                                Text="{Binding QuantityDisplay, Mode=TwoWay}"
                                Foreground="{StaticResource LoginScreenTextFontColor}">
                                <Editors:TextEdit.TextInputSettings>
                                    <Editors:TextInputMaskSettings 
                                        IgnoreBlank="True"
                                        MaskType="RegEx"
                                        Mask="[0-9]?[0-9]?[0-9]?[0-9]?"
                                        SaveLiteral="True">
                                    </Editors:TextInputMaskSettings>
                                </Editors:TextEdit.TextInputSettings>
                            </Editors:TextEdit>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTemplateColumn
                    x:Name="cart"
                    Width="50" 
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="CartImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Add to Cart" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Tapped="Grid_Tapped" MaxHeight="100">
                                <Image  x:Name="cartImage">
                                    <Image.Source>
                                        <BitmapImage 
                                             UriSource="{Binding IsAddedToCart, Mode=TwoWay, Converter={StaticResource cartImageUriCovnerter}}" />
                                    </Image.Source>
                                </Image>
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>
            </DE:GridControl.Columns>
        </DE:GridControl>
        <Grid
            Grid.Row="1"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{Binding LoadingVisibility}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>
    </Grid>
</Page>
