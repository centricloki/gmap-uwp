<Page
    x:Class="DRLMobile.Views.RackOrderCartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:customControls="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DRLMobile.Views"
    xmlns:localConverter="using:DRLMobile.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource LoginBackgroundColor}"
    mc:Ignorable="d">
    <Page.Resources>
        <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource CartTextColor}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
        <Flyout
            x:Key="CustomKeyPadFlyout"
            x:Name="QuantityCustomKeyPadFlyout"
            Closing="QuantityCustomKeyPadFlyout_Closing_1"
            FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
            LightDismissOverlayMode="Off"
            Placement="Left">
            <customControls:CustomKeypad
                DoneClickEvent="CustomKeypad_DoneClickEvent"
                IsDotButtonVisible="Collapsed"
                IsMinusButtonVisible="Visible"
                NumPadButtonClick="{x:Bind RackOrderCartPageViewModel.NumPadButtonClickCommand, Mode=OneWay}" />
        </Flyout>
        <Flyout
            x:Key="CustomGridKeyPadFlyout"
            x:Name="QuantityGridCustomKeyPadFlyout"
            Closing="QuantityCustomKeyPadFlyout_Closing"
            FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
            LightDismissOverlayMode="Off"
            Placement="Left">
            <customControls:CustomKeypad
                DoneClickEvent="CustomKeypad_DoneClickEvent1"
                IsDotButtonVisible="Collapsed"
                IsMinusButtonVisible="Visible"
                NumPadButtonClick="{x:Bind RackOrderCartPageViewModel.NumPadGridButtonClickCommand, Mode=OneWay}" />
        </Flyout>
        <localConverter:BoolToCartImageConverter x:Key="cartImageCovnerter" />

    </Page.Resources>
    <Grid x:Name="outerPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <customControls:HeaderControl
            Title="NEW RACK ORDER"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            BadgeText="{x:Bind RackOrderCartPageViewModel.BadgeText, Mode=OneWay}"
            CartButtonClick="{x:Bind RackOrderCartPageViewModel.CartButtonCommand, Mode=OneWay}"
            CustomerAddressText="{x:Bind RackOrderCartPageViewModel.CustomerAddresss, Mode=OneWay}"
            CustomerNameText="{x:Bind RackOrderCartPageViewModel.CustomerNameNumber, Mode=OneWay}"
            CustomerSubAddressText="{x:Bind RackOrderCartPageViewModel.CustomerCityState, Mode=OneWay}"
            IsBadgeVisible="{x:Bind RackOrderCartPageViewModel.IsBadgeVisible, Mode=OneWay}"
            IsCartButtonVisible="Visible"
            IsCustomerPanelVisible="{x:Bind RackOrderCartPageViewModel.CustomerTitlePanelVisibility, Mode=OneWay}"
            IsPageTitleVisible="Visible" />
        <Grid
            Grid.Row="1"
            Margin="10"
            Padding="20"
            Background="{StaticResource FooterTextColor}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Left Panel Image, name, description  -->
            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                Margin="10"
                Padding="10"
                HorizontalAlignment="Stretch"
                Background="{StaticResource FooterTextColor}"
                Orientation="Horizontal">
                <Image
                    x:Name="itemImage"
                    Width="200"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Stretch="Uniform">
                    <Image.Source>
                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{x:Bind RackOrderCartPageViewModel.RackOrderCartUIModel.ProductImagePath, Mode=TwoWay}" />
                    </Image.Source>
                </Image>
                <StackPanel
                    Margin="20,20,0,0"
                    HorizontalAlignment="Stretch"
                    Orientation="Vertical">
                    <TextBlock
                        Margin="0,10,0,0"
                        HorizontalAlignment="Left"
                        FontSize="{StaticResource MediumFontSize}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource CartTextColor}"
                        Text="{x:Bind RackOrderCartPageViewModel.RackOrderCartUIModel.ProductName, Mode=OneWay}" />
                    <TextBlock
                        Margin="0,15,0,0"
                        HorizontalAlignment="Left"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LoginScreenTextFontColor}"
                        Text="{x:Bind RackOrderCartPageViewModel.RackOrderCartUIModel.Description, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <!--  Right panel Quantity, Add to cart  -->
            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                Margin="10"
                Padding="10"
                HorizontalAlignment="Right"
                Background="{StaticResource FooterTextColor}"
                Orientation="Horizontal">
                <StackPanel
                    Margin="0,10,0,0"
                    HorizontalAlignment="Stretch"
                    Orientation="Vertical">
                    <TextBlock
                        Margin="0,22,0,0"
                        HorizontalAlignment="Left"
                        FontSize="{StaticResource FooterFontSize}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource CartTextColor}"
                        Text="Quantity" />
                    <TextBox
                        Name="headerQuantity"
                        Width="100"
                        Margin="0,13,0,0"
                        HorizontalAlignment="Left"
                        BeforeTextChanging="quantityTextBlock_BeforeTextChanging"
                        FlyoutBase.AttachedFlyout="{StaticResource CustomKeyPadFlyout}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LoginScreenTextFontColor}"
                        GotFocus="QuantityTextBlock_GotFocus"
                        InputScope="Number"
                        MaxLength="4"
                        PointerExited="quantityTextBlock_PointerExited"
                        Text="{x:Bind RackOrderCartPageViewModel.RackOrderCartUIModel.QuantityDisplay, Mode=TwoWay}" />
                </StackPanel>
                <Rectangle
                    Width="1"
                    Margin="20,30,20,30"
                    VerticalAlignment="Stretch"
                    Fill="{StaticResource LoginButtonBorderBrush}" />
                <StackPanel
                    Margin="0,10,0,0"
                    HorizontalAlignment="Stretch"
                    Orientation="Vertical">
                    <TextBlock
                        Margin="0,22,0,0"
                        HorizontalAlignment="Left"
                        FontSize="{StaticResource FooterFontSize}"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource CartTextColor}"
                        Text="Add To Cart" />
                    <Grid Tapped="Grid_Tapped_1">
                        <Image
                            Width="30"
                            Height="30"
                            Margin="0,13,0,0"
                            HorizontalAlignment="Left"
                            Source="{x:Bind RackOrderCartPageViewModel.RackOrderCartUIModel.IsAddedToCart, Mode=OneWay, Converter={StaticResource cartImageCovnerter}}" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Grid>
        <!--  Rack Cart Items List  -->
        <DE:GridControl
            Grid.Row="2"
            Margin="10"
            AlternationCount="2"
            AutoGenerateColumns="False"
            FontSize="{StaticResource DataGridTextSize}"
            ItemsSource="{x:Bind RackOrderCartPageViewModel.RackOrderListGridDataSource, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ShowAutoFilterRow="False"
            ShowCriteriaInAutoFilterRow="True"
            ShowGroupPanel="False"
            ShowGroupedColumns="False">

            <DE:GridControl.Columns>
                <DE:GridTemplateColumn
                    x:Name="headerItemImage"
                    Width="100"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="ProductImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Image" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent">
                                <Image
                                    x:Name="popItemImage"
                                    Width="120"
                                    Height="120"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Stretch="Uniform">
                                    <Image.Source>
                                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding ProductImagePath}" />
                                    </Image.Source>
                                </Image>
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTextColumn
                    Width="70"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    AutoFilterCriteria="Contains"
                    FieldName="ProductName"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    Width="180"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    AutoFilterCriteria="Contains"
                    FieldName="Description"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTemplateColumn
                    x:Name="quantity"
                    MinWidth="50"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="QuantityDisplay">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Quantity" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox
                                x:Name="quantityTextBlock"
                                Width="60"
                                HorizontalAlignment="Left"
                                BeforeTextChanging="quantityTextBlock_BeforeTextChanging"
                                FlyoutBase.AttachedFlyout="{StaticResource CustomGridKeyPadFlyout}"
                                Foreground="{StaticResource LoginScreenTextFontColor}"
                                GotFocus="quantityTextBlock_GotFocus"
                                MaxLength="4"
                                PointerExited="QuantityTextBlock_PointerExited"
                                Text="{Binding QuantityDisplay, Mode=TwoWay}" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTemplateColumn
                    x:Name="cart"
                    Width="40"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="CartImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Add to Cart" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Tapped="Grid_Tapped">
                                <Image
                                    x:Name="cartImage"
                                    Width="27"
                                    Height="27"
                                    Source="{Binding IsAddedToCart, Mode=TwoWay, Converter={StaticResource cartImageCovnerter}}" />

                                <!--  Source="{StaticResource CartUnselected}" />  -->
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>
            </DE:GridControl.Columns>
        </DE:GridControl>
        <Grid
            Grid.Row="1"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{Binding LoadingVisibility}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>
    </Grid>
</Page>
