<Page
    x:Class="DRLMobile.Uwp.View.RetailTransactionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:ui="using:Microsoft.Toolkit.Uwp.UI" 
    xmlns:Editors="using:DevExpress.UI.Xaml.Editors"
    xmlns:localConverter="using:DRLMobile.Uwp.Converters"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:core="using:Microsoft.Xaml.Interactions.Core"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <Style x:Key="NoExpanderHeaderStyle" TargetType="ToggleButton">
                <Setter Property="Visibility" Value="Collapsed" />
            </Style>
            <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource CartTextColor}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
            </Style>
            <Flyout
                x:Key="CustomGridKeyPadFlyout"
                x:Name="QuantityGridCustomKeyPadFlyout"
                Closing="QuantityCustomKeyPadFlyout_Closing"
                FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                LightDismissOverlayMode="Off"
                Placement="Left">
                <customControls:CustomKeypad
                    DoneClickEvent="CustomKeypad_DoneClickEvent1"
                    IsDotButtonVisible="Collapsed"
                    IsMinusButtonVisible="Visible"
                    NumPadButtonClick="{x:Bind retailTransactionPageViewModel.NumPadGridButtonClickCommand, Mode=OneWay}" />
            </Flyout>
            <localConverter:VisibilityToBoolConverter x:Key="VisibilityToBoolConverter" />
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundColor}">

        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="90" />
        </Grid.RowDefinitions>

        <Canvas x:Name="PrintCanvas" Opacity="0" />

        <customControls:HeaderControl
            Title="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PageTitle, Mode=OneWay}"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            IsPageTitleVisible="Visible" />

        <ScrollViewer x:Name="ParentScrollView" Grid.Row="1">
            <Grid Padding="0,10,0,0" RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Grid.Column="0"
                    Spacing="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.TransactionNumberText, Mode=OneWay}" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.TransactionNumber, Mode=OneWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Account" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.AccountNumber, Mode=OneWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Purchase Order" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Purchase Order"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PurchaseOrderNumber, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Customer Name" />
                                <Run x:Uid="Colon" d:Text=":" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <!--<TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Customer Name"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CustomerName, Mode=TwoWay}" />-->
                        <TextBox
                            Grid.Column="1"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CustomerName, Mode=OneWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Address" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Height="70"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Addreess"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.Address, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="City" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="City"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CityName, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="State" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <ComboBox
                            Grid.Column="1"
                            Margin="20,10,0,0"
                            FontSize="16"
                            ItemsSource="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.States.Values, Mode=OneWay}"
                            SelectedItem="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SelectedPhysicalState, Mode=TwoWay}"
                            Style="{StaticResource ComboBoxWhiteBackground}">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Zip" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <!--  BeforeTextChanging="NumericTextBox_BeforeTextChanging"  -->
                        <TextBox
                            Grid.Column="1"
                            d:Text="zip"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.Zip, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="State Tobacco License" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Tobacco License"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.StateTobaccoLicense, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Retailer License" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Retailer License"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.RetailerLicense, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Retailer Sales Tax Certificate :" />

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Sales Tax Certificate"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.RetailerSalesTaxCertificate, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Email To" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            Height="70"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.EmailTo, Mode=TwoWay}" />

                        <!--
                            ui:TextBoxExtensions.IsValid="{x:Bind retailTransactionPageViewModel.IsEmailValid, Mode=TwoWay}"
                            ui:TextBoxExtensions.Regex="^([\w\.\-]+)@([\w\-]+)((\.(\w){2,3})+)$"
                            ui:TextBoxExtensions.ValidationType="Email"
                        -->
                    </Grid>

                    <Grid ColumnSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Custom Tax Statement :" />

                        <TextBox
                            x:Name="customTaxTextBox"
                            Grid.Column="1"
                            Height="80"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CustomTaxStatement, Mode=TwoWay}"
                            TextChanged="TextBox_TextChanged" />

                        <FontIcon
                            x:Name="AddTaxStatementIcon"
                            Grid.Column="2"
                            Width="20"
                            Height="20"
                            Foreground="Black"
                            Visibility="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CustomTaxStatementIconVisibility, Mode=OneWay}"
                            Glyph="{StaticResource AddIcon}"
                            Tapped="AddTaxStatementIcon_Tapped" />

                        <FlyoutBase.AttachedFlyout>
                            <Flyout
                                x:Name="taxStatmentFlyout"
                                FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                                LightDismissOverlayMode="Off">
                                <Grid
                                    Width="300"
                                    Height="300"
                                    Background="White"
                                    BorderBrush="Black"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="auto" />
                                    </Grid.RowDefinitions>

                                    <Grid
                                        Grid.Row="0"
                                        Height="35"
                                        HorizontalAlignment="Stretch"
                                        Background="{StaticResource FooterBackgroundColor}">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="16"
                                            Foreground="White"
                                            Text="Select Tax Statement" />
                                    </Grid>

                                    <ListView
                                        Grid.Row="1"
                                        ItemsSource="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.UserTaxStatementList, Mode=OneWay}"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid
                                                    x:Name="CustomTaxtStatementTemplateGrid"
                                                    Background="Transparent"
                                                    Tapped="CustomTaxtStatementTemplateGrid_Tapped">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="25" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        MinWidth="250"
                                                        HorizontalAlignment="Stretch"
                                                        FontSize="12"
                                                        FontWeight="Medium"
                                                        Text="{Binding Title}"
                                                        TextWrapping="Wrap" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <StackPanel
                                        Grid.Row="2"
                                        Margin="3"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="10">
                                        <Button
                                            x:Name="CancelTaxStatement"
                                            Click="CancelTaxStatement_Click"
                                            Content="Cancel"
                                            Style="{StaticResource FlyoutButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.CommentsLabel, Mode=OneWay}" />
                        <!--  Text="Enter Retail Sales Call Notes :" />  -->

                        <TextBox
                            Grid.Column="1"
                            Style="{StaticResource EditTextBoxStyle}"
                            Height="70"
                            MaxLength="1000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.RetailsSalesCallNotes, Mode=TwoWay}" />
                    </Grid>

                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Republic Sales Rep :" />

                        <TextBox
                            Grid.Column="1"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.RepublicSalesRepName, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Seller's Representative Tobacco Permit :" />

                        <TextBox
                            Grid.Column="1"
                            PlaceholderForeground="LightGray"
                            PlaceholderText="Permit Number"
                            Style="{StaticResource EditTextBoxStyle}"
                            Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SellerRepresentativeTobaccoPermit, Mode=TwoWay}" />

                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="salesTypeLabel"
                            Padding="0,5,0,0"
                            VerticalAlignment="Top"
                            Style="{StaticResource FieldTextBlockStyle}"
                            Text="Sales Type : "
                            Visibility="Collapsed" />

                        <StackPanel
                            x:Name="SalesTypeStackPanel"
                            Grid.Column="1"
                            Padding="30,10"
                            Spacing="6"
                            x:Load="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.OrderSalesOptionVisibility, 
                            Mode=OneWay, Converter={StaticResource VisibilityToBoolConverter}}"
                            >
                            <muxc:RadioButtons x:Name="RBtnSaleType"
                                ItemsSource="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SaleTypeCollection, Mode=OneWay}" 
                                SelectedItem="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.ChosenSaleType, Mode=TwoWay}"
                                SelectionChanged="SalesTypeOption_SelectionChanged">
                                <muxc:RadioButtons.ItemTemplate>
                                    <DataTemplate >
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </muxc:RadioButtons.ItemTemplate>
                            </muxc:RadioButtons>
                        </StackPanel>
                        <RadioButton
                            x:Name="rackoption"
                            Grid.Column="1"
                            Margin="20,12"
                            Content="Rack/POS"
                            IsChecked="True"
                            Tag="RackPOS"
                            Visibility="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.RackOrderOptionVisibility, Mode=OneWay}" />
                        <RadioButton
                            x:Name="sampleorderoption"
                            Grid.Column="1"
                            Margin="20,12"
                            Content="Sample Order"
                            IsChecked="True"
                            Tag="SampleOrder"
                            Visibility="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SampleOrderOptionVisibility, Mode=OneWay}" />
                    </Grid>

                    <StackPanel x:Name="distributorStackPanel" 
                    Visibility="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.DistributorVisibility, Mode=OneWay}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Retailer’s Distributor Customer Number :" />

                            <TextBox
                                Grid.Column="1"
                                PlaceholderForeground="LightGray"
                                PlaceholderText="Retailer’s Distributor Customer Number"
                                Style="{StaticResource EditTextBoxStyle}"
                                Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.RetailDistributorNumber, Mode=TwoWay}" />
                        </Grid>


                        <Grid Padding="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Distributor :" />

                            <Grid
                                x:Name="DistributorGrid"
                                Grid.Column="1"
                                MinWidth="250"
                                MinHeight="40"
                                Margin="20,10,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                CornerRadius="5"
                                Style="{StaticResource EditBackgroundGridStyle}"
                                Tapped="DistributorGrid_Tapped">

                                <FlyoutBase.AttachedFlyout>
                                    <Flyout
                                        x:Name="DistributorFlyout"
                                        FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                                        LightDismissOverlayMode="Off">
                                        <Grid
                                            Width="350"
                                            Height="350"
                                            Background="White"
                                            BorderBrush="Black"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="auto" />
                                            </Grid.RowDefinitions>

                                            <Grid
                                                Grid.Row="0"
                                                Height="25"
                                                HorizontalAlignment="Stretch"
                                                Background="{StaticResource FooterBackgroundColor}">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="16"
                                                    Foreground="White"
                                                    Text="Select Distributor" />
                                            </Grid>

                                            <ListView
                                                Grid.Row="1"
                                                ItemsSource="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.DistributorsList, Mode=OneWay}"
                                                SelectionMode="None">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid
                                                            x:Name="DistributorTemplateGrid"
                                                            Background="Transparent"
                                                            Tapped="DistributorTemplateGrid_Tapped">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="25" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock MinWidth="270" HorizontalAlignment="Stretch"
                                                                FontSize="12" FontWeight="Medium" TextWrapping="Wrap">
                                                                    <TextBlock.Inlines>
                                                                        <Run Text="{Binding FullName}" />
                                                                        <LineBreak/>
                                                                        <Run FontStyle="Italic" FontSize="11" FontWeight="Normal" Text="{Binding AssignUserName}" />
                                                                    </TextBlock.Inlines>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>

                                            <StackPanel
                                                Grid.Row="2"
                                                Margin="3"
                                                HorizontalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="10">
                                                <Button
                                                    Click="CancelButton_Click"
                                                    Content="Cancel"
                                                    Style="{StaticResource FlyoutButtonStyle}" />
                                                <!--<Button Click="DoneButton_Click"
                                                        Content="Done" Style="{StaticResource FlyoutButtonStyle}" />-->
                                            </StackPanel>
                                        </Grid>

                                    </Flyout>
                                </FlyoutBase.AttachedFlyout>

                                <TextBlock
                                    Margin="2"
                                    x:Name="selectedDistributor"
                                    MaxWidth="230" HorizontalAlignment="Stretch"
                                    FontSize="14"  TextWrapping="Wrap"
                                    Foreground="{StaticResource LoginScreenTextFontColor}"
                                    Text="Select Distributor" />
                            </Grid>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="City :" />

                            <TextBox
                                Grid.Column="1"
                                IsReadOnly="True"
                                PlaceholderForeground="LightGray"
                                PlaceholderText="City"
                                Style="{StaticResource EditTextBoxStyle}"
                                Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PrebookCity, Mode=OneWay}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="8*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.ColumnSpan="2"
                                Margin="0,18,99,0"
                                VerticalAlignment="Top"
                                Style="{StaticResource FieldTextBlockStyle}"
                                Text="State :" />

                            <ComboBox
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Margin="20,10,0,0"
                                FontSize="16"
                                IsEnabled="False"
                                ItemsSource="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PrebookState.Values, Mode=OneWay}"
                                SelectedItem="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.SelectedPrebookState, Mode=TwoWay}"
                                Style="{StaticResource ComboBoxEditStyle}">

                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" HorizontalAlignment="Left" Margin="10,0,0,0" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Zip :" />

                            <TextBox
                                Grid.Column="1"
                                IsReadOnly="True"
                                PlaceholderForeground="LightGray"
                                PlaceholderText="Zip"
                                Style="{StaticResource EditTextBoxStyle}"
                                Text="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PrebookZip, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>

                    <Grid Padding="0,100" Visibility="{x:Bind retailTransactionPageViewModel.RetailTransacUiModel.PrebookDateVisiblity, Mode=TwoWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}" Text="Prebook Ship Date :" />

                        <CalendarDatePicker
                            x:Name="prebookDatePicker"
                            Grid.Column="1"
                            Margin="20,10,0,0"
                            Background="White"
                            DateChanged="prebookDatePicker_DateChanged"
                            PlaceholderText="Choose Prebook Date" />
                    </Grid>

                </StackPanel>

                <StackPanel
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Padding="0,20,0,0"
                    Spacing="0">

