<Page
    x:Class="DRLMobile.Views.CustomerDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Editors="using:DevExpress.UI.Xaml.Editors"
    xmlns:converter="using:DRLMobile.Converters"
    xmlns:core="using:Microsoft.Xaml.Interactions.Core"
    xmlns:customControl="using:DRLMobile.CustomControls"
    xmlns:customControls="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:Microsoft.Toolkit.Uwp.UI"
    d:Height="3000"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>

            <Style TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>


            <converter:BoolToInvertBoolConverter x:Key="BoolToInvertBoolConverter" />
            <converter:BoolToImageSourceConverter x:Key="BoolToImageConverter" />
            <converter:StringToPhoneNumberConverter x:Key="StringToPhoneNumber" />
            <converter:BoolToStyleConverter x:Key="BoolToStyleConverter" />
            <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converter:EscapeStringConverter x:Key="EscapeStringConverter" />
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <customControls:HeaderControl
            x:Name="HeaderControl"
            x:Uid="CustomerDetailPageTitle"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            ButtonClick="{x:Bind ViewModel.EditSaveCommand, Mode=OneWay}"
            CustomIconButtonVisibility="Visible"
            HoverImageSource="{x:Bind ViewModel.UiModel.IsInEditMode, Mode=OneWay, Converter={StaticResource BoolToImageConverter}, ConverterParameter='Hover'}"
            IsAutoSuggestBoxVisible="Collapsed"
            IsPageTitleVisible="Visible"
            NormalImageSource="{x:Bind ViewModel.UiModel.IsInEditMode, Mode=OneWay, Converter={StaticResource BoolToImageConverter}, ConverterParameter='Normal'}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden">
            <FlyoutBase.AttachedFlyout>
                <Flyout
                    x:Name="AlertFlyout"
                    FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                    Placement="Right">
                    <Grid
                        MinWidth="350"
                        Background="White"
                        BorderBrush="Red"
                        BorderThickness="1"
                        CornerRadius="10">
                        <TextBlock
                            Name="AlertFlyoutTextBlock"
                            Margin="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="Red"
                            HorizontalTextAlignment="Center"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </Grid>
                </Flyout>
            </FlyoutBase.AttachedFlyout>
        </customControls:HeaderControl>

        <ScrollViewer x:Name="ParentScrollView" Grid.Row="1">
            <Grid RowSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="-5">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_CustomerName" d:Text="Customer Name" />
                                <Run
                                    d:Text="*"
                                    Foreground="Red"
                                    Text="{x:Bind ViewModel.UiModel.MandatoryText, Mode=OneWay}" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Name="CustomerNameTextBox"
                            Grid.Column="1"
                            d:Text="Customer Name"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.CustomerName, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_AccountType" d:Text="Account type" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            d:Text="Account type"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind ViewModel.UiModel.AccountType, Mode=TwoWay}" />


                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_AccountClassification" d:Text="Account Classification" />
                                <Run
                                    d:Text="*"
                                    Foreground="Red"
                                    Text="{x:Bind ViewModel.UiModel.MandatoryText, Mode=OneWay}" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <ComboBox
                            x:Name="AccountClassificationComboBox"
                            Grid.Column="1"
                            Margin="20,10,0,0"
                            d:Text="Account Classification"
                            FontSize="16"
                            ItemsSource="{Binding UiModel.Classifications.Values}"
                            SelectedItem="{x:Bind ViewModel.UiModel.SelectedAccountClassification, Mode=TwoWay}"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='ComboBox'}">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AccountClassificationName}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>


                        </ComboBox>


                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_Rank" d:Text="Rank" />
                                <Run
                                    d:Text="*"
                                    Foreground="Red"
                                    Text="{x:Bind ViewModel.UiModel.MandatoryText, Mode=OneWay}" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <ComboBox
                            x:Name="RankComboBox"
                            Grid.Column="1"
                            Margin="20,10,0,0"
                            FontSize="16"
                            ItemsSource="{Binding UiModel.Ranks.Values}"
                            SelectedItem="{x:Bind ViewModel.UiModel.SelectedRank, Mode=TwoWay}"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='ComboBox'}">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>


                        </ComboBox>


                    </Grid>

                    <TextBlock
                        x:Uid="CustomerDetailPage_PhysicalAddress"
                        d:Text="Physical Address"
                        Style="{StaticResource TitleHeaderStyle}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_Address" d:Text="Address" />
                                <Run
                                    d:Text="*"
                                    Foreground="Red"
                                    Text="{x:Bind ViewModel.UiModel.MandatoryText, Mode=OneWay}" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Name="PhysicalAddressTextBox"
                            Grid.Column="1"
                            d:Text="Address"
                            MaxLength="1000"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.PhysicalAddress, Mode=TwoWay, Converter={StaticResource EscapeStringConverter}}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_City" d:Text="city" />
                                <Run
                                    d:Text="*"
                                    Foreground="Red"
                                    Text="{x:Bind ViewModel.UiModel.MandatoryText, Mode=OneWay}" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            x:Name="PhysicalCityComboBox"
                            Grid.Column="1"
                            d:Text="city"
                            MaxLength="50"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.PhysicalCity, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_State" d:Text="state" />
                                <Run
                                    d:Text="*"
                                    Foreground="Red"
                                    Text="{x:Bind ViewModel.UiModel.MandatoryText, Mode=OneWay}" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <ComboBox
                            x:Name="PhysicalStateComboBox"
                            Grid.Column="1"
                            Margin="20,10,0,0"
                            FontSize="16"
                            ItemsSource="{Binding UiModel.States.Values}"
                            SelectedItem="{x:Bind ViewModel.UiModel.SelectedPhysicalState, Mode=TwoWay}"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='ComboBox'}">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>

                        </ComboBox>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_Zip" d:Text="zip" />
                                <Run
                                    d:Text="*"
                                    Foreground="Red"
                                    Text="{x:Bind ViewModel.UiModel.MandatoryText, Mode=OneWay}" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            x:Name="PhysicalZipTextBox"
                            Grid.Column="1"
                            d:Text="zip"
                            BeforeTextChanging="NumericTextBox_BeforeTextChanging"
                            MaxLength="10"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.PhysicalZip, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_ContactName" d:Text="Contact Name" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            d:Text="contact Name"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.PhysicalContactPersonName, Mode=TwoWay, Converter={StaticResource EscapeStringConverter}}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_ContactRole" d:Text="Contact Role" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            d:Text="Customer role"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.PhysicalContactPersonRole, Mode=TwoWay, Converter={StaticResource EscapeStringConverter}}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_ContactEmail" d:Text="Contact Email" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            d:Text="Customer email"
                            ui:TextBoxExtensions.IsValid="{x:Bind ViewModel.UiModel.IsEmailValid, Mode=TwoWay}"
                            ui:TextBoxExtensions.Regex="^([\w\.\-]+)@([\w\-]+)((\.(\w){2,3})+)$"
                            ui:TextBoxExtensions.ValidationType="Email"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.PhysicalContactEmail, Mode=TwoWay, Converter={StaticResource EscapeStringConverter}}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_Phone" d:Text="Phone" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <Editors:TextEdit
                            Grid.Column="1"
                            CornerRadius="10"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='DevExpressEditor'}"
                            Text="{x:Bind ViewModel.UiModel.PhysicalContactPhone, Mode=TwoWay}">
                            <Editors:TextEdit.TextInputSettings>
                                <Editors:TextInputMaskSettings
                                    IgnoreBlank="True"
                                    Mask="(999)-999-9999"
                                    MaskType="Simple"
                                    SaveLiteral="True" />
                            </Editors:TextEdit.TextInputSettings>
                        </Editors:TextEdit>



                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_Fax" d:Text="Fax" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <Editors:TextEdit
                            Grid.Column="1"
                            CornerRadius="10"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='DevExpressEditor'}"
                            Text="{x:Bind ViewModel.UiModel.PhysicalContactFax, Mode=TwoWay}">
                            <Editors:TextEdit.TextInputSettings>
                                <Editors:TextInputMaskSettings
                                    IgnoreBlank="True"
                                    Mask="(999)-999-9999"
                                    MaskType="Simple"
                                    SaveLiteral="True" />
                            </Editors:TextEdit.TextInputSettings>
                        </Editors:TextEdit>


                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Uid="CustomerDetailPage_ShippingAddress"
                            Grid.Column="0"
                            d:Text="Shipping Address"
                            Style="{StaticResource TitleHeaderStyle}" />

                        <CheckBox
                            x:Name="ShippingAddressCheckBox"
                            x:Uid="CustomerDetailPage_SameAsPhysicalAddress"
                            Grid.Column="1"
                            d:Content="Same As Physical Address"
                            IsChecked="{x:Bind ViewModel.UiModel.IsCheckedForSameAsPhysicalAddressShippingAddess, Mode=TwoWay}"
                            Style="{StaticResource CheckBoxStyle}"
                            Visibility="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <i:Interaction.Behaviors>
                                <core:EventTriggerBehavior EventName="Checked">
                                    <core:InvokeCommandAction Command="{x:Bind ViewModel.UiModel.ShippingAddressCheckBoxCommand, Mode=OneWay}" CommandParameter="{Binding ElementName=ShippingAddressCheckBox, Path=IsChecked}" />
                                </core:EventTriggerBehavior>
                                <core:EventTriggerBehavior EventName="Unchecked">
                                    <core:InvokeCommandAction Command="{x:Bind ViewModel.UiModel.ShippingAddressCheckBoxCommand, Mode=OneWay}" CommandParameter="{Binding ElementName=ShippingAddressCheckBox, Path=IsChecked}" />
                                </core:EventTriggerBehavior>
                            </i:Interaction.Behaviors>
                        </CheckBox>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_Address" d:Text="Address" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            d:Text="address"
                            IsReadOnly="{x:Bind ViewModel.UiModel.IsShippingAddressEditable, Mode=OneWay, Converter={StaticResource BoolToInvertBoolConverter}}"
                            MaxLength="1000"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.ShippingAddress, Mode=TwoWay, Converter={StaticResource EscapeStringConverter}}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_City" d:Text="city" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            d:Text="city"
                            IsReadOnly="{x:Bind ViewModel.UiModel.IsShippingAddressEditable, Mode=OneWay, Converter={StaticResource BoolToInvertBoolConverter}}"
                            MaxLength="50"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.ShippingCity, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_State" d:Text="state" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <ComboBox
                            Grid.Column="1"
                            Margin="20,10,0,0"
                            FontSize="16"
                            IsEnabled="{x:Bind ViewModel.UiModel.IsShippingAddressEditable, Mode=OneWay}"
                            ItemsSource="{Binding UiModel.States.Values}"
                            SelectedItem="{x:Bind ViewModel.UiModel.SelectedShippingState, Mode=TwoWay}"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='ComboBox'}">

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_Zip" d:Text="zip" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            d:Text="zip"
                            BeforeTextChanging="NumericTextBox_BeforeTextChanging"
                            IsReadOnly="{x:Bind ViewModel.UiModel.IsShippingAddressEditable, Mode=OneWay, Converter={StaticResource BoolToInvertBoolConverter}}"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.ShippingZip, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Uid="CustomerDetailPage_MailingAddress"
                            Grid.Column="0"
                            d:Text="Mailing Address"
                            Style="{StaticResource TitleHeaderStyle}" />

                        <CheckBox
                            x:Name="MailingAddressCheckBox"
                            x:Uid="CustomerDetailPage_SameAsPhysicalAddress"
                            Grid.Column="1"
                            d:Content="Same As Physical Address"
                            IsChecked="{x:Bind ViewModel.UiModel.IsCheckedForSameAsPhysicalAddressMailingAddess, Mode=TwoWay}"
                            Style="{StaticResource CheckBoxStyle}"
                            Visibility="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <i:Interaction.Behaviors>
                                <core:EventTriggerBehavior EventName="Checked">
                                    <core:InvokeCommandAction Command="{x:Bind ViewModel.UiModel.MailingAddressCheckBoxCommand, Mode=OneWay}" CommandParameter="{Binding ElementName=MailingAddressCheckBox, Path=IsChecked}" />
                                </core:EventTriggerBehavior>
                                <core:EventTriggerBehavior EventName="Unchecked">
                                    <core:InvokeCommandAction Command="{x:Bind ViewModel.UiModel.MailingAddressCheckBoxCommand, Mode=OneWay}" CommandParameter="{Binding ElementName=MailingAddressCheckBox, Path=IsChecked}" />
                                </core:EventTriggerBehavior>
                            </i:Interaction.Behaviors>
                        </CheckBox>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_Address" d:Text="Address" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            d:Text="Customer address"
                            IsReadOnly="{x:Bind ViewModel.UiModel.IsMailingAddressEditable, Mode=OneWay, Converter={StaticResource BoolToInvertBoolConverter}}"
                            MaxLength="1000"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.MailingAddress, Mode=TwoWay, Converter={StaticResource EscapeStringConverter}}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_City" d:Text="city" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <TextBox
                            Grid.Column="1"
                            d:Text="city"
                            IsReadOnly="{x:Bind ViewModel.UiModel.IsMailingAddressEditable, Mode=OneWay, Converter={StaticResource BoolToInvertBoolConverter}}"
                            MaxLength="50"
                            Style="{x:Bind ViewModel.UiModel.IsCustomerDetailsEditEnabled, Mode=OneWay, Converter={StaticResource BoolToStyleConverter}, ConverterParameter='TextBox'}"
                            Text="{x:Bind ViewModel.UiModel.MailingCity, Mode=TwoWay}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run x:Uid="CustomerDetailPage_State" d:Text="state" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>

                        <ComboBox
                            Grid.Column="1"
                            Margin="20,10,0,0"
                            FontSize="16"
