<UserControl
    x:Class="DRLMobile.CustomControls.NameAndSignaturePanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400">
    <UserControl.Resources>
        <Style x:Key="columnLabels" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="columnLabels1" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontStyle" Value="Normal"/>
            <Setter Property="Foreground" Value="LightGray"/>        
        </Style>
        <Style x:Key="buttonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="DarkSlateGray"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Light"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="250, 200" RowSpacing="6" ColumnSpacing="5" Background="White" Padding="15" BorderThickness="1" BorderBrush="DarkGray" CornerRadius="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Print Name:*" Style="{StaticResource columnLabels}" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Signature:*" Style="{StaticResource columnLabels}" VerticalAlignment="Top"/>
        <TextBox x:Name="nameTextBox" Grid.Row="0" Grid.Column="1" PlaceholderText="Print Name" VerticalAlignment="Center" 
                 BorderThickness="1" BorderBrush="DarkGray" Height="40" CornerRadius="3"
                 Text="{x:Bind retailTransactionVM.RetailTransacUiModel.PrintName,Mode=TwoWay}" TextChanging="nameTextBox_TextChanging"/>
        <Grid x:Name="signaturePanel" Grid.Row="1" Grid.Column="1" RowSpacing="6" BorderThickness="1" BorderBrush="DarkGray" CornerRadius="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width=".33*"/>
                <ColumnDefinition Width=".33*"/>
                <ColumnDefinition Width=".33*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource buttonStyle}" Content="Cancel"
                    Click="CancelButton_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource buttonStyle}" HorizontalAlignment="Center" Content="Clear"
                    Click="ClearSignatureButton_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource buttonStyle}" HorizontalAlignment="Right" Content="Confirm"
                    Click="ConfirmButton_Click"/>
            <InkCanvas x:Name="signatureCanvas" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"/>
        </Grid>
    </Grid>
</UserControl>
