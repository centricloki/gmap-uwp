                    FieldName="StoreType"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="{Binding}" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    Width="80"
                    AllowSorting="True"
                    AutoFilterCriteria="Contains"
                    FieldName="Rank"
