<Page Width="300"
    x:Class="DRLMobile.Uwp.View.PrintOrderXAMLPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DRLMobile.Uwp.View"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="PrintableArea">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <RichTextBlock Grid.Row="0"
            Foreground="Black" x:Name="TextContent"    OverflowContentTarget="{Binding ElementName=FirstLinkedContainer}" 
            IsTextSelectionEnabled="True" TextAlignment="Left" FontFamily="Segoe UI" VerticalAlignment="Top" HorizontalAlignment="Left">
        </RichTextBlock>

        <RichTextBlockOverflow Grid.Row="1"
            x:Name="FirstLinkedContainer" OverflowContentTarget="{Binding ElementName=ContinuationPageLinkedContainer}" />

        <RichTextBlockOverflow Grid.Row="2" 
            x:Name="ContinuationPageLinkedContainer" />

        <StackPanel  Grid.Row="3" x:Name="Footer" Visibility="Collapsed">
            <TextBlock Foreground="Black" FontSize="16" TextAlignment="Left" FontFamily="Segoe UI">
            </TextBlock>
        </StackPanel>

    </Grid>

</Page>
