<Page
    x:Class="DRLMobile.Views.PopOrderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:customControls="using:DRLMobile.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:localConverter="using:DRLMobile.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource LoginBackgroundColor}"
    mc:Ignorable="d">
    <Page.Resources>
        <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource CartTextColor}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>

        <Flyout
            x:Key="CustomGridKeyPadFlyout"
            x:Name="QuantityGridCustomKeyPadFlyout"
            Closing="QuantityCustomKeyPadFlyout_Closing"
            FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
            LightDismissOverlayMode="Off"
            Placement="Left">
            <customControls:CustomKeypad
                DoneClickEvent="CustomKeypad_DoneClickEvent1"
                IsDotButtonVisible="Collapsed"
                IsMinusButtonVisible="Visible"
                NumPadButtonClick="{x:Bind PopOrderViewModel.NumPadGridButtonClickCommand, Mode=OneWay}" />
        </Flyout>
        <localConverter:BoolToCartImageConverter x:Key="cartImageCovnerter" />
    </Page.Resources>

    <Grid x:Name="outerPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <customControls:HeaderControl
            Title="NEW POP ORDER"
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            BadgeText="{x:Bind PopOrderViewModel.BadgeText, Mode=OneWay}"
            CartButtonClick="{x:Bind PopOrderViewModel.CartButtonCommand, Mode=OneWay}"
            CustomerAddressText="{x:Bind PopOrderViewModel.CustomerAddresss, Mode=OneWay}"
            CustomerNameText="{x:Bind PopOrderViewModel.CustomerNameNumber, Mode=OneWay}"
            CustomerSubAddressText="{x:Bind PopOrderViewModel.CustomerCityState, Mode=OneWay}"
            IsBadgeVisible="{x:Bind PopOrderViewModel.IsBadgeVisible, Mode=OneWay}"
            IsCartButtonVisible="Visible"
            IsCustomerPanelVisible="{x:Bind PopOrderViewModel.CustomerTitlePanelVisibility, Mode=OneWay}"
            IsPageTitleVisible="Visible" />
        <Grid
            Grid.Row="1"
            Padding="10,30,10,20"
            Background="{StaticResource LoginBackgroundColor}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel
                Grid.Row="0"
                Grid.Column="0"
                Orientation="Horizontal">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Category" />
                <ComboBox
                    Width="250"
                    Margin="20,-8,0,0"
                    Background="Transparent"
                    PlaceholderText="Select" />
            </StackPanel>
            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Material" />
                <ComboBox
                    Width="250"
                    Margin="20,-8,0,0"
                    Background="Transparent"
                    PlaceholderText="Select" />
            </StackPanel>
            <StackPanel
                Grid.Row="0"
                Grid.Column="2"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Family" />
                <ComboBox
                    Width="250"
                    Margin="20,-8,0,0"
                    Background="Transparent"
                    PlaceholderText="Select" />
            </StackPanel>
            <StackPanel
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,20,0,0"
                Orientation="Horizontal">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Brand" />
                <ComboBox
                    Width="250"
                    Margin="40,-8,0,0"
                    Background="Transparent"
                    PlaceholderText="Select" />
            </StackPanel>
            <StackPanel
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource CartTextColor}"
                    Text="Group" />
                <ComboBox
                    Width="250"
                    Margin="32,-8,0,0"
                    Background="Transparent"
                    PlaceholderText="Select" />
            </StackPanel>
        </Grid>
        <!--  Pop Items List  -->
        <DE:GridControl
            Grid.Row="2"
            Margin="10"
            AlternationCount="2"
            AutoGenerateColumns="False"
            FontSize="{StaticResource DataGridTextSize}"
            ItemsSource="{x:Bind PopOrderViewModel.PopOrderListGridDataSource, Mode=TwoWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            ShowAutoFilterRow="False"
            ShowCriteriaInAutoFilterRow="True"
            ShowGroupPanel="False"
            ShowGroupedColumns="False">

            <DE:GridControl.Columns>
                <DE:GridTemplateColumn
                    x:Name="headerItemImage"
                    Width="100"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="ProductImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Image" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent">
                                <Image
                                    x:Name="popItemImage"
                                    Width="120"
                                    Height="120"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Stretch="Uniform">
                                    <Image.Source>
                                        <BitmapImage CreateOptions="IgnoreImageCache" UriSource="{Binding ProductImagePath}" />
                                    </Image.Source>
                                </Image>
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTextColumn
                    Width="70"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    AutoFilterCriteria="Contains"
                    FieldName="ProductName"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTextColumn
                    Width="180"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    AutoFilterCriteria="Contains"
                    FieldName="Description"
                    TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTemplateColumn
                    x:Name="quantity"
                    MinWidth="50"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="QuantityDisplay">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Quantity" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox
                                x:Name="quantityTextBlock"
                                Width="60"
                                HorizontalAlignment="Left"
                                BeforeTextChanging="quantityTextBlock_BeforeTextChanging"
                                FlyoutBase.AttachedFlyout="{StaticResource CustomGridKeyPadFlyout}"
                                Foreground="{StaticResource LoginScreenTextFontColor}"
                                GotFocus="quantityTextBlock_GotFocus"
                                MaxLength="4"
                                PointerExited="QuantityTextBlock_PointerExited"
                                Text="{Binding QuantityDisplay, Mode=TwoWay}" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTemplateColumn
                    x:Name="cart"
                    Width="40"
                    AllowAutoFilter="False"
                    AllowColumnFiltering="False"
                    AllowSorting="False"
                    FieldName="CartImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Add to Cart" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Tapped="Grid_Tapped">
                                <Image
                                    x:Name="cartImage"
                                    Width="27"
                                    Height="27"
                                    Source="{Binding IsAddedToCart, Mode=TwoWay, Converter={StaticResource cartImageCovnerter}}" />

                                <!--  Source="{StaticResource CartUnselected}" />  -->
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>
            </DE:GridControl.Columns>
        </DE:GridControl>
        <Grid
            Grid.Row="1"
            Grid.RowSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{Binding LoadingVisibility}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>

        <!--<DE:GridControl
                                x:Name="DataGridcontrol"
                                Grid.Row="2"
                                AlternationCount="2"
                                AutoGenerateColumns="False"
                                FontSize="{StaticResource DataGridTextSize}"
                                ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                ShowAutoFilterRow="False"
                                ShowCriteriaInAutoFilterRow="True"
                                ShowGroupPanel="False"
                                ShowGroupedColumns="False">
            <DE:GridControl.Columns>
                <DE:GridTemplateColumn
                                        x:Name="itemImage"
                                        Width="80"
                                        AllowColumnFiltering="False"
                                        FieldName="ItemImage">
                    <DE:GridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" />
                        </DataTemplate>
                    </DE:GridTemplateColumn.HeaderTemplate>
                    <DE:GridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid >
                                <Image
                                                        x:Name="popItemImage"
                                                        Width="80"
                                                        Height="80"
                                                        Source="{StaticResource RackItemPlaceHolder}" />
                            </Grid>
                        </DataTemplate>
                    </DE:GridTemplateColumn.CellTemplate>
                </DE:GridTemplateColumn>

                <DE:GridTextColumn
                                        Width="90"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="Item"
                                        TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                  <DE:GridTextColumn
                                        Width="200"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="ItemDescription"
                                        TextWrapping="Wrap">
                    <DE:GridTextColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item Description" />
                        </DataTemplate>
                    </DE:GridTextColumn.HeaderTemplate>
                </DE:GridTextColumn>

                <DE:GridTemplateColumn
                                        x:Name="quantity"
                                        MinWidth="160"
                                        AllowColumnFiltering="False"
                                        AllowSorting="True"
