<Page
    x:Class="DRLMobile.Uwp.View.EditActivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DE="using:DevExpress.UI.Xaml.Grid"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:convertes="using:DRLMobile.Uwp.Converters"
    xmlns:core="using:Microsoft.Xaml.Interactions.Core"
    xmlns:customControl="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helper="using:DRLMobile.Uwp.Helpers"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:local="using:DRLMobile.Uwp.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="using:System"
    xmlns:vm="using:DRLMobile.Uwp.ViewModel"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Page.Resources>
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="GridHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource CartTextColor}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalTextAlignment" Value="Center" />
        </Style>
        <!--  ✅ FIXED: Use non-zero offset to enable DynamicWidthBehavior  -->
        <Style
            x:Key="DynamicWidthBehaviorStyle"
            BasedOn="{StaticResource EditTextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="helper:DynamicWidthBehavior.WidthOffset" Value="-20" />
        </Style>
        <Style
            x:Key="FixedMaxWidthStyle"
            BasedOn="{StaticResource FieldTextBlockStyle}"
            TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="5,5,0,0" />
            <!--<Setter Property="MinWidth" Value="120" />-->
        </Style>
        <convertes:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <convertes:BoolToInvertBoolConverter x:Key="BoolToInvertBoolConverter" />
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <customControl:HeaderControl
            Title="EDIT ACTIVITY"
            ButtonClick="{x:Bind ViewModel.SaveCommand}"
            CustomIconButtonVisibility="{x:Bind ViewModel.IsSaveIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            HoverImageSource="{StaticResource SaveIconHover}"
            NormalImageSource="{StaticResource SaveIconNormal}" />
        <!--  ✅ Replaced StackPanel with responsive Grid  -->
        <ScrollViewer
            x:Name="MainScrollViewer"
            Grid.Row="1"
            Background="{StaticResource LoginBackgroundColor}"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <!--  ✅ Key: Bind Width to ScrollViewer's viewport  -->
            <Grid
                x:Name="FormGrid" Padding="40,10,140,0"
                MinWidth="300"
                >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!--  Row 0: Call Date + Activity Type  -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Call Date" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <CalendarDatePicker
                            Grid.Column="1"
                            Margin="30,0,0,0"
                            VerticalAlignment="Center"
                            Background="White"
                            Date="{x:Bind ViewModel.UIModel.CallDate, Mode=TwoWay}"
                            DateFormat="{}{month.abbreviated(3)} {day.integer}, {year.full}"
                            IsEnabled="{x:Bind ViewModel.IscallDateEditable, Mode=OneWay}" />
                    </Grid>
                    <Grid Grid.Column="1" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Activity Type" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <Grid
                                Name="ActivityTypeGrid"
                                Grid.Column="0"
                                Margin="30,5,0,0"                                
                                HorizontalAlignment="Stretch"
                                Background="White"
                                CornerRadius="5"
                                Tapped="OpenActivityTypeFlyout">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <FlyoutBase.AttachedFlyout>
                                    <Flyout
                                        x:Name="ActivityTypeFlyout"
                                        FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                                        LightDismissOverlayMode="Off"
                                        Placement="Bottom">
                                        <Grid
                                            MinWidth="200"
                                            Background="White"
                                            BorderBrush="Black"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                            <ListView
                                                Grid.Row="1"
                                                ItemsSource="{x:Bind ViewModel.ActivityTypeList, Mode=OneWay}"
                                                SelectionMode="None">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Background="Transparent" Tapped="ActivityTypeSelected">
                                                            <TextBlock
                                                                Margin="5"
                                                                Text="{Binding}"
                                                                TextWrapping="WrapWholeWords" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Flyout>
                                </FlyoutBase.AttachedFlyout>
                                <TextBox
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    BorderThickness="0"
                                    IsHitTestVisible="False"
                                    IsReadOnly="True"
                                    TextAlignment="Left"
                                    Style="{StaticResource NoHoverTextBoxStyle}"
                                    Text="{x:Bind ViewModel.UIModel.SelectedActivityType, Mode=TwoWay}" />
                                <FontIcon
                                    Grid.Column="1"
                                    Margin="0,0,10,0"
                                    FontSize="12"
                                    Glyph="{StaticResource DownArrowIcon}"
                                    Style="{StaticResource FontIconStyle}" />
                            </Grid>
                            <!--  ✅ Replaced x:Load with Visibility  -->
                            <FontIcon
                                x:Name="AttachmentIcon"
                                Grid.Column="1"
                                Margin="20,0,-20,0"
                                FontSize="30"
                                Glyph="{StaticResource AttachmentIcon}"
                                Style="{StaticResource FontIconStyle}"
                                Tapped="OpenAttachmentTypeFlyout"
                                Visibility="{x:Bind ViewModel.IsAttachmentIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <FontIcon.RenderTransform>
                                    <RotateTransform Angle="45" CenterX="10" CenterY="0" />
                                </FontIcon.RenderTransform>
                                <FlyoutBase.AttachedFlyout>
                                    <Flyout
                                        x:Name="AttachmentTypeFlyout"
                                        FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                                        LightDismissOverlayMode="Off"
                                        Placement="Bottom">
                                        <StackPanel Background="White" CornerRadius="10">
                                            <Button
                                                Width="100"
                                                Margin="10"
                                                Background="White"
                                                Command="{x:Bind ViewModel.OpenPickerCommand}"
                                                CommandParameter="camera"
                                                Content="Take Photo" />
                                            <Button
                                                Width="120"
                                                Margin="10"
                                                Background="White"
                                                Command="{x:Bind ViewModel.OpenPickerCommand}"
                                                CommandParameter="picker"
                                                Content="Photo Library" />
                                            <!--  ✅ Replaced x:Load with Visibility  -->
                                            <Button
                                                x:Name="BtnDocumentPicker"
                                                Width="120"
                                                Margin="10"
                                                Background="White"
                                                Command="{x:Bind ViewModel.OpenPickerCommand}"
                                                CommandParameter="doc"
                                                Content="Document"
                                                Visibility="{x:Bind ViewModel.IsNarrativeWeeklyReport, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Flyout>
                                </FlyoutBase.AttachedFlyout>
                            </FontIcon>
                            <!--  ✅ Replaced x:Load with Visibility  -->
                            <FontIcon
                                x:Name="AttachementPreviewIcon"
                                Grid.Column="2"
                                Margin="20,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="35"
                                Glyph="{StaticResource PreviewIcon}"
                                Style="{StaticResource FontIconStyle}"
                                Visibility="{x:Bind ViewModel.IsPreviewIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <i:Interaction.Behaviors>
                                    <core:EventTriggerBehavior EventName="Tapped">
                                        <core:InvokeCommandAction Command="{x:Bind ViewModel.PreviewCommand, Mode=OneWay}" />
                                    </core:EventTriggerBehavior>
                                </i:Interaction.Behaviors>
                            </FontIcon>
                        </Grid>
                    </Grid>
                </Grid>
                <!--  Row 1: Created By + Team  -->
                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Created By" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <TextBox
                            Grid.Column="1"
                            Margin="20,3,0,5"
                            VerticalAlignment="Top"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind ViewModel.UIModel.CreatedBy, Mode=OneWay}" />
                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Team" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <TextBox
                            Grid.Column="1"
                            Margin="20,3,0,5"
                            VerticalAlignment="Top"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind ViewModel.UIModel.Team, Mode=OneWay}" />
                    </Grid>
                </Grid>
                <!--  Row 2: Account No + Account Name  -->
                <Grid Grid.Row="2" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Account No" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <TextBox
                            Grid.Column="1"
                            Margin="20,3,0,5"
                            helper:DynamicWidthBehavior.WidthOffset="-40"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind ViewModel.UIModel.AccountNo, Mode=OneWay}" />
                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Account Name" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <Grid
                            Name="AccountNameGrid"
                            Grid.Column="1"
                            Margin="30,5,0,0"
                            HorizontalAlignment="Stretch"
                            Background="White"
                            CornerRadius="5"
                            Tapped="OpenAccountSelectionFlyout">
                            <FlyoutBase.AttachedFlyout>
                                <Flyout
                                    x:Name="CustomerSelectionFlyout"
                                    FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                                    LightDismissOverlayMode="Off"
                                    Placement="Bottom">
                                    <Grid
                                        Height="300"
                                        MinWidth="300"
                                        Background="White"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBox
                                            Grid.Row="0"
                                            Margin="10"
                                            PlaceholderText="Search Customer"
                                            Visibility="Collapsed" />
                                        <ListView
                                            Grid.Row="1"
                                            ItemsSource="{x:Bind ViewModel.CustomerList, Mode=OneWay}"
                                            SelectionMode="None">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Background="Transparent" Tapped="CustomerSelected">
                                                        <TextBlock Margin="5" TextWrapping="WrapWholeWords">
                                                            <TextBlock.Inlines>
                                                                <Run FontWeight="SemiBold" Text="{Binding CustomerName}" />
                                                                <Run Text="&#x0a;" />
                                                                <Run Text="{Binding CustomerNumber}" />
                                                            </TextBlock.Inlines>
                                                        </TextBlock>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </Flyout>
                            </FlyoutBase.AttachedFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch"
                                TextAlignment="Left"
                                BorderThickness="0"
                                IsHitTestVisible="False"
                                IsReadOnly="True"
                                Style="{StaticResource NoHoverTextBoxStyle}"
                                Text="{x:Bind ViewModel.UIModel.AccountName, Mode=TwoWay}" />
                            <FontIcon
                                Grid.Column="1"
                                Margin="0,0,10,0"
                                FontSize="12"
                                Glyph="{StaticResource DownArrowIcon}"
                                Style="{StaticResource FontIconStyle}" />
                        </Grid>
                        <TextBox
                            Grid.Column="1"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Visibility="Collapsed" />
                    </Grid>
                </Grid>
                <!--  Row 3: City + State  -->
                <Grid Grid.Row="3" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Top" Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="City" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <TextBox
                            Grid.Column="1"
                            Margin="20,3,0,5"
                            VerticalAlignment="Top"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind ViewModel.UIModel.City, Mode=OneWay}" />
                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Top" Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="State" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <TextBox
                            Grid.Column="1"
                            Margin="20,3,0,5"
                            VerticalAlignment="Top"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind ViewModel.UIModel.State, Mode=OneWay}" />
                    </Grid>
                </Grid>
                <!--  Row 4: Amount + Consumer Activation  -->
                <Grid Grid.Row="4" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Amount" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <TextBox
                            Grid.Column="1"
                            Margin="20,3,0,5"
                            VerticalAlignment="Top"
                             HorizontalAlignment="Stretch"
                            Style="{StaticResource ViewOnlyTextBoxStyle}"
                            Text="{x:Bind ViewModel.UIModel.Amount, Mode=OneWay}" />
                    </Grid>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <!--  Label spanning both rows in column 0  -->
                        <TextBlock
                            Grid.RowSpan="2"
                            Style="{StaticResource FixedMaxWidthStyle}"
                            Text="Consumer Activation Engagement :"  />
                        <!--  TextBox in row 0, column 1  -->
                        <Grid Grid.Row="0" Margin="30,0,0,0" HorizontalAlignment="Stretch"
                            Grid.Column="1">
                            <TextBox                           
                            Style="{StaticResource EditTextBoxStyle}" HorizontalAlignment="Stretch" Margin="0"
                            Text="{x:Bind ViewModel.UIModel.ConsumerActivationEngagement, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <!--  Validation TextBlock in row 1, column 1  -->
                        <TextBlock
                            x:Name="TxtActivationValid"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="30,10,0,0"
                            HorizontalAlignment="Left"
                            helper:DynamicWidthBehavior.WidthOffset="-20"
                            FontSize="14"
                            Foreground="Red"
                            Text="{x:Bind ViewModel.UIModel.ErrorConsumerActivationEngagement, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.UIModel.IsInValidConsumerActivationEngagement, Mode=TwoWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </Grid>
                <!--  Row 5: Hours  -->
                <Grid Grid.Row="5" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Hours" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <Grid
                            x:Name="HoursGrid"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Margin="33,5,0,0"
                            Background="White"
                            CornerRadius="5"
                            Tapped="OpenHoursFlyout">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <FlyoutBase.AttachedFlyout>
                                <Flyout
                                    x:Name="HoursFlyout"
                                    FlyoutPresenterStyle="{StaticResource ErrorFlyoutPresenterStyle}"
                                    LightDismissOverlayMode="Off"
                                    Placement="Bottom">
                                    <Grid
                                        MinWidth="200"
                                        Background="White"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <ListView
                                            Grid.Row="1"
                                            SelectionChanged="HoursSelected"
                                            SelectionMode="Single">
                                            <x:String>1</x:String>
                                            <x:String>2</x:String>
                                            <x:String>3</x:String>
                                            <x:String>4</x:String>
                                            <x:String>5</x:String>
                                            <x:String>6</x:String>
                                            <x:String>7</x:String>
                                            <x:String>8</x:String>
                                        </ListView>
                                    </Grid>
                                </Flyout>
                            </FlyoutBase.AttachedFlyout>
                            <TextBox
                                Grid.Column="0"
                                TextAlignment="Left"
                                HorizontalAlignment="Stretch"
                                BorderThickness="0"
                                IsHitTestVisible="False"
                                IsReadOnly="True"
                                Style="{StaticResource NoHoverTextBoxStyle}"
                                Text="{x:Bind ViewModel.UIModel.Hours, Mode=TwoWay}" />
                            <FontIcon
                                Grid.Column="1"
                                Margin="0,0,10,0"
                                FontSize="12"
                                Glyph="{StaticResource DownArrowIcon}"
                                Style="{StaticResource FontIconStyle}" />
                        </Grid>
                    </Grid>
                </Grid>
                <!--  Row 6: Market(s) Visited + Calls Made vs Goal  -->
                <Grid 
                    x:Name="grdNarrativeRow0"
                    Grid.Row="6" Margin="0,5,0,0"
                    Visibility="{x:Bind ViewModel.IsNarrativeWeeklyReport, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"  />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Market(s) Visited" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <TextBox
                            Grid.Column="1"
                            Height="200"
                            MaxHeight="250"
                            AcceptsReturn="True"
                            MaxLength="4000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Text="{x:Bind ViewModel.UIModel.MarketsVisited, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Column="1" Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Calls Made vs Goal" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <TextBox
                            Grid.Column="1"
                            Height="200"
                            MaxHeight="250"
                            AcceptsReturn="True"
                            MaxLength="4000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Text="{x:Bind ViewModel.UIModel.CallsMadeVsGoal, Mode=TwoWay}" />
                    </Grid>
                </Grid>
                <!--  Row 7: New Customer + Key Wins  -->
                <Grid
                    x:Name="grdNarrativeRow1"
                    Grid.Row="7"  Margin="0,5,0,0"
                    Visibility="{x:Bind ViewModel.IsNarrativeWeeklyReport, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FixedMaxWidthStyle}">
                            <TextBlock.Inlines>
                                <Run Text="New Customer Acquisitions" />
                                <Run x:Uid="Colon" d:Text=":" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <TextBox
                            Grid.Column="1"
                            Height="200"
                            MaxHeight="250"
                            AcceptsReturn="True"
                            MaxLength="4000"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DynamicWidthBehaviorStyle}"
                            Text="{x:Bind ViewModel.UIModel.NewCustomerAcquisitions, Mode=TwoWay}" />
                    </Grid>
                    <Grid Grid.Column="1" Margin="20,0,0,0">
                        <Grid.ColumnDefinitions>
