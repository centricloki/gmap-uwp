                                        FieldName="DisplayProductUnitPrice"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Unit Price" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                    <DE:GridTextColumn
                                        AllowSorting="True"
                                        AutoFilterCriteria="Contains"
                                        FieldName="DisplayProductSubtotal"
                                        TextWrapping="Wrap">
                                        <DE:GridTextColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Sub Total" />
                                            </DataTemplate>
                                        </DE:GridTextColumn.HeaderTemplate>
                                    </DE:GridTextColumn>
                                </DE:GridControl.Columns>
                            </DE:GridControl>
                            <StackPanel
                                Grid.Row="1"
                                HorizontalAlignment="Right"
                                Background="{ThemeResource LoginButtonBackground}">
                                <StackPanel
                                    Padding="10,10,50,10"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="5">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="Sub Total:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Foreground="{StaticResource CartTextColor}"
                                        Text="{x:Bind ViewModel.TotalDifTobacco, Mode=OneWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </controls:Expander>
                </StackPanel>
                <!--  Row 17: Rack POS Grid  -->
                <DE:GridControl
                    x:Name="rackPosGrid"
                    Grid.Row="17"
                    Margin="100,0,0,0"
                    AlternationCount="2"
                    AutoGenerateColumns="False"
                    FontSize="{StaticResource DataGridTextSize}"
                    ItemsSource="{x:Bind ViewModel.RackPosPopOrderDetailsItemSource, Mode=OneWay}"
                    ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                    ShowAutoFilterRow="False"
                    ShowCriteriaInAutoFilterRow="True"
                    ShowGroupPanel="False"
                    ShowGroupedColumns="False"
                    Visibility="{x:Bind ViewModel.LoadRackPosPopGrid, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <DE:GridControl.Columns>
                        <DE:GridTextColumn
                            Width="70"
                            AllowColumnFiltering="False"
                            AllowSorting="False"
                            AutoFilterCriteria="Contains"
                            FieldName="DisplayProductName"
                            TextWrapping="Wrap">
                            <DE:GridTextColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Item" />
                                </DataTemplate>
                            </DE:GridTextColumn.HeaderTemplate>
                        </DE:GridTextColumn>
                        <DE:GridTemplateColumn
                            x:Name="quantity"
                            MinWidth="50"
                            AllowColumnFiltering="False"
                            AllowSorting="False"
                            FieldName="ProductQty">
                            <DE:GridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource GridHeaderStyle}" Text="Quantity" />
                                </DataTemplate>
                            </DE:GridTemplateColumn.HeaderTemplate>
                            <DE:GridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox
                                        x:Name="quantityTextBlock"
                                        Width="60"
                                        HorizontalAlignment="Left"
                                        Foreground="{StaticResource LoginScreenTextFontColor}"
                                        IsReadOnly="True"
                                        MaxLength="4"
                                        Text="{Binding ProductQty, Mode=TwoWay}" />
                                </DataTemplate>
                            </DE:GridTemplateColumn.CellTemplate>
                        </DE:GridTemplateColumn>
                    </DE:GridControl.Columns>
                </DE:GridControl>
                <!--  Row 18: Grand Total  -->
                <StackPanel
                    x:Name="grandTotalStackPanel"
                    Grid.Row="18"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Right"
                    Background="{ThemeResource LoginButtonBackground}"
                    Visibility="{x:Bind ViewModel.LoadTotalStackPanel, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel
                        Padding="10,10,50,10"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="5">
                        <TextBlock
                            HorizontalAlignment="Right"
                            FontWeight="Bold"
                            Foreground="{StaticResource CartTextColor}"
                            Text="Grand Total: " />
                        <TextBlock
                            HorizontalAlignment="Right"
                            Foreground="{StaticResource CartTextColor}"
                            Text="{x:Bind ViewModel.CombineTotal, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
                <!--  Row 19: Save/Cancel Buttons  -->
                <StackPanel
                    Grid.Row="19"
                    Margin="30"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="60">
                    <Button
                        x:Name="ButtonSaveIcon"
                        Width="100"
                        HorizontalAlignment="Left"
                        Command="{x:Bind ViewModel.SaveCommand}"
                        Content="Save"
                        Visibility="{x:Bind ViewModel.IsSaveIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button
                        x:Name="ButtonCancelIcon"
                        Width="100"
                        HorizontalAlignment="Right"
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Content="Cancel"
                        Visibility="{x:Bind ViewModel.IsSaveIconVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
                <!--  Row 20: Bottom Spacer  -->
                <Rectangle Grid.Row="20" Height="50" />
            </Grid>
        </ScrollViewer>
        <!--  Loading Overlay  -->
        <Grid
            x:Name="ProgressRingGrid"
            Grid.Row="0"
            Grid.RowSpan="3"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            d:Visibility="Collapsed"
            Background="Black"
            Opacity="0.7"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressRing
                Width="100"
                Height="100"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="White"
                IsActive="True" />
        </Grid>
    </Grid>
</Page>