                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="25" />
                                        </Grid.ColumnDefinitions>

                                        <!--<TextBlock Grid.Column="0" Text="{Binding DistributorID}" />-->
                                        <TextBlock Grid.Column="0" MinWidth="375" HorizontalAlignment="Stretch"
                    TextWrapping="Wrap"  FontWeight="Medium" FontSize="12"  Padding="0,10,0,10" >
                                            <TextBlock.Inlines>
                                                <Run Text="{Binding FullName}" />
                                                <LineBreak/>
                                                <Run FontStyle="Italic" FontWeight="Normal" FontSize="11" Text="{Binding AssignUserName}" />
                                            </TextBlock.Inlines>
                                        </TextBlock>
                                        <Grid
                    Grid.Column="1"
                    Background="Transparent"
                    Tapped="DistributorDeletedIconTapped">
                                            <FontIcon 
                        Margin="3"
                        HorizontalAlignment="Right"                                                
                        FontSize="14"
                        Foreground="Red"
                        Glyph="{StaticResource DeleteIcon}"
                        Style="{StaticResource FontIconStyle}"
                        Visibility="{Binding IsDeleteIconVisibile}" />
                                        </Grid>
                                    </Grid>

                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </customControls:AlternateRowColorListView>
                    </Grid>

                    <Grid x:Name="gridWeekDays" Margin="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"  />
                            <ColumnDefinition  Width="2*"  />
                        </Grid.ColumnDefinitions>

                        <TextBlock 
    VerticalAlignment="Top" Grid.Column="0" Margin="0" HorizontalAlignment="Left"
    Style="{StaticResource FieldTextBlockStyle}">
                            <TextBlock.Inlines>
                                <Run Text="Store Truck / Order Delivery Date :"/>
                            </TextBlock.Inlines>
                        </TextBlock>
                        <customControls:AlternateRowColorListView
    CornerRadius="5" Grid.Column="1" HorizontalAlignment="Left" Margin="20,0,0,0" Width="250" 
    ItemsSource="{x:Bind ViewModel.Weekdays, Mode=TwoWay}"
    SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="uim:WeekdayUIModel">
                                    <StackPanel Orientation="Horizontal" >
                                        <!-- Bind to the parent's DataContext property -->
                                        <CheckBox Content="{x:Bind Name}" IsChecked="{x:Bind IsSelected, Mode=TwoWay}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </customControls:AlternateRowColorListView>
                    </Grid>

                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!--  Loader  -->
        <Grid
        x:Name="ProgressRingGrid"
        Grid.Row="0"
        Grid.RowSpan="2"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        d:Visibility="Collapsed"
        x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
        Background="Black"
        Opacity="0.7">
            <ProgressRing
          Width="100"
          Height="100"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Foreground="White"
          IsActive="True" />
        </Grid>

    </Grid>

</Page>