<Page
    x:Class="DRLMobile.Uwp.View.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.Toolkit.Uwp.UI.Controls"
    xmlns:converters="using:DRLMobile.Uwp.Converters"
    xmlns:customControls="using:DRLMobile.Uwp.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="using:Microsoft.Xaml.Interactivity"
    xmlns:ic="using:Microsoft.Xaml.Interactions.Core"
    xmlns:local="using:DRLMobile.Uwp.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Microsoft.Toolkit.Uwp.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    RequestedTheme="Light"
    mc:Ignorable="d">
    <Page.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
        </Style>

        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <SplitView
            x:Name="MainSplitView"
            CompactPaneLength="45"
            DisplayMode="CompactInline"
            IsPaneOpen="{x:Bind ViewModel.IsPaneOpen, Mode=TwoWay}"
            OpenPaneLength="200"
            PaneBackground="{StaticResource R255_G38_B0}">
            <SplitView.Pane>
                <ScrollViewer HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Visible">
                    <StackPanel Spacing="0">
                        <Button
                            x:Name="BtnSideMenu"
                            Margin="0"
                            Padding="0"
                            x:Load="{x:Bind ViewModel.IsBackEnabled, Mode=OneWay}"
                            Background="LightGray"
                            Command="{x:Bind ViewModel.SideMenuItemClicked}"
                            CommandParameter="Back">
                            <FontIcon
                                Width="40"
                                Height="40"
                                Margin="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FontSize="19"
                                Foreground="Black"
                                Glyph="{StaticResource BackIcon}"
                                Style="{StaticResource FontIconStyle}"
                                ToolTipService.ToolTip="Back" />
                            <!--<i:Interaction.Behaviors>
                                    <ic:EventTriggerBehavior EventName="Tapped">
                                        <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Back" />
                                    </ic:EventTriggerBehavior>
                                </i:Interaction.Behaviors>-->

                        </Button>

                        <Button
                            Margin="0"
                            Padding="0"
                            Background="Transparent"
                            Command="{x:Bind ViewModel.SideMenuItemClicked}"
                            CommandParameter="Menu">
                            <FontIcon
                                Width="40"
                                Height="40"
                                Margin="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FontSize="23"
                                FontWeight="Bold"
                                Foreground="Black"
                                Glyph="{StaticResource NavIcon}"
                                Style="{StaticResource FontIconStyle}"
                                ToolTipService.ToolTip="Menu" />
                            <!--<i:Interaction.Behaviors>
                                    <ic:EventTriggerBehavior EventName="Tapped">
                                        <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Menu" />
                                    </ic:EventTriggerBehavior>
                                </i:Interaction.Behaviors>-->

                        </Button>

                        <Grid Background="Transparent" ToolTipService.ToolTip="Home">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Home" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                            <FontIcon
                                Width="40"
                                Height="40"
                                Margin="4"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FontSize="29"
                                FontWeight="ExtraLight"
                                Foreground="{StaticResource DashboardHomeButtonColor}"
                                Glyph="{StaticResource HomeIcon}"
                                Style="{StaticResource FontIconStyle}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Text="Home" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="SRC/Product">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Product" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource SrcNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="SRC/Product" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Cart">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Cart" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource CartNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="Cart" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Customer">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Customer" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource CustomerNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="Customer" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Favorite">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Favorite" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>


                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource FavoriteNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="Favorite" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Route Lists">

                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Route" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource RouteListNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="Route Lists" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Settings">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Settings" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource SettingNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="Settings" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Activities">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Activities" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource ActivitiesNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="Activities" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Map">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Map" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource MapNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="Map" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Sync">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Sync" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource SyncNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="Sync" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Rack Order">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Rack" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>


                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource RackOrderNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="Rack Order" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Pop Order">

                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Pop" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>


                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource PopOrderNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="Pop Order" />
                        </Grid>

                        <Grid
                            Margin="0,10,0,0"
                            Background="Transparent"
                            ToolTipService.ToolTip="Travel/VRIP">
                            <i:Interaction.Behaviors>
                                <ic:EventTriggerBehavior EventName="Tapped">
                                    <ic:InvokeCommandAction Command="{x:Bind ViewModel.SideMenuItemClicked}" CommandParameter="Travel" />
                                </ic:EventTriggerBehavior>
                            </i:Interaction.Behaviors>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Image
                                Width="40"
                                Height="30"
                                Source="{StaticResource TravelNormal}" />


                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                Text="Travel/VRIP" />
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </SplitView.Pane>

            <Frame Name="MainFrame" />
        </SplitView>

        <customControls:FooterControl
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            IsLoggedInVisible="Visible"
            IsSyncVisible="Visible"
            LoggedInUsername="{x:Bind ViewModel.TempUserName, Mode=OneWay}"
            SyncDateTime="{x:Bind ViewModel.LastSyncDateTime, Mode=TwoWay}" />

        <toolkit:Loading
            x:Name="LoadingView"
            Grid.Row="0"
            Grid.RowSpan="2"
            x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            IsLoading="{x:Bind ViewModel.IsLoading, Mode=TwoWay}">
            <controls:Loading.Background>
                <SolidColorBrush Opacity="0.4" Color="Black" />
            </controls:Loading.Background>

            <ProgressRing
                Name="ProgressRing"
                x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                Foreground="White"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=TwoWay}" />
        </toolkit:Loading>

    </Grid>
</Page>
